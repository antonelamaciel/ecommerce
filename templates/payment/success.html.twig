{% extends 'base.html.twig' %}

{% block title %}¡Pedido Confirmado! - {{ personalize.companyName }}{% endblock %}

{% block body %}
<style>
    :root {
        --c-success: #28a745;
        --c-bg: #fcfbf9;
        --radius-lg: 24px;
        --shadow: 0 10px 40px rgba(0,0,0,.04);
    }
    .success-container {
        padding: 4rem 1rem;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 60dvh;
    }
    .success-card {
        background: #fff;
        border-radius: var(--radius-lg);
        padding: 4rem;
        max-width: 600px;
        width: 100%;
        text-align: center;
        box-shadow: var(--shadow);
        border: 1px solid #f0ede8;
    }
    
    @media (max-width: 767px) {
        .success-container { padding: 2rem 1rem; min-height: auto; }
        .success-card { padding: 2.5rem 1.5rem; border-radius: 16px; }
        .success-icon { font-size: 3.5rem; margin-bottom: 1.5rem; }
        .status-badge { padding: 0.4rem 1.25rem; font-size: 0.8rem; margin-bottom: 1.5rem; }
        h1 { font-size: 1.5rem !important; }
        .text-muted.fs-5 { font-size: 1rem !important; }
    }
    
    .success-icon {
        font-size: 5.5rem;
        color: var(--c-success);
        margin-bottom: 2rem;
        display: inline-block;
        animation: scaleIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) both;
    }
    @keyframes scaleIn {
        from { transform: scale(0); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
    
    .status-badge {
        display: inline-block;
        padding: 0.6rem 1.75rem;
        border-radius: 50px;
        background: #eafcf1;
        color: #10b981;
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 2rem;
    }
    
    .order-ref {
        font-family: monospace;
        background: #f8f9fa;
        padding: 0.25rem 0.75rem;
        border-radius: 6px;
        color: #1a1a1a;
        font-weight: bold;
    }
    
    .redirect-notice {
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid #f0ede8;
        font-size: 0.85rem;
        color: #999;
    }
    
    .progress-bar-container {
        width: 100%;
        height: 4px;
        background: #f0f0f0;
        border-radius: 2px;
        margin-top: 1rem;
        overflow: hidden;
    }
    
    .progress-bar-fill {
        height: 100%;
        background: var(--tertiary-color, #1a1a1a);
        width: 0%;
        transition: width 5s linear;
    }

    /* ── Dark Mode Overrides ── */
    body.dark-mode .success-card {
        background-color: #1e1e1e !important;
        border-color: #333 !important;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
    }
    body.dark-mode .status-badge {
        background-color: #06331a !important;
        color: #50e3a6 !important;
    }
    body.dark-mode .order-ref {
        background-color: #2a2a2a !important;
        color: #ffffff !important;
    }
    body.dark-mode .redirect-notice {
        border-top-color: #333 !important;
    }
    body.dark-mode h1 { color: #fff !important; }
</style>

<div class="container success-container">
    <div class="success-card">
        <div class="success-icon">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        
        <h1 class="fw-bold mb-3">¡Pedido Recibido!</h1>
        <div class="status-badge">Estado: Pago Aceptado</div>
        
        <p class="text-muted fs-5 mb-4">
            Hola <b class="text-dark-mode-adapt">{{ order.user.firstname }}</b>, tu pedido <span class="order-ref">#{{ order.reference }}</span> ha sido registrado correctamente.
        </p>

        <p class="text-muted">
            Te hemos enviado un correo electrónico con todos los detalles de tu compra.
        </p>

        <div class="redirect-notice">
            <p class="mb-2">Serás redirigido al detalle de tu pedido en unos segundos...</p>
            <div class="progress-bar-container">
                <div class="progress-bar-fill" id="redirectProgress"></div>
            </div>
            <div class="mt-3">
                <a href="{{ path('account_order', {'reference': order.reference}) }}" class="text-decoration-none fw-bold" style="color: var(--tertiary-color, #000);">
                    O haz clic aquí para ir ahora <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const progressFill = document.getElementById('redirectProgress');
    if (progressFill) {
        setTimeout(() => {
            progressFill.style.width = '100%';
        }, 100);
    }

    // Redirect after 5 seconds
    setTimeout(function() {
        window.location.href = "{{ path('account_order', {'reference': order.reference}) }}";
    }, 5000);
});
</script>

{% endblock %}