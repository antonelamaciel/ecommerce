{# templates/_pcard.html.twig #}
{% set is_popular = is_popular|default(false) %}
{% set buy_btn_text = buy_btn_text|default('Comprar') %}
{% set suffix = suffix|default('gen') %}

{% set maxBundleDiscount = product.getMaxDiscount() %}
{% set finalPrice = maxBundleDiscount > 0 ? product.price * (1 - maxBundleDiscount / 100) : product.price %}

<article class="pcard" 
         data-price="{{ finalPrice }}"
         data-stock="{{ product.stock }}"
         data-date="{{ product.id }}"
         data-url="{{ path('product_show', {slug: product.slug}) }}">
         
    {% if is_popular %}
        <span class="pcard__badge mt-2">Popular</span>
    {% endif %}
    
    {% for bundle in product.bundles %}
        {% if bundle.topRightBadge %}
            {% set badgeText = bundle.topRightBadge == 'envio_gratis' ? 'Envío gratis' : 
                               (bundle.topRightBadge == 'recomendado' ? 'Recomendado' : 'Más vendido') %}
            <span class="top-badge-right">{{ badgeText }}</span>
        {% endif %}
    {% endfor %}
    
    {% set firstVariant = null %}
    {% for option in product.options %}
        {% if option.isAvailable and not firstVariant %}
            {% for value in option.productOptionValues %}
                {% if value.isAvailable and not firstVariant %}
                    {% set firstVariant = option.name ~ ': ' ~ value.name %}
                {% endif %}
            {% endfor %}
        {% endif %}
    {% endfor %}

    <div class="pcard__img-wrap">
        <a href="{{ path('product_show', {slug: product.slug}) }}">
            {% if product.image %}
                <img class="pcard__img" src="/uploads/{{ product.image }}" alt="{{ product.name }}" data-extra-images="{{ product.images|default([])|json_encode }}">
            {% else %}
                <div class="pcard__img d-flex align-items-center justify-content-center" style="background-color: #f8fafc;">
                   <svg width="100" height="100" viewBox="144 144 512 512" fill="#ffc8f4ff" stroke="#ffc8f4ff" stroke-width="2" xmlns="http://www.w3.org/2000/svg"><defs><clipPath id="a"><path d="m173 148.09h459V651.9H173z"/></clipPath></defs><g clip-path="url(#a)"><path d="m532.71 245.05c-.47266-5.0781-4.7461-8.9609-9.8594-8.9609h-49.094c.10156 1.8906.16016 3.793.16016 5.7109v28.238c6.0039 5.5 9.5664 13.344 9.5664 21.59.0 16.156-13.176 29.301-29.371 29.301s-29.371-13.145-29.371-29.301c0-8.2461 3.5625-16.094 9.5664-21.59V241.8c0-1.9258-.10156-3.8281-.26953-5.7109h-127.91c-.16797 1.8828-.26953 3.7852-.26953 5.7109v27.594c6.4375 5.5039 10.254 13.578 10.254 22.234.0 16.156-13.176 29.301-29.371 29.301s-29.371-13.145-29.371-29.301c0-8 3.2461-15.508 8.8789-20.973V241.8c0-1.918.058594-3.8203.16016-5.7109h-48.406c-5.1133.0-9.3828 3.8828-9.8594 8.9609l-34.824 372.05c-.26172 2.7656.66016 5.5156 2.5391 7.5703 1.875 2.0547 4.5312 3.2266 7.3203 3.2266h260.02c-16.254-20.031-26.004-45.52-26.004-73.234.0-64.297 52.434-116.61 116.88-116.61 5.707.0 11.316.41797 16.809 1.2109zm28.359 285.77c-3.3203-2.4805-5.6328-2.4492-7.082-2.207-4.9141.81641-9.7344 6.1602-11.426 8.4609-1.7891 2.9414-4.9961 4.7578-8.4688 4.7578-3.4336.0-6.6133-1.7734-8.4141-4.6523-1.5625-2.1758-6.4883-7.7305-11.504-8.5664-.35938-.058593-.76563-.10547-1.2266-.10547-1.4219.0-3.3516.44141-5.8555 2.3125-4.4961 3.3594-6.543 7.1328-6.4336 11.883.10547 4.4961 2.9102 20.297 33.422 42.488 30.508-22.191 33.316-37.992 33.418-42.488.10938-4.75-1.9336-8.5273-6.4297-11.883m-20.953 74.297c-1.6875 1.2891-3.7891 2.0391-6.0234 2.0391-.003906-.003906-.003906-.003906-.011718.0-.003907-.003906-.011719-.003906-.015626.0h-.035156c-1.8867-.011719-3.6445-.54688-5.1406-1.4688-.24609-.14844-.48438-.3125-.71484-.48047-30.066-20.465-46.863-42.492-47.312-62.051-.25781-11.207 4.707-20.941 14.359-28.152 6.9062-5.1602 14.645-7.1797 22.367-5.8516 6.7305 1.1602 12.324 4.6484 16.492 8.2031 4.1641-3.5547 9.7617-7.043 16.488-8.2031 7.7266-1.3281 15.461.69141 22.371 5.8516 9.6523 7.2109 14.617 16.945 14.359 28.152-.44922 19.531-17.199 41.52-47.184 61.961m-6.0352-147.7c-53.75.0-97.477 43.625-97.477 97.242.0 53.621 43.727 97.246 97.477 97.246s97.477-43.625 97.477-97.246c0-53.617-43.727-97.242-97.477-97.242m-70.066-182.48v-33.137c0-51.672-42.137-93.707-93.93-93.707s-93.93 42.035-93.93 93.707v33.551c-5.3359 3.4688-8.8789 9.4648-8.8789 16.277.0 10.711 8.7344 19.422 19.469 19.422s19.469-8.7109 19.469-19.422c0-7.3867-4.1562-13.82-10.254-17.102v-32.727c0-40.777 33.254-73.949 74.125-73.949s74.125 33.172 74.125 73.949v33.137c-5.7148 3.3867-9.5664 9.5898-9.5664 16.691.0 10.711 8.7344 19.422 19.469 19.422 10.734.0 19.469-8.7109 19.469-19.422.0-7.1016-3.8516-13.305-9.5664-16.691" fill-rule="evenodd"/></g></svg>
                 </div>
            {% endif %}
        </a>

        {# MOBILE BUY BUTTON (Inside Image) #}
        {% if product.stock is not null and product.stock <= 0 %}
            <div class="pcard__buy-btn pcard__buy-btn-mobile disabled d-md-none" style="background: rgba(255,255,255,0.9); color: #dc3545 !important; cursor: not-allowed;">
                <span style="margin-right:0.25rem">Sin stock</span> <i class="bi bi-cart-x"></i>
            </div>
        {% else %}
            <a href="{{ path('product_show', {slug: product.slug}) }}" 
               class="pcard__buy-btn pcard__buy-btn-mobile pcard__buy-btn--p d-md-none" 
               data-add-cart-url="{{ path('add_to_cart', {id: product.id, variants: firstVariant}) }}"
               style="{% if personalize is defined and personalize and personalize.tertiaryColor %}background-color: {{ personalize.tertiaryColor }};{% endif %}">
                <span style="margin-right:0.25rem; font-size: 0.75rem;">Añadir</span> <i class="bi bi-cart-plus"></i>
            </a>
        {% endif %}
    </div>

    <div class="pcard__body">
        <h3 class="pcard__name">
            <a href="{{ path('product_show', {slug: product.slug}) }}">
                <span class="pcard__name-text"><b>{{ product.name }}</b></span>
            </a>
        </h3>

        {% if product.bundles|length > 0 %}
            <div class="pcard__pills-wrap" style="display: flex; gap: 4px; margin-top: 2px;">
                {% for bundle in product.bundles %}
                    <span class="bundle-pill" style="font-size: 0.6rem; color: #999; font-weight: 600; text-transform: uppercase;">
                        • {{ bundle.type == 'pocas_unidades' ? 'Pocas unidades' : (bundle.type == 'oferta_sorpresa' ? 'Oferta' : 'Promo') }}
                    </span>
                {% endfor %}
            </div>
        {% endif %}
        
        <div class="pcard__price" style="margin-top: 4px;">
            <div class="pcard__price-container">
                {% if maxBundleDiscount > 0 or (product.oldPrice and product.oldPrice != product.price) %}
                    {% set oldPrice = product.oldPrice ?: product.price %}
                    <span class="pcard__price-old">{{ (oldPrice / 100)|number_format(2, ',', '.') }}$</span>
                    <span class="pcard__price-main" style="{% if maxBundleDiscount > 0 %}color: #dc3545;{% elseif personalize is defined and personalize and personalize.tertiaryColor %}color: {{ personalize.tertiaryColor }};{% endif %}">
                        {{ (finalPrice / 100)|number_format(2, ',', '.') }}$ 
                        {% if maxBundleDiscount > 0 %}{{ maxBundleDiscount }}%OFF{% endif %}
                    </span>
                {% else %}
                    <span class="pcard__price-main" style="{% if personalize is defined and personalize and personalize.tertiaryColor %}color: {{ personalize.tertiaryColor }};{% endif %}">{{ (product.price / 100)|number_format(2, ',', '.') }}$</span>
                {% endif %}
            </div>
        </div>

        {% if product.stock is not null and product.stock <= 0 %}
            <div class="pcard__buy-btn disabled text-center d-none d-md-block" style="background: #f1f1f1; color: #999 !important; cursor: not-allowed; margin-top: auto;">
                Sin stock
            </div>
        {% else %}
            <a href="{{ path('product_show', {slug: product.slug}) }}" 
               class="pcard__buy-btn pcard__buy-btn--p d-none d-md-block" 
               data-add-cart-url="{{ path('add_to_cart', {id: product.id, variants: firstVariant}) }}"
               style="margin-top: auto; {% if personalize is defined and personalize and personalize.tertiaryColor %}background-color: {{ personalize.tertiaryColor }};{% endif %}">
                <span>Agregar al carrito</span>
            </a>
        {% endif %}
    </div>

    {# Hidden store for Quick View #}
    <div class="pcard__options-store d-none">
        {% if product.options|length > 0 %}
            <div class="product-options-interactive-store mb-2 mt-2 w-100">
                <div class="d-flex flex-wrap gap-1 justify-content-center mb-2 qv-parents-row">
                    {% for option in product.options %}
                        {% if option.isAvailable %}
                            <button type="button" 
                                    class="btn btn-sm btn-outline-dark rounded-pill px-3 qv-parent-btn {{ loop.first ? 'active' : '' }}" 
                                    data-target="qv-option-{{ suffix }}-{{ product.id }}-{{ option.id }}"
                                    data-image="{{ option.image }}">
                                {{ option.name }}
                            </button>
                        {% endif %}
                    {% endfor %}
                </div>

                {% for option in product.options %}
                    {% if option.isAvailable %}
                        <div class="qv-option-values {{ not loop.first ? 'd-none' : '' }}" id="qv-option-{{ suffix }}-{{ product.id }}-{{ option.id }}" data-group-name="{{ option.name }}">
                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                {% for value in option.productOptionValues %}
                                    <button type="button" 
                                            class="btn btn-sm qv-value-btn {{ value.isAvailable ? '' : 'option-unavailable' }}" 
                                            data-value-name="{{ value.name }}" 
                                            data-image="{{ value.image }}"
                                            {{ not value.isAvailable ? 'disabled' : '' }}>
                                        {{ value.name }}
                                    </button>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endif %}
    </div>
</article>
