{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}

<style>
  /* ── Tokens (Consistent with Home) ── */
  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561ff;
    --c-accent: #1a1a1a;
    --radius-lg: 32px;
    --radius-md: 20px;
    --radius-sm: 12px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }


  /* ── Check Animation ── */
  @keyframes checkPop {
    0% { transform: scale(0); opacity: 0; }
    40% { transform: scale(1.4); opacity: 1; }
    60% { transform: scale(0.9); }
    80% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }
  .check-animated {
    display: inline-flex;
    animation: checkPop 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* ── Qty Reset Animation ── */
  @keyframes qtyReset {
    0% { transform: scale(1); background: transparent; border-color: var(--c-border); }
    25% { transform: scale(1.3); background: rgba(25, 135, 84, 0.15); border-color: #198754; }
    50% { transform: scale(0.9); }
    75% { transform: scale(1.1); }
    100% { transform: scale(1); background: transparent; border-color: var(--c-border); }
  }
  .qty-reset-animate {
    animation: qtyReset 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .product-detail {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  /* ── Breadcrumbs ── */
  .custom-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    list-style: none;
    padding: 0;
    font-size: 0.85rem;
  }
  .custom-breadcrumb a {
    color: var(--c-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .custom-breadcrumb a:hover { color: var(--c-ink); }
  .custom-breadcrumb .separator { color: var(--c-border); font-size: 0.7rem; }
  .custom-breadcrumb .current { color: var(--c-ink); font-weight: 600; }

  /* ── Image Display ── */
  .pdetail-img-card {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    padding: 1.5rem 1rem;
    box-shadow: var(--shadow-soft);
    position: sticky;
    top: 100px;
    transition: var(--transition);
  }
  .pdetail-img-wrap {
    width: 100%;
    max-width: 500px;
    height: 420px;
    min-height: 280px;
    max-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 10px;
    background: #f8f8f8;
    margin: 0 auto;
  }
  .pdetail-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  /* ── Product Info ── */
  .pdetail-header { margin-bottom: 2rem; }
  .pdetail-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .pdetail-subtitle {
    font-size: 1.1rem;
    color: var(--c-muted);
    font-weight: 400;
  }

  .pdetail-price-box {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .pdetail-price {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .pdetail-tax-badge {
    font-size: 0.75rem;
    color: var(--c-muted);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    background: var(--c-border);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .pdetail-description {
    margin-bottom: 3rem;
  }
  .pdetail-section-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--c-muted);
    margin-bottom: 1.25rem;
    display: block;
  }
  .pdetail-content {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--c-ink);
    opacity: 0.9;
  }

  /* ── Actions ── */
  .pdetail-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .pdetail-add-grid {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .btn-pdetail-cart {
    background: var(--secondary-color, var(--primary-color, var(--c-ink)));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1.2rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: var(--transition);
  }
  .btn-pdetail-cart:hover {
    filter: brightness(1.1);
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: #fff;
  }
  .btn-pdetail-back {
    background: transparent;
    border: 1px solid var(--c-border);
    color: var(--c-muted);
    border-radius: var(--radius-md);
    padding: 1.2rem;
    font-weight: 500;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: var(--transition);
  }
  .btn-pdetail-back:hover {
    background: var(--c-border);
    color: var(--c-ink);
  }

  /* ── Features ── */
  .pdetail-features {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-border);
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--c-muted);
  }
  .feature-item i {
    font-size: 1.2rem;
    color: var(--c-ink);
  }

  @media (max-width: 991px) {
    .product-detail { padding-top: 1rem; padding-bottom: 2rem; }
    .custom-breadcrumb { margin-bottom: 1rem; font-size: 0.8rem; }
    
    .pdetail-img-card { padding: 0.5rem; margin-bottom: 1rem; }
    .pdetail-img-wrap { height: 260px; min-height: 200px; }
    
    .pdetail-header { margin-bottom: 0.5rem; }
    .pdetail-title { font-size: 1.5rem; margin-bottom: 0.25rem; line-height: 1.2; }
    .pdetail-subtitle { font-size: 0.9rem; }
    
    .pdetail-price-box { margin-bottom: 0.75rem; gap: 0.5rem; }
    .pdetail-price { font-size: 1.5rem; }
    
    .pdetail-description { margin-bottom: 1.5rem; }
    .pdetail-section-title { margin-bottom: 0.5rem; font-size: 0.8rem; }
    .pdetail-content { font-size: 0.9rem; line-height: 1.5; }
    
    .pdetail-add-grid { flex-wrap: nowrap; gap: 0.5rem; }
    #qty-control { padding: 0.1rem !important; }
    #qty-control button { width: 28px !important; height: 28px !important; font-size: 0.85rem; }
    #pd-qty { width: 24px !important; font-size: 0.9rem !important; }
    .btn-pdetail-cart { padding: 0.6rem 0.75rem; font-size: 0.9rem; }
    .btn-pdetail-back { padding: 0.6rem 0.75rem; font-size: 0.85rem; white-space: nowrap; }
    .pdetail-actions { margin-bottom: 1rem; }
    
    .pdetail-features { gap: 0.75rem; padding-top: 1rem; flex-direction: column; align-items: flex-start; }
    .feature-item { font-size: 0.85rem; gap: 0.5rem; }
    
    #pd-prev-img, #pd-next-img { display: none !important; }
    .pdetail-img-wrap { margin-left: 0 !important; margin-right: 0 !important; max-width: 100%; }
    
    /* Botón medios de pago más ajustado */
    .mb-4.d-flex.align-items-center { margin-bottom: 1rem !important; }
    .btn.btn-success { padding: 0.5rem 1rem; font-size: 0.85rem; }
    
    /* Calculador envios */

  }

  /* ── Related Products ── */
  .pcard {
    background: var(--c-surface);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    border: 1px solid var(--c-border);
    text-decoration: none;
    color: var(--c-ink);
  }
  .pcard:hover {
    box-shadow: 0 12px 40px rgba(0,0,0,.08);
    transform: translateY(-6px);
  }
  .pcard__img-wrap {
    aspect-ratio: 1/1;
    background: #fdfcfb;
    margin: 0.5rem;
    border-radius: calc(var(--radius-md) - 6px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .pcard__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    transition: transform .6s ease;
  }
  .pcard:hover .pcard__img { transform: scale(1.08); }
  
  .pcard__body {
    padding: 0.5rem 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    text-align: center;
  }
  .pcard__name {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
    color: var(--c-ink);
    text-decoration: none;
  }
  .pcard__subtitle {
    font-size: 0.8rem;
    color: var(--c-muted);
  }
  .pcard__price {
    font-size: 1.1rem;
    font-weight: 700;
  }

  /* Quick-add button (Cart) */
  .pcard__buy-btn {
    background: var(--secondary-color, var(--c-ink));
    color: #fff !important;
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 1rem;
    text-align: center;
    text-decoration: none !important;
    transition: var(--transition);
    margin-top: auto;
  }
  .pcard__buy-btn:hover {
    filter: brightness(1.1);
  }

  /* Scroll container */
  .related-scroll-container {
    display: flex;
    overflow-x: auto;
    gap: 1.5rem;
    padding: 1rem 0.5rem 2rem 0.5rem;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE and Edge */
  }
  .related-scroll-container::-webkit-scrollbar {
    display: none; /* Chrome/Safari/Edge */
  }
  .related-scroll-container > .pcard {
    scroll-snap-align: start;
    width: 220px;
    flex-shrink: 0;
  }
  .scroll-btn {
    width: 44px;
    height: 44px;
    border: 1px solid var(--c-border);
    background: var(--c-surface);
    color: var(--c-ink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: var(--shadow-soft);
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    transition: var(--transition);
  }
  .scroll-btn:hover {
    background: var(--c-ink);
    color: #fff;
  }
  .scroll-btn-left { left: -20px; }
  .scroll-btn-right { right: -20px; }
  
  @media (max-width: 991px) {
    .related-scroll-container > .pcard {
      width: 160px;
    }
    .pcard__name { font-size: 0.85rem; }
    .pcard__price { font-size: 1rem; }
    .pcard__img { padding: 1rem; }
  }
</style>

<div class="container product-detail">
    <nav aria-label="breadcrumb">
        <ul class="custom-breadcrumb">
            <li><a href="{{ path('home') }}">Inicio</a></li>
            <li class="separator"><i class="bi bi-chevron-right"></i></li>
            <li><a href="{{ path('product') }}">Tienda</a></li>
            <li class="separator"><i class="bi bi-chevron-right"></i></li>
            <li class="current">{{ product.name }}</li>
        </ul>
    </nav>

    <div class="row g-lg-5">
        <!-- Izquierda: Imagen -->
        <div class="col-lg-6">
            <div class="pdetail-img-card">
                {% set all_images = [product.image] %}
                {% if product.images is defined and product.images %}
                    {% for img in product.images %}
                        {% set all_images = all_images|merge([img]) %}
                    {% endfor %}
                {% endif %}

                <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
                    {% if all_images|length > 1 %}
                    <button type="button" id="pd-prev-img" class="btn text-white rounded-circle shadow flex-shrink-0 d-flex align-items-center justify-content-center" style="width:42px; height:42px; min-width:42px; background: var(--primary-color, #333); border: none; transition: opacity 0.2s;"><i class="bi bi-chevron-left fs-5"></i></button>
                    {% endif %}
                    
                    <div class="pdetail-img-wrap flex-grow-1 w-100 mx-3" style="position: relative;">
                        {% for bundle in product.bundles %}
                          {% if bundle.topRightBadge %}
                            {% set badgeText = bundle.topRightBadge == 'envio_gratis' ? 'Envío gratis' : 
                                               (bundle.topRightBadge == 'recomendado' ? 'Recomendado' : 'Más vendido') %}
                            <span class="top-badge-right top-badge-right--{{ bundle.topRightBadge }}" style="font-size: 0.85rem; padding: 0.5rem 0.8rem;">{{ badgeText }}</span>
                          {% endif %}
                        {% endfor %}
                        <img id="main-product-img" src="/uploads/{{ product.image }}" alt="{{ product.name }}" class="pdetail-img">
                    </div>
                    
                    {% if all_images|length > 1 %}
                    <button type="button" id="pd-next-img" class="btn text-white rounded-circle shadow flex-shrink-0 d-flex align-items-center justify-content-center" style="width:42px; height:42px; min-width:42px; background: var(--primary-color, #333); border: none; transition: opacity 0.2s;"><i class="bi bi-chevron-right fs-5"></i></button>
                    {% endif %}
                </div>
                
                {% if all_images|length > 1 %}
                <div class="d-flex justify-content-center gap-2 flex-wrap mb-3">
                    {% for img in all_images %}
                        <img src="/uploads/{{ img }}" alt="Thumbnail" class="pd-thumbnail" data-src="/uploads/{{ img }}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; cursor: pointer; border: {{ loop.first ? '2px solid var(--primary-color, #333)' : '2px solid transparent' }}; transition: border 0.2s;">
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Derecha: Datos -->
        <div class="col-lg-6">
            <header class="pdetail-header">
                <h1 class="pdetail-title">
                  {{ product.name }}
                  {% if product.bundles|length > 0 %}
                    <br class="d-md-none">
                    {% for bundle in product.bundles %}
                      {% set pillText = 'Descuento Especial' %}
                      {% if bundle.type == 'oferta_sorpresa' %}{% set pillText = 'Oferta sorpresa!' %}{% endif %}
                      {% if bundle.type == 'ultimos_stock' %}{% set pillText = 'Últimos en stock!' %}{% endif %}
                      {% if bundle.type == 'pocas_unidades' %}{% set pillText = '¡Apúrate, quedan pocas unidades!' %}{% endif %}
                      <span class="bundle-pill bundle-pill--{{ bundle.type }}" title="{{ bundle.title }}" style="font-size: 0.8rem; margin-top: 0.5rem; margin-left: 0;">{{ pillText }}</span>
                    {% endfor %}
                  {% endif %}
                </h1>
                <p class="pdetail-subtitle">{{ product.subtitle }}</p>
            </header>

            <div class="pdetail-price-box">
                <span class="pdetail-price">$ {{ (product.price / 100)|number_format(2, ',', '.') }} ARS</span>
            </div>

            <div class="mb-4 d-flex align-items-center">
                <a href="#" class="btn btn-success d-flex align-items-center" data-toggle="modal" data-target="#paymentMethodsModal">
                    <i class="bi bi-credit-card mr-2"></i>
                    Ver medios de pago
                </a>
            </div>

            {% if product.options|length > 0 %}
                <div class="product-options-interactive mb-4">
                    {# Parent Options Row #}
                    <div class="d-flex flex-wrap gap-2 mb-3" id="parent-options-container">
                        {% for option in product.options %}
                            {% if option.isAvailable %}
                                <button type="button" 
                                        class="btn btn-outline-dark rounded-pill px-4 fw-bold parent-option-btn {% if loop.first %}active{% endif %}" 
                                        data-target="option-group-{{ option.id }}"
                                        style="font-size: 0.85rem; border: 1.5px solid #ddd; transition: all 0.2s;">
                                    {{ option.name }}
                                </button>
                            {% endif %}
                        {% endfor %}
                    </div>

                    {# Children Values Containers #}
                    {% for option in product.options %}
                        {% if option.isAvailable %}
                            <div class="option-values-container {% if not loop.first %}d-none{% endif %}" 
                                 id="option-group-{{ option.id }}"
                                 data-group-name="{{ option.name }}">
                                <div class="d-flex flex-wrap gap-2 animate__animated animate__fadeInUp animate__faster">
                                    {% for value in option.productOptionValues %}
                                        <button type="button" 
                                              class="btn product-option-value-btn {{ value.isAvailable ? 'available' : 'option-unavailable text-muted' }}" 
                                              data-value-name="{{ value.name }}"
                                              {% if not value.isAvailable %}disabled{% endif %}
                                              style="padding: 0.4rem 0.8rem; border: 1px solid {{ value.isAvailable ? 'var(--primary-color, #333)' : '#ccc' }}; border-radius: 4px; font-weight: 600; font-size: 0.85rem; color: {{ value.isAvailable ? '#000' : '#adb5bd' }}; background: transparent; transition: all 0.2s;">
                                            {{ value.name }}
                                        </button>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>

                <style>
                    .parent-option-btn.active {
                        background-color: var(--primary-color, #000) !important;
                        color: #fff !important;
                        border-color: var(--primary-color, #000) !important;
                        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                    }
                    .parent-option-btn:hover:not(.active) {
                        border-color: var(--primary-color, #000) !important;
                        color: var(--primary-color, #000) !important;
                    }
                    .product-option-value-btn.active {
                        background-color: #000 !important;
                        color: #fff !important;
                        border-color: #000 !important;
                    }
                    .product-option-value-btn:hover:not(.active):not(:disabled) {
                        background-color: #f8f9fa;
                    }
                </style>

            {% endif %}

            <div class="pdetail-description">
                <span class="pdetail-section-title">Sobre este artículo</span>
                <div class="pdetail-content">
                    {{ product.description }}
                </div>
            </div>

            <div class="pdetail-actions">
                <form id="product-add-form" action="{{ path('add_to_cart', {id: product.id}) }}" method="GET" class="d-flex gap-2 align-items-center w-100">
                    <div class="d-flex align-items-center flex-shrink-0" id="qty-control" style="border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: 0.2rem;">
                        <button type="button" class="btn fw-bold text-muted border-0 d-flex justify-content-center align-items-center" id="pd-minus" style="width: 36px; height: 36px; background: transparent;">-</button>
                        <input type="number" id="pd-qty" name="qty" value="1" min="1" class="form-control text-center border-0 fw-bold bg-transparent p-0" style="pointer-events: none; font-size: 1rem; box-shadow: none; width: 32px;" readonly>
                        <button type="button" class="btn fw-bold text-muted border-0 d-flex justify-content-center align-items-center" id="pd-plus" style="width: 36px; height: 36px; background: transparent;">+</button>
                    </div>
                    
                    <button type="submit" id="pd-submit" class="btn-pdetail-cart ml-2 m-0 flex-grow-1">
                        <i class="bi bi-bag-plus-fill"></i>
                        <span class="d-none d-md-inline">Comprar ahora</span>
                        <span class="d-inline d-md-none">Comprar</span>
                    </button>
                </form>

                <a href="{{ path('product') }}" class="btn-pdetail-back mt-2 w-100">
                    <i class="bi bi-arrow-left"></i>
                    <span class="d-none d-md-inline">Volver a la tienda</span>
                    <span class="d-inline d-md-none">Volver</span>
                </a>
            </div>

            <div class="pdetail-features mt-4">
                <div class="feature-item">
                    <i class="bi bi-truck"></i>
                    <span>Envío express</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-shield-check"></i>
                    <span>Pago 100% seguro</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>Decepción cero</span>
                </div>
            </div>

        </div>
    </div>

    <!-- Related Products Section -->
    {% if relatedProducts is defined and relatedProducts|length > 0 %}
    <div class="mt-5 pt-5 border-top">
        <h3 class="mb-4 fw-bold" style="font-size: 1.5rem; text-align: center;">Productos complementarios</h3>
        <small class="d-block text-center mb-4">Podrian interesarte, hecha un vistazo</small>
        
        <div class="position-relative">
            <!-- Left Button -->
            <button class="scroll-btn scroll-btn-left d-none d-md-flex" id="rp-left">
                <i class="bi bi-chevron-left"></i>
            </button>

            <!-- Scroll Container -->
            <div class="related-scroll-container" id="rp-container">
                {% for related in relatedProducts %}
                <article class="pcard">
                    {% for rBundle in related.bundles %}
                      {% if rBundle.topRightBadge %}
                        {% set badgeText = rBundle.topRightBadge == 'envio_gratis' ? 'Envío gratis' : 
                                           (rBundle.topRightBadge == 'recomendado' ? 'Recomendado' : 'Más vendido') %}
                        <span class="top-badge-right top-badge-right--{{ rBundle.topRightBadge }}" style="font-size: 0.6rem; padding: 0.2rem 0.4rem;">{{ badgeText }}</span>
                      {% endif %}
                    {% endfor %}

                    <div class="pcard__img-wrap">
                        <a href="{{ path('product_show', {slug: related.slug}) }}">
                            <img class="pcard__img" src="/uploads/{{ related.image }}" alt="{{ related.name }}" data-extra-images="{{ related.images|default([])|json_encode }}">
                        </a>
                    </div>
                    <div class="pcard__body">
                        <h3 class="pcard__name">
                          <a href="{{ path('product_show', {slug: related.slug}) }}">
                            {{ related.name }}
                            {% if related.bundles|length > 0 %}
                                {% for rBundle in related.bundles %}
                                {% set pillText = 'Descuento' %}
                                {% if rBundle.type == 'oferta_sorpresa' %}{% set pillText = 'Oferta sorpresa!' %}{% endif %}
                                {% if rBundle.type == 'ultimos_stock' %}{% set pillText = 'Últimos en stock!' %}{% endif %}
                                {% if rBundle.type == 'pocas_unidades' %}{% set pillText = '¡Pocas unidades!' %}{% endif %}
                                <span class="bundle-pill bundle-pill--{{ rBundle.type }}" style="font-size: 0.6rem; padding: 0.15rem 0.4rem; animation: pillShake 6s infinite;">{{ pillText }}</span>
                                {% endfor %}
                            {% endif %}
                          </a>
                        </h3>
                        <span class="pcard__subtitle">{{ related.subtitle }}</span>
                        <div class="pcard__price">$ {{ (related.price / 100)|number_format(2, ',', '.') }} ARS</div>
                    </div>
                    
                    {% set firstVariant = null %}
                    {% for option in related.options %}
                        {% if option.isAvailable and not firstVariant %}
                            {% for value in option.productOptionValues %}
                                {% if value.isAvailable and not firstVariant %}
                                     {% set firstVariant = option.name ~ ': ' ~ value.name %}
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    {% endfor %}
                    {% set variantString = firstVariant %}
                    
                    <a href="{{ path('add_to_cart', {id: related.id, variants: variantString}) }}" class="pcard__buy-btn">
                        Agregar
                    </a>

                    <div class="pcard__options-store d-none">
                        {% if related.options|length > 0 %}
                            <div class="product-options-interactive-store mb-2 mt-2 w-100">
                                {# Parents Row #}
                                <div class="d-flex flex-wrap gap-1 justify-content-center mb-2 qv-parents-row">
                                    {% for option in related.options %}
                                        {% if option.isAvailable %}
                                            <button type="button" 
                                                    class="btn btn-sm btn-outline-dark rounded-pill px-3 qv-parent-btn {% if loop.first %}active{% endif %}" 
                                                    data-target="qv-option-rel-{{ related.id }}-{{ option.id }}"
                                                    style="font-size: 0.7rem; border: 1.5px solid #ddd; font-weight: 700;">
                                                {{ option.name }}
                                            </button>
                                        {% endif %}
                                    {% endfor %}
                                </div>

                                {# Children Containers #}
                                {% for option in related.options %}
                                    {% if option.isAvailable %}
                                        <div class="qv-option-values {% if not loop.first %}d-none{% endif %}" 
                                             id="qv-option-rel-{{ related.id }}-{{ option.id }}"
                                             data-group-name="{{ option.name }}">
                                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                                {% for value in option.productOptionValues %}
                                                    <button type="button" 
                                                          class="btn btn-sm qv-value-btn {{ value.isAvailable ? '' : 'option-unavailable' }}" 
                                                          data-value-name="{{ value.name }}"
                                                          {% if not value.isAvailable %}disabled{% endif %}
                                                          style="border: 1px solid {{ value.isAvailable ? 'var(--primary-color, #333)' : '#ccc' }}; color: {{ value.isAvailable ? '#000' : '#adb5bd' }}; background: transparent; font-size: 0.75rem; padding: 0.2rem 0.5rem; transition: all 0.2s;">
                                                        {{ value.name }}
                                                    </button>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                </article>
                {% endfor %}
            </div>

            <!-- Right Button -->
            <button class="scroll-btn scroll-btn-right d-none d-md-flex" id="rp-right">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
    {% endif %}

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ── Selections Logic (Integrated) ──
    const parentBtns = document.querySelectorAll('.parent-option-btn');
    const valueContainers = document.querySelectorAll('.option-values-container');
    const selections = {}; // Track selections like { "Color": "Rojo", "Talle": "L" }
    const variantsInput = document.createElement('input');
    variantsInput.type = 'hidden';
    variantsInput.name = 'variants';
    
    const optionForm = document.querySelector('#product-add-form');
    if (optionForm) optionForm.appendChild(variantsInput);

    function updateVariantsString() {
        const str = Object.entries(selections)
            .sort((a, b) => a[0].localeCompare(b[0]))
            .map(([group, val]) => `${group}: ${val}`)
            .join(', ');
        variantsInput.value = str;
    }

    if (parentBtns.length > 0) {
        parentBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                parentBtns.forEach(b => b.classList.remove('active'));
                valueContainers.forEach(c => c.classList.add('d-none'));

                this.classList.add('active');
                const targetId = this.getAttribute('data-target');
                const targetContainer = document.getElementById(targetId);
                if (targetContainer) {
                    targetContainer.classList.remove('d-none');
                    document.querySelectorAll('.product-option-value-btn').forEach(b => b.classList.remove('active'));
                    for (let key in selections) delete selections[key];

                    const groupName = targetContainer.dataset.groupName;
                    const firstAvailable = targetContainer.querySelector('.product-option-value-btn.available');
                    if (firstAvailable) {
                        firstAvailable.classList.add('active');
                        selections[groupName] = firstAvailable.dataset.valueName;
                    }
                    updateVariantsString();
                }
            });
        });

        document.querySelectorAll('.product-option-value-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const container = this.closest('.option-values-container');
                const groupName = container.dataset.groupName;
                document.querySelectorAll('.product-option-value-btn').forEach(b => b.classList.remove('active'));
                for (let key in selections) delete selections[key];
                this.classList.add('active');
                selections[groupName] = this.dataset.valueName;
                updateVariantsString();
            });
        });

        function autoSelectFirst() {
            const activeContainer = Array.from(valueContainers).find(c => !c.classList.contains('d-none'));
            if (activeContainer) {
                const groupName = activeContainer.dataset.groupName;
                const firstAvailable = activeContainer.querySelector('.product-option-value-btn.available');
                if (firstAvailable) {
                    firstAvailable.classList.add('active');
                    selections[groupName] = firstAvailable.dataset.valueName;
                }
            }
            updateVariantsString();
        }
        autoSelectFirst();
    }

    // ── Rest of the product page handlers ──
    const mainImg = document.getElementById('main-product-img');
    const thumbnails = document.querySelectorAll('.pd-thumbnail');
    const pdPrevImg = document.getElementById('pd-prev-img');
    const pdNextImg = document.getElementById('pd-next-img');
    
    if (mainImg && thumbnails.length > 0) {
        let currentIndex = 0;
        
        function updateMainImg(idx) {
            if (idx < 0) idx = thumbnails.length - 1;
            if (idx >= thumbnails.length) idx = 0;
            currentIndex = idx;
            
            const thumb = thumbnails[currentIndex];
            const src = thumb.getAttribute('data-src');
            mainImg.style.opacity = '0.5';
            setTimeout(() => {
                mainImg.src = src;
                mainImg.style.opacity = '1';
            }, 150);
            
            thumbnails.forEach(t => t.style.border = '2px solid transparent');
            thumb.style.border = '2px solid var(--c-ink)';
        }

        thumbnails.forEach((thumb, index) => {
            thumb.addEventListener('click', () => updateMainImg(index));
        });

        if (pdPrevImg) pdPrevImg.addEventListener('click', () => updateMainImg(currentIndex - 1));
        if (pdNextImg) pdNextImg.addEventListener('click', () => updateMainImg(currentIndex + 1));
        
        let touchStartX = 0;
        let touchEndX = 0;
        if(mainImg.parentElement) {
            mainImg.parentElement.addEventListener('touchstart', e => {
                touchStartX = e.changedTouches[0].screenX;
            }, {passive: true});
            mainImg.parentElement.addEventListener('touchend', e => {
                touchEndX = e.changedTouches[0].screenX;
                if (touchEndX < touchStartX - 40) updateMainImg(currentIndex + 1);
                if (touchEndX > touchStartX + 40) updateMainImg(currentIndex - 1);
            }, {passive: true});
        }
    }

    const pdMinus = document.getElementById('pd-minus');
    const pdPlus = document.getElementById('pd-plus');
    const pdQty = document.getElementById('pd-qty');
    const pdForm = document.getElementById('product-add-form');
    const pdSubmit = document.getElementById('pd-submit');

    if(pdMinus && pdPlus && pdQty) {
        pdMinus.addEventListener('click', () => {
            let val = parseInt(pdQty.value);
            if(val > 1) pdQty.value = val - 1;
        });
        pdPlus.addEventListener('click', () => {
            let val = parseInt(pdQty.value);
            pdQty.value = val + 1;
        });
    }

    if(pdForm && pdSubmit) {
        pdForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const actionUrl = new URL(pdForm.action, window.location.origin);
            actionUrl.searchParams.set('qty', pdQty.value);
            actionUrl.searchParams.set('ajax', '1');

            const vInput = pdForm.querySelector('input[name="variants"]');
            if (vInput && vInput.value) {
                actionUrl.searchParams.set('variants', vInput.value);
            }

            const originalBtnHtml = pdSubmit.innerHTML;
            pdSubmit.disabled = true;

            fetch(actionUrl.toString(), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    let badges = document.querySelectorAll('.cart-badge');
                    if(badges.length > 0) {
                        badges.forEach(b => b.textContent = data.cartCount);
                    } else {
                        document.querySelectorAll('.cart-btn').forEach(btn => {
                            const badge = document.createElement('span');
                            badge.className = 'cart-badge';
                            badge.textContent = data.cartCount;
                            btn.appendChild(badge);
                        });
                    }
                    
                    // Preserve original width to avoid layout jump
                    const btnWidth = pdSubmit.offsetWidth;
                    pdSubmit.style.minWidth = btnWidth + 'px';
                    
                    pdSubmit.innerHTML = '<span class="check-animated"><i class="bi bi-check-lg" style="font-size: 1.5rem;"></i></span>';
                    pdSubmit.style.background = '#198754'; // Bootstrap success color
                    
                    // Reset quantity selector with animation
                    if (pdQty) {
                        pdQty.value = 1;
                        const qtyContainer = document.getElementById('qty-control');
                        if (qtyContainer) {
                            qtyContainer.classList.remove('qty-reset-animate');
                            void qtyContainer.offsetWidth; // Trigger reflow
                            qtyContainer.classList.add('qty-reset-animate');
                        }
                    }

                    // Deselect all options
                    for (let key in selections) delete selections[key];
                    document.querySelectorAll('.product-option-value-btn').forEach(btn => btn.classList.remove('active'));
                    updateVariantsString();
                    
                    setTimeout(() => {
                        pdSubmit.style.background = '';
                        pdSubmit.style.minWidth = '';
                        pdSubmit.innerHTML = originalBtnHtml;
                        pdSubmit.disabled = false;
                    }, 1000);
                }
            })
            .catch(err => {
                console.error(err);
                pdSubmit.innerHTML = originalBtnHtml;
                pdSubmit.disabled = false;
            });
        });
    }


    // Related Products Scroll
    const rpContainer = document.getElementById('rp-container');
    const rpLeft = document.getElementById('rp-left');
    const rpRight = document.getElementById('rp-right');

    if (rpContainer && rpLeft && rpRight) {
        const itemWidth = rpContainer.querySelector('.pcard') ? rpContainer.querySelector('.pcard').offsetWidth + 24 : 240;
        
        rpLeft.addEventListener('click', () => {
            rpContainer.scrollBy({ left: -itemWidth, behavior: 'smooth' });
        });
        rpRight.addEventListener('click', () => {
            rpContainer.scrollBy({ left: itemWidth, behavior: 'smooth' });
        });
        
        // Hide/show buttons based on scroll position
        const updateButtons = () => {
            if (rpContainer.scrollLeft <= 0) {
                rpLeft.style.opacity = '0.5';
                rpLeft.style.pointerEvents = 'none';
            } else {
                rpLeft.style.opacity = '1';
                rpLeft.style.pointerEvents = 'auto';
            }
            
            if (rpContainer.scrollLeft + rpContainer.clientWidth >= rpContainer.scrollWidth - 1) {
                rpRight.style.opacity = '0.5';
                rpRight.style.pointerEvents = 'none';
            } else {
                rpRight.style.opacity = '1';
                rpRight.style.pointerEvents = 'auto';
            }
        };
        
        rpContainer.addEventListener('scroll', updateButtons);
        // Initial check
        setTimeout(updateButtons, 100);
        window.addEventListener('resize', updateButtons);
    }
});
</script>

<!-- Modal Medios de Pago -->
<div class="modal fade" id="paymentMethodsModal" tabindex="-1" aria-labelledby="paymentMethodsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="paymentMethodsModalLabel">Medios de Pago Disponibles</h5>
                <button type="button" class="close mr-2" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex flex-column gap-3">
                    
                    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                        <i class="bi bi-wallet2 text-primary fs-1 mr-3"></i>
                        <div>
                            <h6 class="fw-bold mb-0">Efectivo</h6>
                            <small class="text-muted">Al retirar el producto</small>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                        <i class="bi bi-credit-card-2-front text-info fs-1 mr-3"></i>
                        <div>
                            <h6 class="fw-bold mb-0">Mercado Pago</h6>
                            <small class="text-muted">Tarjeta de crédito o débito, dinero en cuenta</small>
                        </div>
                    </div>

                    {% if personalize and personalize.aliasCbu %}
                    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border border-primary border-opacity-25">
                        <i class="bi bi-bank text-primary fs-1 mr-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Transferencia Bancaria</h6>
                            <small class="text-muted d-block">Alias / CBU:
                            <span class="badge badge-primary user-select-all" style="font-size: 0.9rem;">{{ personalize.aliasCbu }}</span></small>
                        </div>
                    </div>
                    {% endif %}

                    <a href="https://wa.me/{{ personalize.whatsapp|replace({'+': '', ' ': '', '-': ''}) }}" target="_blank" class="text-decoration-none text-dark">
                        <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border border-success border-opacity-25" style="transition: all 0.2s;">
                            <i class="bi bi-whatsapp text-success fs-1 mr-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Acordar con el vendedor</h6>
                                <small class="text-muted">Coordiná el pago directamente por WhatsApp <i class="bi bi-box-arrow-up-right ms-1"></i></small>
                            </div>
                        </div>
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
