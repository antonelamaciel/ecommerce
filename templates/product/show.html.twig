                            <i class="bi bi-wallet2 fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-700 payment-title">Efectivo al retirar</h6>
                            <p class="small text-muted mb-0">¡Pagando en efectivo tienes beneficios!</p>
                        </div>
                    </div>

                    {# Mercado Pago Option #}
                    <div class="payment-option-card p-3 d-flex align-items-center gap-3 transition-all">
                        <div class="payment-icon-wrap" style="background: transparent; color: #d97706;">
                            <i class="bi bi-lightning-charge-fill fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-700 payment-title">Mercado Pago</h6>
                            <p class="small text-muted mb-0">Tarjetas de crédito, débito y dinero en cuenta</p>
                        </div>
                    </div>

                    {# Transfer Option #}
                    {% if personalize and personalize.aliasCbu %}
                    <div class="payment-option-card p-3 d-flex align-items-center gap-3 transition-all">
                        <div class="payment-icon-wrap" style="background: transparent; color: #059669;">
                            <i class="bi bi-bank2 fs-4"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="mb-0 fw-700 payment-title">Transferencia Bancaria</h6>
                            <p class="small text-muted mb-0 text-truncate" style="max-width: 200px;">Alias: {{ personalize.aliasCbu }}</p>
