{% extends 'base.html.twig' %}

{% block title %}{{ product.name }}{% endblock %}

{% block body %}

<style>
  /* ── Tokens (Consistent with Home) ── */
  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561ff;
    --c-accent: #1a1a1a;
    --radius-lg: 32px;
    --radius-md: 20px;
    --radius-sm: 12px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }

  .product-detail {
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  /* ── Breadcrumbs ── */
  .custom-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    list-style: none;
    padding: 0;
    font-size: 0.85rem;
  }
  .custom-breadcrumb a {
    color: var(--c-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .custom-breadcrumb a:hover { color: var(--c-ink); }
  .custom-breadcrumb .separator { color: var(--c-border); font-size: 0.7rem; }
  .custom-breadcrumb .current { color: var(--c-ink); font-weight: 600; }

  /* ── Image Display ── */
  .pdetail-img-card {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    padding: 1.5rem 1rem;
    box-shadow: var(--shadow-soft);
    position: sticky;
    top: 100px;
    transition: var(--transition);
  }
  .pdetail-img-wrap {
    width: 100%;
    max-width: 500px;
    height: 420px;
    min-height: 280px;
    max-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 10px;
    background: #f8f8f8;
    margin: 0 auto;
  }
  .pdetail-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  /* ── Product Info ── */
  .pdetail-header { margin-bottom: 2rem; }
  .pdetail-title {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }
  .pdetail-subtitle {
    font-size: 1.1rem;
    color: var(--c-muted);
    font-weight: 400;
  }

  .pdetail-price-box {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .pdetail-price {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .pdetail-tax-badge {
    font-size: 0.75rem;
    color: var(--c-muted);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    background: var(--c-border);
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  .pdetail-description {
    margin-bottom: 3rem;
  }
  .pdetail-section-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--c-muted);
    margin-bottom: 1.25rem;
    display: block;
  }
  .pdetail-content {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--c-ink);
    opacity: 0.9;
  }

  /* ── Actions ── */
  .pdetail-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .pdetail-add-grid {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .btn-pdetail-cart {
    background: var(--secondary-color, var(--primary-color, var(--c-ink)));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1.2rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: var(--transition);
  }
  .btn-pdetail-cart:hover {
    filter: brightness(1.1);
    transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    color: #fff;
  }
  .btn-pdetail-back {
    background: transparent;
    border: 1px solid var(--c-border);
    color: var(--c-muted);
    border-radius: var(--radius-md);
    padding: 1.2rem;
    font-weight: 500;
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transition: var(--transition);
  }
  .btn-pdetail-back:hover {
    background: var(--c-border);
    color: var(--c-ink);
  }

  /* ── Features ── */
  .pdetail-features {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-border);
  }
  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--c-muted);
  }
  .feature-item i {
    font-size: 1.2rem;
    color: var(--c-ink);
  }

  @media (max-width: 991px) {
    .product-detail { padding-top: 1rem; padding-bottom: 2rem; }
    .custom-breadcrumb { margin-bottom: 1rem; font-size: 0.8rem; }
    
    .pdetail-img-card { padding: 0.5rem; margin-bottom: 1rem; }
    .pdetail-img-wrap { height: 260px; min-height: 200px; }
    
    .pdetail-header { margin-bottom: 0.5rem; }
    .pdetail-title { font-size: 1.5rem; margin-bottom: 0.25rem; line-height: 1.2; }
    .pdetail-subtitle { font-size: 0.9rem; }
    
    .pdetail-price-box { margin-bottom: 0.75rem; gap: 0.5rem; }
    .pdetail-price { font-size: 1.5rem; }
    
    .pdetail-description { margin-bottom: 1.5rem; }
    .pdetail-section-title { margin-bottom: 0.5rem; font-size: 0.8rem; }
    .pdetail-content { font-size: 0.9rem; line-height: 1.5; }
    
    .pdetail-add-grid { flex-wrap: nowrap; gap: 0.5rem; }
    #qty-control { padding: 0.1rem !important; }
    #qty-control button { width: 28px !important; height: 28px !important; font-size: 0.85rem; }
    #pd-qty { width: 24px !important; font-size: 0.9rem !important; }
    .btn-pdetail-cart { padding: 0.6rem 0.75rem; font-size: 0.9rem; }
    .btn-pdetail-back { padding: 0.6rem 0.75rem; font-size: 0.85rem; white-space: nowrap; }
    .pdetail-actions { margin-bottom: 1rem; }
    
    .pdetail-features { gap: 0.75rem; padding-top: 1rem; flex-direction: column; align-items: flex-start; }
    .feature-item { font-size: 0.85rem; gap: 0.5rem; }
    
    #pd-prev-img, #pd-next-img { display: none !important; }
    .pdetail-img-wrap { margin-left: 0 !important; margin-right: 0 !important; max-width: 100%; }
    
    /* Botón medios de pago más ajustado */
    .mb-4.d-flex.align-items-center { margin-bottom: 1rem !important; }
    .btn.btn-success { padding: 0.5rem 1rem; font-size: 0.85rem; }
    
    /* Calculador envios */

  }
</style>

<div class="container product-detail">
    <nav aria-label="breadcrumb">
        <ul class="custom-breadcrumb">
            <li><a href="{{ path('home') }}">Inicio</a></li>
            <li class="separator"><i class="bi bi-chevron-right"></i></li>
            <li><a href="{{ path('product') }}">Tienda</a></li>
            <li class="separator"><i class="bi bi-chevron-right"></i></li>
            <li class="current">{{ product.name }}</li>
        </ul>
    </nav>

    <div class="row g-lg-5">
        <!-- Izquierda: Imagen -->
        <div class="col-lg-6">
            <div class="pdetail-img-card">
                {% set all_images = [product.image] %}
                {% if product.images is defined and product.images %}
                    {% for img in product.images %}
                        {% set all_images = all_images|merge([img]) %}
                    {% endfor %}
                {% endif %}

                <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
                    {% if all_images|length > 1 %}
                    <button type="button" id="pd-prev-img" class="btn text-white rounded-circle shadow flex-shrink-0 d-flex align-items-center justify-content-center" style="width:42px; height:42px; min-width:42px; background: var(--primary-color, #333); border: none; transition: opacity 0.2s;"><i class="bi bi-chevron-left fs-5"></i></button>
                    {% endif %}
                    
                    <div class="pdetail-img-wrap flex-grow-1 w-100 mx-3">
                        <img id="main-product-img" src="/uploads/{{ product.image }}" alt="{{ product.name }}" class="pdetail-img">
                    </div>
                    
                    {% if all_images|length > 1 %}
                    <button type="button" id="pd-next-img" class="btn text-white rounded-circle shadow flex-shrink-0 d-flex align-items-center justify-content-center" style="width:42px; height:42px; min-width:42px; background: var(--primary-color, #333); border: none; transition: opacity 0.2s;"><i class="bi bi-chevron-right fs-5"></i></button>
                    {% endif %}
                </div>
                
                {% if all_images|length > 1 %}
                <div class="d-flex justify-content-center gap-2 flex-wrap mb-3">
                    {% for img in all_images %}
                        <img src="/uploads/{{ img }}" alt="Thumbnail" class="pd-thumbnail" data-src="/uploads/{{ img }}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; cursor: pointer; border: {{ loop.first ? '2px solid var(--primary-color, #333)' : '2px solid transparent' }}; transition: border 0.2s;">
                    {% endfor %}
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Derecha: Datos -->
        <div class="col-lg-6">
            <header class="pdetail-header">
                <h1 class="pdetail-title">{{ product.name }}</h1>
                <p class="pdetail-subtitle">{{ product.subtitle }}</p>
            </header>

            <div class="pdetail-price-box">
                <span class="pdetail-price">$ {{ (product.price / 100)|number_format(2, ',', '.') }} ARS</span>
            </div>

            <div class="mb-4 d-flex align-items-center">
                <a href="#" class="btn btn-success d-flex align-items-center" data-toggle="modal" data-target="#paymentMethodsModal">
                    <i class="bi bi-credit-card mr-2"></i>
                    Ver medios de pago
                </a>
            </div>

            <div class="pdetail-description">
                <span class="pdetail-section-title">Sobre este artículo</span>
                <div class="pdetail-content">
                    {{ product.description }}
                </div>
            </div>

            <div class="pdetail-actions">
                <form id="product-add-form" action="{{ path('add_to_cart', {id: product.id}) }}" method="GET" class="d-flex gap-2 align-items-center w-100">
                    <div class="d-flex align-items-center flex-shrink-0" id="qty-control" style="border: 1px solid var(--c-border); border-radius: var(--radius-md); padding: 0.2rem;">
                        <button type="button" class="btn fw-bold text-muted border-0 d-flex justify-content-center align-items-center" id="pd-minus" style="width: 36px; height: 36px; background: transparent;">-</button>
                        <input type="number" id="pd-qty" name="qty" value="1" min="1" class="form-control text-center border-0 fw-bold bg-transparent p-0" style="pointer-events: none; font-size: 1rem; box-shadow: none; width: 32px;" readonly>
                        <button type="button" class="btn fw-bold text-muted border-0 d-flex justify-content-center align-items-center" id="pd-plus" style="width: 36px; height: 36px; background: transparent;">+</button>
                    </div>
                    
                    <button type="submit" id="pd-submit" class="btn-pdetail-cart ml-2 m-0 flex-grow-1">
                        <i class="bi bi-bag-plus-fill"></i>
                        <span class="d-none d-md-inline">Comprar ahora</span>
                        <span class="d-inline d-md-none">Comprar</span>
                    </button>
                </form>

                <a href="{{ path('product') }}" class="btn-pdetail-back mt-2 w-100">
                    <i class="bi bi-arrow-left"></i>
                    <span class="d-none d-md-inline">Volver a la tienda</span>
                    <span class="d-inline d-md-none">Volver</span>
                </a>
            </div>

            <div class="pdetail-features mt-4">
                <div class="feature-item">
                    <i class="bi bi-truck"></i>
                    <span>Envío express</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-shield-check"></i>
                    <span>Pago 100% seguro</span>
                </div>
                <div class="feature-item">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>Decepción cero</span>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const mainImg = document.getElementById('main-product-img');
    const thumbnails = document.querySelectorAll('.pd-thumbnail');
    const pdPrevImg = document.getElementById('pd-prev-img');
    const pdNextImg = document.getElementById('pd-next-img');
    
    if (mainImg && thumbnails.length > 0) {
        let currentIndex = 0;
        
        function updateMainImg(idx) {
            if (idx < 0) idx = thumbnails.length - 1;
            if (idx >= thumbnails.length) idx = 0;
            currentIndex = idx;
            
            const thumb = thumbnails[currentIndex];
            const src = thumb.getAttribute('data-src');
            mainImg.style.opacity = '0.5';
            setTimeout(() => {
                mainImg.src = src;
                mainImg.style.opacity = '1';
            }, 150);
            
            thumbnails.forEach(t => t.style.border = '2px solid transparent');
            thumb.style.border = '2px solid var(--c-ink)';
        }

        thumbnails.forEach((thumb, index) => {
            thumb.addEventListener('click', () => updateMainImg(index));
        });

        if (pdPrevImg) pdPrevImg.addEventListener('click', () => updateMainImg(currentIndex - 1));
        if (pdNextImg) pdNextImg.addEventListener('click', () => updateMainImg(currentIndex + 1));
        
        let touchStartX = 0;
        let touchEndX = 0;
        if(mainImg.parentElement) {
            mainImg.parentElement.addEventListener('touchstart', e => {
                touchStartX = e.changedTouches[0].screenX;
            }, {passive: true});
            mainImg.parentElement.addEventListener('touchend', e => {
                touchEndX = e.changedTouches[0].screenX;
                if (touchEndX < touchStartX - 40) updateMainImg(currentIndex + 1);
                if (touchEndX > touchStartX + 40) updateMainImg(currentIndex - 1);
            }, {passive: true});
        }
    }

    const pdMinus = document.getElementById('pd-minus');
    const pdPlus = document.getElementById('pd-plus');
    const pdQty = document.getElementById('pd-qty');
    const pdForm = document.getElementById('product-add-form');
    const pdSubmit = document.getElementById('pd-submit');

    if(pdMinus && pdPlus && pdQty) {
        pdMinus.addEventListener('click', () => {
            let val = parseInt(pdQty.value);
            if(val > 1) pdQty.value = val - 1;
        });
        pdPlus.addEventListener('click', () => {
            let val = parseInt(pdQty.value);
            pdQty.value = val + 1;
        });
    }

    if(pdForm && pdSubmit) {
        pdForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const actionUrl = new URL(pdForm.action, window.location.origin);
            actionUrl.searchParams.set('qty', pdQty.value);
            actionUrl.searchParams.set('ajax', '1');

            const originalBtnHtml = pdSubmit.innerHTML;
            pdSubmit.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Añadiendo...';
            pdSubmit.disabled = true;

            fetch(actionUrl.toString(), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
            .then(response => response.json())
            .then(data => {
                if(data.success) {
                    let badges = document.querySelectorAll('.cart-badge');
                    if(badges.length > 0) {
                        badges.forEach(b => b.textContent = data.cartCount);
                    } else {
                        document.querySelectorAll('.cart-btn').forEach(btn => {
                            const badge = document.createElement('span');
                            badge.className = 'cart-badge';
                            badge.textContent = data.cartCount;
                            btn.appendChild(badge);
                        });
                    }
                    
                    pdSubmit.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> Agregado!';
                    pdSubmit.style.background = '#198754'; // Bootstrap success color
                    
                    setTimeout(() => {
                        pdSubmit.style.background = '';
                        pdSubmit.innerHTML = originalBtnHtml;
                        pdSubmit.disabled = false;
                    }, 2000);
                }
            })
            .catch(err => {
                console.error(err);
                pdSubmit.innerHTML = originalBtnHtml;
                pdSubmit.disabled = false;
            });
        });
    }
});
</script>

<!-- Modal Medios de Pago -->
<div class="modal fade" id="paymentMethodsModal" tabindex="-1" aria-labelledby="paymentMethodsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="paymentMethodsModalLabel">Medios de Pago Disponibles</h5>
                <button type="button" class="close mr-2" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4">
                <div class="d-flex flex-column gap-3">
                    
                    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                        <i class="bi bi-wallet2 text-primary fs-1 mr-3"></i>
                        <div>
                            <h6 class="fw-bold mb-0">Efectivo</h6>
                            <small class="text-muted">Al retirar el producto</small>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3">
                        <i class="bi bi-credit-card-2-front text-info fs-1 mr-3"></i>
                        <div>
                            <h6 class="fw-bold mb-0">Mercado Pago</h6>
                            <small class="text-muted">Tarjeta de crédito o débito, dinero en cuenta</small>
                        </div>
                    </div>

                    {% if personalize and personalize.aliasCbu %}
                    <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border border-primary border-opacity-25">
                        <i class="bi bi-bank text-primary fs-1 mr-3"></i>
                        <div>
                            <h6 class="fw-bold mb-1">Transferencia Bancaria</h6>
                            <small class="text-muted d-block">Alias / CBU:
                            <span class="badge badge-primary user-select-all" style="font-size: 0.9rem;">{{ personalize.aliasCbu }}</span></small>
                        </div>
                    </div>
                    {% endif %}

                    <a href="https://wa.me/{{ personalize.whatsapp|replace({'+': '', ' ': '', '-': ''}) }}" target="_blank" class="text-decoration-none text-dark">
                        <div class="d-flex align-items-center gap-3 p-3 bg-light rounded-3 border border-success border-opacity-25" style="transition: all 0.2s;">
                            <i class="bi bi-whatsapp text-success fs-1 mr-3"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Acordar con el vendedor</h6>
                                <small class="text-muted">Coordiná el pago directamente por WhatsApp <i class="bi bi-box-arrow-up-right ms-1"></i></small>
                            </div>
                        </div>
                    </a>

                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
