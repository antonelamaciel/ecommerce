    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 overflow-hidden shadow-lg" style="border-radius:24px; background: var(--c-surface);">
            <div class="modal-header border-0 p-4 pb-2 d-flex align-items-center justify-content-between">
                <div>
                   <h5 class="fw-bold mb-0">Medios de Pago</h5>
                   <p class="text-muted small mb-0">Al final del carrito podrás elegir tu forma de pago preferida</p>
                </div>
                <button type="button" class="btn border-0 shadow-none d-flex align-items-center justify-content-center" data-dismiss="modal" aria-label="Close" style="width: 38px; height: 38px; border-radius: 50%; padding: 0; background: var(--tertiary-color) !important; color: var(--primary-color) !important; border: 1px solid var(--primary-color) !important; transition: all 0.2s;">
                    <i class="bi bi-x-lg" style="font-size: 1.1rem;"></i>
