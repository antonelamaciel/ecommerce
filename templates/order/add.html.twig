{% extends 'base.html.twig' %}

{% block title %}Resumen de mi pedido - {{ personalize.companyName ?? 'Empresa' }}{% endblock %}

{% block body %}

<style>
  /* ── Tokens (Consistent with ecosystem) ── */
  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }

  .order-container { padding-top: 3rem; padding-bottom: 5rem; }

  /* ── Header ── */
  .order-header { margin-bottom: 3rem; }
  .order-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }

  /* ── Grid Layout ── */
  .order-grid { display: grid; grid-template-columns: 1fr 400px; gap: 3rem; }

  /* ── Info Cards (Left) ── */
  .info-card {
    background: var(--c-surface);
    border-radius: var(--radius-md);
    padding: 2rem;
    border: 1px solid var(--c-border);
    margin-bottom: 1.5rem;
  }
  .info-card__title {
    font-size: 0.9rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-muted);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .info-card__title i { color: var(--primary-color, var(--c-ink)); }
  .info-card__content { font-size: 1rem; line-height: 1.6; }

  /* ── Summary Sidebar (Right) ── */
  .summary-sidebar {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-soft);
    position: sticky; top: 100px;
    height: fit-content;
  }
  .summary-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 2rem; }

  .summary-item {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .summary-item__img {
    width: 50px; height: 50px;
    object-fit: contain;
    background: #fdfcfb;
    border-radius: var(--radius-sm);
    padding: 0.25rem;
  }
  .summary-item__name { font-size: 0.9rem; font-weight: 500; color: var(--c-ink); line-height: 1.3; }
  .summary-item__qty { font-size: 0.85rem; color: var(--c-muted); font-weight: 600; }

  .summary-breakdown {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--c-border);
  }
  .breakdown-row {
    display: flex; justify-content: space-between;
    margin-bottom: 0.75rem; font-size: 0.95rem;
  }
  .breakdown-row.final-total {
    margin-top: 1.5rem; padding-top: 1.5rem;
    border-top: 1px solid var(--c-border);
    font-size: 1.4rem; font-weight: 700; color: var(--c-ink);
  }

  .btn-pay {
    width: 100%;
    background: var(--primary-color, var(--c-ink));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1.25rem;
    font-weight: 700;
    font-size: 1.1rem;
    display: flex; align-items: center; justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
    transition: var(--transition);
    text-decoration: none !important;
  }
  .btn-pay:hover {
    filter: brightness(1.1); transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1); color: #fff;
  }

  /* ── Mobile ── */
  @media (max-width: 991px) {
    .order-grid { grid-template-columns: 1fr; }
    .summary-sidebar { position: static; }
  }
</style>

<div class="container order-container">
    <header class="order-header">
        <h1 class="order-title">Resumen de mi pedido</h1>
        <p class="text-muted mt-2">Último paso: Revisa tus datos y procede al pago seguro</p>
    </header>

    <div class="order-grid">
        <!-- Left: Details -->
        <main>
            <div class="info-card">
                <div class="info-card__title">
                    <i class="bi bi-geo-alt-fill"></i>
                    Dirección de entrega
                </div>
                <div class="info-card__content">
                    {{ order.delivery|raw }}
                </div>
            </div>

            <div class="info-card">
                <div class="info-card__title">
                    <i class="bi bi-truck"></i>
                    Método de envío
                </div>
                <div class="info-card__content">
                    <strong>{{ order.carrierName }}</strong>
                </div>
            </div>

            <div class="mt-4">
                <a href="{{ path('order') }}" class="text-decoration-none fw-semibold" style="color: var(--c-muted)">
                    <i class="bi bi-arrow-left me-1"></i> Cambiar datos de entrega
                </a>
            </div>
        </main>

        <!-- Right: Summary & Pay -->
        <aside>
            <div class="summary-sidebar">
                <h2 class="summary-title">Tus artículos</h2>
                
                <div class="summary-items-list text-muted">
                    {% for item in cart.products %}
                        <div class="summary-item">
                            <img src="/uploads/{{ item.product.image }}" alt="{{ item.product.name }}" class="summary-item__img">
                            <div class="summary-item__name">
                                {{ item.product.name }}{% if item.variants %}<span class="text-muted" style="font-weight: 400; font-size: 0.85em;"> con {{ item.variants }}</span>{% endif %}
                            </div>
                            <div class="summary-item__qty">x{{ item.quantity }}</div>
                        </div>
                    {% endfor %}
                </div>

                <div class="summary-breakdown">
                    <div class="breakdown-row">
                        <span>Subtotal art.</span>
                        <span>$ {{ (totalPrice / 100)|number_format(2,',','.') }} ARS</span>
                    </div>
                    <div class="breakdown-row">
                        <span>Costo de envío</span>
                        <span>$ {{ (order.carrierPrice/100)|number_format(2,',','.') }} ARS</span>
                    </div>

                    <div class="breakdown-row final-total">
                        <span>Total pedido</span>
                        <span>$ {{ ((totalPrice / 100) + order.carrierPrice / 100)|number_format(2,',','.') }} ARS</span>
                    </div>

                    <a href="{{ path('mercadopago_checkout', {reference: order.reference}) }}" class="btn-pay">
                        <i class="bi bi-wallet2"></i>
                        Pagar con Mercado Pago
                    </a>

                    <div class="mt-4 pt-4 border-top text-center text-muted small">
                        <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                            <i class="bi bi-shield-lock-fill"></i>
                            <span>Conexión 100% segura</span>
                        </div>
                        <p class="mb-0">Aceptamos la mayoría de tarjetas de crédito y débito</p>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

{% endblock %}
