{% extends 'base.html.twig' %}

{% block title %}Pedido Confirmado - {{ personalize.companyName }}{% endblock %}

{% block body %}
<style>
    :root {
        --c-success: #28a745;
        --c-bg: #fcfbf9;
        --radius-lg: 24px;
        --shadow: 0 10px 40px rgba(0,0,0,.04);
    }
    .success-container {
        padding: 1rem;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 50dvh;
    }
    .success-card {
        background: #fff;
        border-radius: var(--radius-lg);
        padding: 4rem;
        max-width: 600px;
        width: 100%;
        text-align: center;
        box-shadow: var(--shadow);
        border: 1px solid #f0ede8;
    }
    
    @media (max-width: 767px) {
        .success-container { padding: 1rem; min-height: auto; }
        .success-card { padding: 2rem 1.25rem; border-radius: 16px; }
        .success-icon { font-size: 3.5rem; margin-bottom: 1.5rem; }
        .status-badge { padding: 0.4rem 1.25rem; font-size: 0.8rem; margin-bottom: 1.5rem; }
        h4 { font-size: 1.15rem !important; }
        .text-muted.fs-5 { font-size: 0.95rem !important; margin-bottom: 1.5rem !important; }
        .warning-box { padding: 1.25rem; margin-top: 1.5rem; }
        .warning-box h6 { font-size: 0.85rem !important; }
        .warning-box p { font-size: 0.8rem !important; }
        .btn-action { margin-top: 1.5rem; padding: 0.8rem 1.5rem; width: 100%; }
    }
    .success-icon {
        font-size: 5rem;
        color: var(--c-success);
        margin-bottom: 2rem;
        animation: scaleIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    @keyframes scaleIn {
        from { transform: scale(0); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
    .status-badge {
        display: inline-block;
        padding: 0.5rem 1.5rem;
        border-radius: 50px;
        background: #fff3cd;
        color: #856404;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 2rem;
    }
    .order-ref {
        font-family: monospace;
        background: #f8f9fa;
        border-radius: 6px;
        color: #1a1a1a;
    }
    .btn-action {
        background: #1a1a1a;
        color: #fff;
        padding: 1rem 2rem;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 600;
        display: inline-block;
        transition: 0.3s;
        margin-top: 2rem;
        font-size: 0.9rem;
    }
    .btn-action:hover {
        background: #333;
        transform: translateY(-2px);
        color: #fff;
    }
    .warning-box {
        margin-top: 2rem;
        padding: 1.5rem;
        background: #fff9db;
        border-radius: 16px;
        text-align: left;
        border: 1px solid #ffe066;
    }

    /* ── Dark Mode Overrides ── */
    body.dark-mode {
        --c-bg: #121212;
    }
    body.dark-mode .success-card {
        background-color: #1e1e1e !important;
        border-color: #333 !important;
        box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
        color: #ffffff !important;
    }
    body.dark-mode .status-badge {
        background-color: #2b2100 !important;
        color: #ffd666 !important;
    }
    body.dark-mode .order-ref {
        background-color: #2a2a2a !important;
        color: #ffffff !important;
    }
    body.dark-mode .btn-action {
        background-color: #444 !important;
        border: 1px solid #555 !important;
        color: #ffffff !important;
    }
    body.dark-mode .btn-action:hover {
        background-color: #000000 !important;
        border-color: #ffffff !important;
        color: #ffffff !important;
        transform: translateY(-2px);
    }
    body.dark-mode .warning-box {
        background-color: #2b2100 !important;
        border-color: #443500 !important;
        color: #ffffff !important;
    }
    body.dark-mode .warning-box h6, body.dark-mode .warning-box p, body.dark-mode .warning-box b, body.dark-mode .warning-box i {
        color: #ffffff !important;
    }
    body.dark-mode .text-muted {
        color: #b0b0b0 !important;
    }
    body.dark-mode .text-dark {
        color: #ffffff !important;
    }
    body.dark-mode .fw-bold, body.dark-mode .fw-semibold {
        color: #ffffff !important;
    }
</style>

<div class="container success-container">
    <div class="success-card">
        <i class="bi bi-check-circle-fill success-icon"></i>
        <h4 class="fw-bold mb-3">¡Pedido Recibido!</h4>
        <div class="status-badge">Estado: Pendiente de pago</div>
        
        <p class="text-muted fs-5 mb-4">
            Hola <b class="mx-1">{{ order.user.firstname }}</b>, tu pedido <b class="order-ref mx-1">#{{ order.reference }}</b> ha sido registrado correctamente.
        </p>

        <div class="warning-box">
            <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-clock-history mr-2"></i>Plazo de retiro</h6>
            <p class="small mb-0 text-dark">
                Tienes un plazo de <b>72 horas hábiles</b> para retirar tu pedido y pagar presencialmente. Pasado este tiempo, la orden será cancelada automáticamente para liberar el stock.
            </p>
        </div>

        <div class="mt-4 text-start">
            <p class="small text-muted mb-1">Dirección de retiro:</p>
            <p class="fw-semibold">{{ personalize.address }}, {{ personalize.city }}</p>
        </div>

        <a href="{{ path('account_orders') }}" class="btn-action">
            Ver mis pedidos
        </a>
    </div>
</div>
{% endblock %}
