{% extends 'base.html.twig' %}

{% block title %}Mi pedido - {{ personalize.companyName ?? 'Empresa' }}{% endblock %}

{% block body %}

<style>
  /* ── Tokens ── */
  :root {
    --c-bg: #fdfcfb;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 8px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.03);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: var(--font-main), sans-serif;
  }

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }

  .order-container { padding-top: 1rem; padding-bottom: 1rem; max-width: 1200px; }

  /* ── Checkout Progress ── */
  .checkout-steps {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .step-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--c-muted);
    opacity: 0.5;
  }
  .step-item.active { opacity: 1; color: var(--tertiary-color, var(--c-ink)); }
  .step-item.active .step-num { background: var(--tertiary-color, var(--c-ink)); color: #fff; }
  .step-num {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: #eee;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem;
  }
  .step-line {
    width: 40px; height: 1px; background: var(--c-border);
  }

  /* ── Header ── */
  .order-header { margin-bottom: 2rem; text-align: center; }
  .order-title {
    font-size: clamp(1rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin: 0;
  }

  /* ── Grid Layout ── */
  .order-grid { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; align-items: start; }

  /* ── Address Cards (Ultra Minimalist) ── */
  .order-card {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 2rem;
    border: none;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .order-card__title {
    font-size: .9rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--c-ink);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .address-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .address-option {
    position: relative;
    cursor: pointer;
    animation: fadeInUp 0.4s ease backwards;
  }
  .address-option:nth-child(2) { animation-delay: 0.05s; }
  .address-option:nth-child(3) { animation-delay: 0.1s; }
  .address-option:nth-child(4) { animation-delay: 0.15s; }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .address-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .address-card-inner {
    border: 1.5px solid var(--c-border);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    height: 100%;
    transition: all 0.3s ease;
    background: transparent;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .address-option:hover .address-card-inner {
    border-color: var(--c-ink);
    background: #fff;
  }

  .address-option input[type="radio"]:checked + .address-card-inner {
    border-color: var(--tertiary-color, var(--c-ink));
    background: #fff;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
  }

  .address-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.15rem;
  }
  .address-card__name {
    font-weight: 800;
    font-size: 0.75rem;
    color: var(--c-ink);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .address-card__check {
    width: 14px; height: 14px;
    border-radius: 50%;
    border: 1.5px solid var(--c-border);
    display: flex; align-items: center; justify-content: center;
    transition: var(--transition);
  }
  .address-option input[type="radio"]:checked + .address-card-inner .address-card__check {
    background: var(--tertiary-color, var(--c-ink));
    border-color: var(--tertiary-color, var(--c-ink));
  }
  .address-card__check i { color: #fff; font-size: 0.55rem; display: none; }
  .address-option input[type="radio"]:checked + .address-card-inner .address-card__check i { display: block; }

  .address-card__details {
    font-size: 0.8rem;
    color: var(--c-muted);
    line-height: 1.4;
    font-weight: 500;
  }

  .btn-add-new-card {
    border: 1px dashed var(--c-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--c-muted);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.8rem;
    transition: var(--transition);
    height: 100%;
    min-height: 80px;
    background: transparent;
  }
  .btn-add-new-card:hover { border-color: var(--tertiary-color, var(--c-ink)); color: var(--tertiary-color, var(--c-ink)); background: #fff; }
  .btn-add-new-card i { font-size: 1rem; }

  /* ── Right Summary Sidebar ── */
  .summary-sidebar {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    border: none;
    box-shadow: 0 4px 25px rgba(0,0,0,0.04);
    position: sticky; top: 120px;
  }
  .summary-title { font-size: 1.15rem; font-weight: 800; margin-bottom: 2rem; letter-spacing: -0.02em; }

  .summary-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .summary-item__img {
    width: 54px; height: 70px;
    object-fit: cover;
    background: #fdfcfb;
    border-radius: var(--radius-sm);
    border: 1px solid var(--c-border);
  }
  .summary-item__info { flex: 1; min-width: 0; }
  .summary-item__name { 
    font-size: 0.9rem; 
    font-weight: 700; 
    color: var(--c-ink); 
    line-height: 1.25; 
    margin-bottom: 0.2rem;
  }
  .summary-item__qty { font-size: 0.8rem; color: var(--c-muted); font-weight: 500; }
  .summary-item__price { font-size: 0.9rem; font-weight: 800; text-align: right; }

  .summary-totals {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--c-border);
  }
  .total-row {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 1rem;
  }
  .total-label { font-size: 0.9rem; font-weight: 600; color: var(--c-muted); }
  .total-amount { font-size: 0.9rem; font-weight: 900; color: var(--c-ink); letter-spacing: -0.03em; }

  .btn-order-next {
    width: 100%;
    background: var(--tertiary-color, var(--c-ink));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1.15rem;
    font-weight: 800;
    font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    transition: var(--transition);
    cursor: pointer;
  }
  .btn-order-next:hover:not(:disabled) {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    filter: brightness(1.1);
  }
  .btn-order-next:disabled { opacity: 0.5; cursor: not-allowed; }

  /* ── Mobile ── */
  @media (max-width: 991px) {
    .order-container { padding-top: 0px; padding-bottom: 1rem; }
    .order-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .order-card { padding: 1.25rem; }
    .summary-sidebar { position: static; max-width: 100%; padding: 1.5rem; }
    .address-grid { grid-template-columns: 1fr; }
    .btn-add-new-card { height: fit-content; min-height: 0; padding: 0.75rem; align-items: center; }
    .order-title { font-size: 1rem; }
    .checkout-steps { margin-bottom: 1.5rem; gap: 0.5rem; }
    .step-item { font-size: 0.75rem; }
    .step-line { width: 25px; }
  }
  
  @media (max-width: 480px) {
    .order-card { padding: 1rem; }
    .address-card-inner { padding: 1rem; }
  }

  /* ── Dark Mode Overrides ── */
  body.dark-mode {
    --c-bg: #121212;
    --c-surface: #1e1e1e;
    --c-border: #333;
    --c-ink: #f5f5f5;
    --c-muted: #b0b0b0;
  }
  body.dark-mode .order-title { color: #ffffff !important; }
  body.dark-mode .order-card { 
    background-color: #1e1e1e !important; 
    box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
  }
  body.dark-mode .order-card__title { color: #ffffff !important; }
  body.dark-mode .address-card-inner { border-color: #333 !important; }
  body.dark-mode .address-option:hover .address-card-inner { border-color: #ffffff !important; background: #2a2a2a !important; }
  body.dark-mode .address-option input[type="radio"]:checked + .address-card-inner { border-color: #ffffff !important; background: #2a2a2a !important; }
  body.dark-mode .address-card__name { color: #ffffff !important; }
  body.dark-mode .address-card__details { color: #b0b0b0 !important; }
  body.dark-mode .btn-add-new-card { border-color: #444 !important; color: #b0b0b0 !important; }
  body.dark-mode .btn-add-new-card:hover { border-color: #ffffff !important; color: #ffffff !important; background: #2a2a2a !important; }
  body.dark-mode .btn-order-next { background-color: #2a2a2a !important; color: #ffffff !important; border: 1px solid #444 !important; }
  body.dark-mode .step-num { background-color: #333 !important; color: #ffffff !important; }
  body.dark-mode .step-item { color: #b0b0b0 !important; }
  body.dark-mode .step-item.active { color: #ffffff !important; }
  body.dark-mode .step-item.active .step-num { background-color: #ffffff !important; color: #121212 !important; }
  body.dark-mode .step-line { background-color: #444 !important; }
</style>

<div class="container order-container">
    
    <div class="mb-1 mt-0 pt-0">
        <button type="button" onclick="window.history.back()" class="btn-back d-flex align-items-center gap-1 text-muted fw-bold" style="margin: 0; padding: 0; border: none; background: transparent; font-size: 0.9rem;">
            <i class="bi bi-arrow-left"></i> Volver
        </button>
    </div>

    <!-- Step Tracker -->
    <div class="checkout-steps pt-3">
        <div class="step-item active">
            <span class="step-num">1</span> Carrito
        </div>
        <div class="step-line"></div>
        <div class="step-item">
            <span class="step-num">2</span> <u>Envio</u>
        </div>
        <div class="step-line"></div>
        <div class="step-item">
            <span class="step-num">3</span> Pago
        </div>
    </div>

    <header class="order-header">
        <p class="order-title">Seccion de Envio</p>
        <small class="text-muted mt-2">Seleccionar a cual dirección deberiamos entregar tu pedido</small>
    </header>

    {% set formHtml %}
        <div class="row justify-content-center">
            <!-- Form -->
            <div class="col-12 col-md-10 col-lg-8">
                <div class="order-card">
                    <div class="order-card__title">
                        <i class="bi bi-geo-alt" style="color: var(--tertiary-color);"></i>
                        Mis Direcciones Guardadas
                    </div>
                    
                    {% if hasAddresses %}
                        <div class="address-grid">
                            {% for choice in form.addresses %}
                                {% set fullLabel = choice.vars.label|replace({'[br]': '<br>', '{br}': '<br>'}) %}
                                {# Split by the colon separator #}
                                {% set labelParts = fullLabel|split(': <br>') %}
                                
                                <label class="address-option">
                                    <input type="radio" name="{{ choice.vars.full_name }}" value="{{ choice.vars.value }}" {% if choice.vars.checked %}checked="checked"{% endif %}>
                                    <div class="address-card-inner">
                                        <div class="address-card__header">
                                            <div class="address-card__name">
                                                {% if labelParts|length > 1 %}
                                                    {{ labelParts[0]|raw }}
                                                {% else %}
                                                    Dirección
                                                {% endif %}
                                            </div>
                                            <div class="address-card__check">
                                                <i class="bi bi-check-lg"></i>
                                            </div>
                                        </div>
                                        <div class="address-card__details">
                                            {% if labelParts|length > 1 %}
                                                {{ labelParts[1]|raw }}
                                            {% else %}
                                                {{ fullLabel|raw }}
                                            {% endif %}
                                        </div>
                                    </div>
                                </label>
                            {% endfor %}

                            <a href="{{ path('account_address_new') }}" class="btn-add-new-card">
                                <i class="bi bi-plus-circle"></i>
                                <span>Nueva Dirección</span>
                            </a>
                        </div>
                        {% do form.addresses.setRendered() %}

                        <div>
                            <button type="submit" class="btn-order-next" id="btn-proceed">
                                <span class="fw-800">Continuar al Pago</span>
                                <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <div class="mb-4">
                                <i class="bi bi-geo-alt text-muted opacity-25" style="font-size: 4rem;"></i>
                            </div>
                            <h3 class="fw-bold mb-3">No tienes direcciones guardadas</h3>
                            <p class="text-muted mb-4">Necesitamos saber a dónde enviar tu pedido para poder continuar.</p>
                            <a href="{{ path('account_address_new') }}" class="btn-order-next d-inline-flex px-5 w-auto">
                                <i class="bi bi-plus-circle"></i>
                                <span>Agregar mi primera dirección</span>
                            </a>
                        </div>
                        {% do form.addresses.setRendered() %}
                    {% endif %}

                    <div class="mt-4 text-center opacity-75">
                        <small class="text-muted d-flex align-items-center justify-content-center gap-2" style="font-size: 0.7rem;">
                            <i class="bi bi-shield-lock-fill"></i>
                            COMPRA 100% SEGURA
                        </small>
                    </div>
                </div>
            </div>
        </div>
    {% endset %}

    {{ form_start(form, {action: path('order_add'), 'attr': {'id': 'checkout-form'}}) }}
        {{ formHtml|raw }}
        {{ form_widget(form._token) }}
    {{ form_end(form, {'render_rest': false}) }}

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const addressRadios = document.querySelectorAll('input[name="order[addresses]"]');
            const btnSubmit = document.getElementById('btn-proceed');

            const updateUI = () => {
                let anyChecked = false;
                addressRadios.forEach(r => { if(r.checked) anyChecked = true; });
                btnSubmit.disabled = !anyChecked;
            };

            addressRadios.forEach(r => r.addEventListener('change', updateUI));
            updateUI();
        });
    </script>
</div>
{% endblock %}
