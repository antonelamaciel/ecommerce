{% extends 'base.html.twig' %}

{% block title %}Mi carrito{% endblock %}

{% block body %}

<style>
  /* ── Tokens (Consistent with whole ecosystem) ── */
  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }

  .cart-container { padding-top: 3rem; padding-bottom: 5rem; }

  /* ── Header ── */
  .cart-header {
    margin-bottom: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .cart-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .clear-cart-link {
    color: #ef4444;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-radius: 99px;
    transition: var(--transition);
  }
  .clear-cart-link:hover { background: #fef2f2; }

  /* ── Cart Items ── */
  .cart-grid { display: grid; grid-template-columns: 1fr 350px; gap: 3rem; }
  
  .cart-item {
    background: var(--c-surface);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin-bottom: 1rem;
    border: 1px solid var(--c-border);
    display: grid;
    grid-template-columns: 100px 1fr auto;
    align-items: center;
    gap: 1.5rem;
    transition: var(--transition);
  }
  .cart-item:hover { transform: translateX(8px); border-color: var(--primary-color, var(--c-ink)); }

  .cart-item__img-wrap {
    width: 100px; height: 100px;
    background: #fdfcfb;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .cart-item__img { max-width: 80%; max-height: 80%; object-fit: contain; }

  .cart-item__info { display: flex; flex-direction: column; gap: 0.25rem; }
  .cart-item__name { font-weight: 600; font-size: 1.1rem; margin: 0; }
  .cart-item__name a { color: var(--c-ink); text-decoration: none; }
  .cart-item__details { font-size: 0.85rem; color: var(--c-muted); }

  .cart-item__actions { display: flex; align-items: center; gap: 2rem; justify-self: end; }

  /* Quantity Controls */
  .qty-ctrl {
    display: flex;
    align-items: center;
    background: #f3f1ed;
    border-radius: 99px;
    padding: 0.35rem;
    gap: 0.75rem;
  }
  .qty-btn {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #fff;
    border: none;
    color: var(--c-ink);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem;
    transition: var(--transition);
    text-decoration: none !important;
  }
  .qty-btn:hover { background: var(--c-ink); color: #fff; }
  .qty-val { font-weight: 700; font-size: 0.95rem; min-width: 20px; text-align: center; }

  .cart-item__price-total { text-align: right; min-width: 100px; }
  .price-total { font-weight: 700; font-size: 1.15rem; display: block; }
  .price-unit { font-size: 0.8rem; color: var(--c-muted); }

  .btn-remove-item {
    color: var(--c-muted);
    font-size: 1.2rem;
    transition: var(--transition);
    padding: 0.5rem;
  }
  .btn-remove-item:hover { color: #ef4444; transform: scale(1.1); }

  /* ── Summary Sidebar ── */
  .cart-summary {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-soft);
    position: sticky; top: 100px;
    height: fit-content;
  }
  .summary-title { font-size: 1.25rem; font-weight: 700; margin-bottom: 2rem; }
  
  .summary-row {
    display: flex; justify-content: space-between;
    margin-bottom: 1rem; font-size: 0.95rem;
  }
  .summary-row.total {
    margin-top: 1.5rem; padding-top: 1.5rem;
    border-top: 1px solid var(--c-border);
    font-size: 1.4rem; font-weight: 700;
  }
  .summary-row.total .total-label { letter-spacing: -0.02em; }

  .btn-checkout {
    width: 100%;
    background: var(--primary-color, var(--c-ink));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1.25rem;
    font-weight: 700;
    font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
    transition: var(--transition);
    text-decoration: none !important;
  }
  .btn-checkout:hover {
    filter: brightness(1.1); transform: translateY(-3px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1); color: #fff;
  }

  /* ── Empty State ── */
  .cart-empty {
    text-align: center; padding: 6rem 1rem;
    background: var(--c-surface); border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
  }
  .empty-icon { font-size: 4rem; color: var(--c-border); margin-bottom: 1.5rem; display: block; }
  .empty-title { font-size: 1.8rem; font-weight: 700; margin-bottom: 1rem; }
  .empty-text { color: var(--c-muted); margin-bottom: 2.5rem; }
  .btn-modern-primary {
    display: inline-flex; background: var(--c-ink); color: #fff;
    padding: 1rem 2.5rem; border-radius: 99px; text-decoration: none;
    font-weight: 600; transition: var(--transition);
  }
  .btn-modern-primary:hover { transform: translateY(-3px); box-shadow: 0 8px 20px rgba(0,0,0,0.1); }

  @media (max-width: 991px) {
    .cart-grid { grid-template-columns: 1fr; }
    .cart-summary { position: static; }
  }

  @media (max-width: 767px) {
    .cart-item {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
      padding: 1rem;
    }
    .cart-item__actions {
      grid-column: 1 / -1;
      justify-content: space-between;
      width: 100%;
      padding-top: 1rem;
      border-top: 1px dashed var(--c-border);
      gap: 1rem;
    }
    .cart-item__img-wrap { width: 80px; height: 80px; }
    .cart-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
  }
</style>

<div class="container cart-container">
    {% if totalQuantity > 0 %}
        <header class="cart-header">
            <div>
                <h1 class="cart-title">Mi Carrito</h1>
                <p class="text-muted mt-2">Tienes {{ totalQuantity }} artículo(s) listo(s) para comprar</p>
            </div>
            <a href="{{ path('remove_cart') }}" class="clear-cart-link">
                <i class="bi bi-trash3"></i> Vaciar carrito
            </a>
        </header>

        <div class="cart-grid">
            <!-- Part 1: Items List -->
            <div class="cart-items-list">
                {% for item in cart %}
                    <article class="cart-item">
                        <div class="cart-item__img-wrap">
                            <img src="/uploads/{{ item.product.image }}" alt="{{ item.product.name }}" class="cart-item__img">
                        </div>
                        
                        <div class="cart-item__info">
                            <h3 class="cart-item__name">
                                <a href="{{ path('product_show', {slug: item.product.slug}) }}">{{ item.product.name }}</a>
                            </h3>
                            <span class="cart-item__details">{{ item.product.subtitle }}</span>
                        </div>

                        <div class="cart-item__actions">
                            <div class="qty-ctrl">
                                <a href="{{ path('decrease_item', {id: item.product.id}) }}" class="qty-btn" title="Quitar uno">
                                    <i class="bi bi-dash-lg"></i>
                                </a>
                                <span class="qty-val">{{ item.quantity }}</span>
                                <a href="{{ path('add_to_cart', {id: item.product.id}) }}" class="qty-btn" title="Añadir uno">
                                    <i class="bi bi-plus-lg"></i>
                                </a>
                            </div>

                            <div class="cart-item__price-total">
                                <span class="price-total">$ {{ (item.quantity * (item.product.price / 100))|number_format(2,',','.') }} ARS</span>
                                <span class="price-unit">$ {{ (item.product.price / 100)|number_format(2,',','.') }} ARS / ud.</span>
                            </div>

                            <a href="{{ path('remove_cart_item', {id: item.product.id}) }}" class="btn-remove-item" title="Eliminar artículo">
                                <i class="bi bi-x-circle-fill"></i>
                            </a>
                        </div>
                    </article>
                {% endfor %}
                
                <div class="mt-4">
                    <a href="{{ path('product') }}" class="text-decoration-none fw-semibold" style="color: var(--c-muted)">
                        <i class="bi bi-arrow-left me-1"></i> Seguir explorando productos
                    </a>
                </div>
            </div>

            <!-- Part 2: Order Summary -->
            <aside>
                <div class="cart-summary">
                    <h2 class="summary-title">Resumen del pedido</h2>
                    
                    <div class="summary-row">
                        <span>Subtotal ({{ totalQuantity }} art.)</span>
                        <span class="fw-bold">$ {{ (totalPrice / 100)|number_format(2,',','.') }} ARS</span>
                    </div>
                    <div class="summary-row">
                        <span>Envío estimado</span>
                        <span class="text-success fw-bold">Gratis</span>
                    </div>
                    <div class="summary-row">
                        <span>Impuestos incluidos</span>
                        <span class="text-muted">Incluidos en total</span>
                    </div>

                    <div class="summary-row total">
                        <span class="total-label">Total</span>
                        <span>$ {{ (totalPrice / 100)|number_format(2,',','.') }} ARS</span>
                    </div>

                    <a href="{{ path('order') }}" class="btn-checkout">
                        <span>Proceder al pago</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>

                    <div class="mt-4 pt-4 border-top">
                        <div class="d-flex align-items-center gap-3 text-muted small mb-2">
                            <i class="bi bi-shield-lock-fill fs-5"></i>
                            <span>Pago 100% encriptado y seguro</span>
                        </div>
                    </div>
                </div>
            </aside>
        </div>

    {% else %}
        <!-- Empty State -->
        <div class="cart-empty">
            <i class="bi bi-bag-x empty-icon"></i>
            <h2 class="empty-title">Tu carrito está vacío</h2>
            <p class="empty-text">Parece que aún no has añadido nada a tu selección.</p>
            <a href="{{ path('home') }}" class="btn-modern-primary">
                Explorar productos
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
