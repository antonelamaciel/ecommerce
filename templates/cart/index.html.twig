{% extends 'base.html.twig' %}

{% block title %}Mi carrito{% endblock %}

{% block body %}

<style>
  /* ── Tokens ── */
  :root {
    --c-bg: #fdfcfb;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: var(--tertiary-color, #1a1a1a);
    --c-muted: #696561;
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 8px;
    --shadow-soft: 0 4px 25px rgba(0,0,0,0.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
  }

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }

  .cart-container { padding-top: 1rem; padding-bottom: 1rem; max-width: 1200px; }

  /* ── Checkout Progress ── */
  .checkout-steps {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .step-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--c-muted);
    opacity: 0.5;
  }
  .step-item.active { opacity: 1; color: var(--tertiary-color, var(--c-ink)); }
  .step-item.active .step-num { background: var(--tertiary-color, var(--c-ink)); color: #fff; }
  .step-num {
    width: 24px; height: 24px;
    border-radius: 50%;
    background: #eee;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem;
  }
  .step-line {
    width: 40px; height: 1px; background: var(--c-border);
  }

  /* ── Header ── */
  .cart-header {
    margin-bottom: 2rem;
    text-align: center;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .cart-title {
    font-size: clamp(1.2rem, 4vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    margin: 0;
  }

  /* ── Cart Grid ── */
  .cart-grid { display: grid; grid-template-columns: 1fr 380px; gap: 1.5rem; align-items: start; }
  
  .cart-items-list {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 1rem 1.75rem;
    box-shadow: var(--shadow-soft);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    animation: fadeInUp 0.5s ease backwards;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .cart-item {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: .5rem 0;
    border-bottom: 1px solid var(--c-border);
    transition: var(--transition);
    position: relative;
  }
  .cart-item:last-child { border-bottom: none; }

  .cart-item__img-wrap {
    width: 80px; height: 100px;
    border-radius: 5px;
    overflow: hidden;
    transition: var(--transition);
  }
  .cart-item:hover .cart-item__img-wrap { transform: scale(1.02); }
  .cart-item__img { width: 100%; height: 100%; object-fit: cover; }

  .cart-item__main {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0; /* Required for ellipsis in some browsers */
  }

  .cart-item__info { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; }
  .cart-item__name { 
    font-weight: 800; font-size: 1.1rem; margin: 0; line-height: 1.2; letter-spacing: -0.02em; 
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cart-item__name a { color: var(--c-ink); text-decoration: none; display: block; overflow: hidden; text-overflow: ellipsis; }
  .cart-item__variants { font-size: 0.7rem; color: var(--c-ink); background: #f0ede8; padding: 0.15rem 0.5rem; border-radius: 99px; width: fit-content; font-weight: 700; text-transform: uppercase; margin-top: 0.2rem; }

  /* New Actions Layer */
  .cart-item__actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 0.25rem;
  }

  .qty-ctrl {
    display: flex;
    align-items: center;
    background: #f8f7f5;
    border-radius: 12px;
    padding: 0.25rem;
    gap: 0.25rem;
  }
  .qty-btn {
    width: 28px; height: 28px;
    border-radius: 10px;
    background: #fff;
    border: 1px solid var(--c-border);
    color: var(--c-ink);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem;
    transition: var(--transition);
    text-decoration: none !important;
  }
  .qty-btn:hover { background: var(--c-ink); color: #fff; border-color: var(--c-ink); }
  .qty-val { font-weight: 800; font-size: 0.95rem; min-width: 32px; text-align: center; }

  .cart-item__side {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
  }

  .cart-item__price-wrap { text-align: right; }
  .price-total { font-weight: 900; font-size: 1.2rem; color: var(--c-ink); letter-spacing: -0.03em; }
  .price-unit { font-size: 0.75rem; color: var(--c-muted); font-weight: 600; display: block; margin-top: 0.05rem; }

  .btn-remove-item {
    color: #ef4444;
    background: transparent;
    border: none;
    padding: 0.5rem;
    font-size: 1.15rem;
    transition: var(--transition);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }
  .btn-remove-item:hover { color: #ef4444; background: #fff1f2; transform: scale(1.1); }

  /* ── Summary Sidebar ── */
  .cart-summary {
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    padding: 1rem;
    border: none;
    box-shadow: var(--shadow-soft);
    position: sticky; top: 120px;
    animation: fadeInUp 0.5s ease backwards 0.2s;
  }
  .summary-title { font-size: 1.25rem; font-weight: 800; margin-bottom: 2rem; color: var(--c-ink); letter-spacing: -0.02em; }
  
  .summary-row {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: .5rem; font-size: 0.95rem; color: var(--c-muted); font-weight: 500;
  }
  .summary-row.total {
    margin-top: 1rem; padding-top: 1rem;
    border-top: 1px solid var(--c-border);
    align-items: flex-end;
  }
  .summary-row.total .total-label { font-size: 0.9rem; font-weight: 600; color: var(--c-muted); }
  .summary-row.total .total-amount { font-size: 0.9rem; font-weight: 900; color: var(--c-ink); letter-spacing: -0.03em; }

  .btn-checkout {
    width: 100%;
    background: var(--tertiary-color, var(--c-ink));
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 1.15rem;
    font-weight: 800;
    font-size: 1rem;
    display: flex; align-items: center; justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    transition: var(--transition);
    text-decoration: none !important;
  }
  .btn-checkout:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.1);
    filter: brightness(1.1); color: #fff;
  }

  .btn-shipping-info {
    font-size: 0.85rem;
    font-weight: 800;
    color: #fff;
    background: #6ed197;
    border: none;
    border-radius: var(--radius-md);
    padding: 0.9rem 1.25rem;
    width: 100%;
    display: flex; align-items: center; justify-content: center;
    gap: 0.6rem;
    transition: var(--transition);
    margin: 1.5rem 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .btn-shipping-info:hover { filter: brightness(1.05); transform: translateY(-2px); box-shadow: 0 5px 20px rgba(110, 209, 151, 0.3); }

  /* ── Selection Cards ── */
  .selection-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .selection-card {
    position: relative; display: block;
    background: #fff; border: 1.5px solid var(--c-border);
    border-radius: var(--radius-md); padding: 1rem 1.25rem;
  }
  .selection-card__body { display: flex; align-items: center; gap: 1rem; }
  .selection-card__icon { 
    width: 42px; height: 42px; border-radius: 12px; background: #f8f7f5;
    display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
    color: var(--c-muted);
  }
  .selection-card__info { flex: 1; min-width: 0; }
  .selection-card__name { font-weight: 800; font-size: 0.95rem; color: var(--c-ink); margin-bottom: 0.1rem; }
  .selection-card__desc { font-size: 0.8rem; color: var(--c-muted); font-weight: 500; line-height: 1.2; }

  /* ── Responsive ── */
  @media (max-width: 991px) {
    .cart-container { padding-top: 0px; padding-bottom: .5rem; }
    .cart-grid { grid-template-columns: 1fr; gap: 1rem; }
    .cart-summary { position: static; max-width: 100%; padding: 1rem; }
    .cart-items-list { padding: 1rem; gap: 0.25rem; }
    .checkout-steps { margin-bottom: 1.5rem; gap: 0.5rem; }
    .step-item { font-size: 0.7rem; gap: 0.4rem; }
    .step-line { width: 20px; }
    .cart-header { margin-bottom: 1.5rem; }
  }

  @media (max-width: 767px) {
    .cart-items-list { gap: 0; }
    .cart-item {
      grid-template-columns: 70px 1fr;
      gap: 0 1rem;
      padding: 0.75rem 0;
    }
    .cart-item__img-wrap { width: 70px; height: 90px; }
    .cart-item__side {
      grid-column: 1 / -1;
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      margin-top: 0;
      background: #fdfcfb;
      padding: 0 0.75rem 0.5rem 0.75rem;
      border-radius: var(--radius-md);
    }
    .cart-item__name { font-size: 1rem; }
    .price-total { font-size: 1.1rem; }
    .qty-btn { width: 26px; height: 26px; }
    .qty-val { font-size: 0.85rem; min-width: 28px; }
    .cart-item__price-wrap { text-align: left; }
    .btn-remove-item { order: 2; }
    .summary-row { margin-bottom: 0.75rem; font-size: 0.9rem; }
    .summary-title { margin-bottom: 1rem; font-size: 1.1rem; }
    .btn-checkout { padding: 0.9rem; margin-top: 1rem; font-size: 0.9rem; }
    .btn-shipping-info { padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.75rem; }
  }

  /* ── Dark Mode Overrides ── */
  body.dark-mode {
    --c-bg: #121212;
    --c-surface: #1e1e1e;
    --c-border: #333;
    --c-ink: #f5f5f5;
    --c-muted: #b0b0b0;
    color: #f5f5f5;
  }
  body.dark-mode .cart-title,
  body.dark-mode .summary-title { color: #ffffff !important; }
  body.dark-mode .cart-items-list, 
  body.dark-mode .cart-summary {
    background-color: #1e1e1e !important;
    border-color: #333 !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
  }
  body.dark-mode .cart-item { border-bottom-color: #333 !important; }
  body.dark-mode .cart-item__name a, body.dark-mode .price-total { color: #ffffff !important; }
  body.dark-mode .summary-row.total { border-top-color: #333 !important; }
  body.dark-mode .total-amount { color: #ffffff !important; }
  body.dark-mode .qty-ctrl { background-color: #2a2a2a !important; }
  body.dark-mode .qty-btn { background-color: #333 !important; border-color: #444 !important; color: #fff !important; }
  body.dark-mode .cart-item__variants { background-color: #333 !important; color: #fff !important; }
  body.dark-mode .step-num { background-color: #333 !important; color: #ffffff !important; }
  body.dark-mode .step-item { color: #b0b0b0 !important; }
  body.dark-mode .step-item.active { color: #ffffff !important; }
  body.dark-mode .step-item.active .step-num { background-color: #ffffff !important; color: #121212 !important; }
  body.dark-mode .step-line { background-color: #444 !important; }
  body.dark-mode .cart-item__side { background-color: #1e1e1e !important; }
  body.dark-mode .btn-checkout { background-color: #2a2a2a !important; color: #ffffff !important; border: 1px solid #444 !important; }

  /* Shipping Popup Dark Mode */
  body.dark-mode .modal-content { background-color: #1a1a1a !important; color: #fff !important; border: 1px solid #333 !important; }
  body.dark-mode .modal-header .modal-title { color: #fff !important; }
  body.dark-mode .modal-header button.close { color: #fff !important; text-shadow: none; opacity: 0.8; }
  body.dark-mode .modal-header button.close:hover { opacity: 1; }
  body.dark-mode .selection-card { background-color: #222 !important; border-color: #333 !important; }
  body.dark-mode .selection-card__name { color: #fff !important; }
  body.dark-mode .selection-card__icon { background-color: #2d2d2d !important; color: #fff !important; }
  body.dark-mode .selection-card__desc { color: #aaa !important; }
  body.dark-mode .modal-footer .btn-dark { background-color: #333 !important; border-color: #444 !important; color: #fff !important; }
  body.dark-mode .selection-card .text-success { color: #2ecc71 !important; }
  body.dark-mode .selection-card .text-muted { color: #aaa !important; }
  
  /* Shipping Results Dark Mode */
  body.dark-mode #shipping-results .text-dark { color: #fff !important; }
  body.dark-mode #shipping-results .border-bottom { border-color: #333 !important; }
  body.dark-mode #shipping-results .text-muted { color: #aaa !important; }
</style>

<div class="container cart-container">
    {% if totalQuantity > 0 %}
        <div class="mb-2 mt-0 pt-0 d-flex justify-content-between align-items-center">
            <button type="button" onclick="window.history.back()" class="btn-back d-flex align-items-center gap-1 text-muted fw-bold" style="margin: 0; padding: 0; border: none; background: transparent; font-size: 0.9rem;">
                <i class="bi bi-arrow-left"></i> Volver
            </button>
            <a href="{{ path('remove_cart') }}" class="text-danger opacity-75 hover-opacity-100 text-decoration-none fw-bold small d-flex align-items-center gap-1" style="margin: 0; padding: 0; transition:0.2s; font-size: 0.9rem;">
                <i class="bi bi-trash3"></i> <b class="mx-2">Vaciar carrito</b>
            </a>
        </div>

        <!-- Step Tracker -->
        <div class="checkout-steps pt-3">
            <div class="step-item">
                <span class="step-num">1</span> <u>Carrito</u>
            </div>
            <div class="step-line"></div>
            <div class="step-item">
                <span class="step-num">2</span> Envio
            </div>
            <div class="step-line"></div>
            <div class="step-item">
                <span class="step-num">3</span> Pago
            </div>
        </div>

        <header class="cart-header">
            <p class="cart-title">MI CARRITO (<span class="js-cart-count">{{ totalQuantity }}</span>) </p>
        </header>

        <div class="cart-grid">
            <main>
                <div class="cart-items-list">

                    {% for item in cart %}
                        <article class="cart-item js-cart-item" data-id="{{ item.compositeId }}" data-price="{{ item.product.price }}">
                            <div class="cart-item__img-wrap">
                                <img src="/uploads/{{ item.product.image }}" alt="{{ item.product.name }}" class="cart-item__img" loading="lazy">
                            </div>
                            
                            <div class="cart-item__main">
                                <div class="cart-item__info">
                                    <h3 class="cart-item__name">
                                        <a href="{{ path('product_show', {slug: item.product.slug}) }}">
                                            {{ item.product.name }}
                                        </a>
                                    </h3>
                                    
                                    {% if item.product.bundles|length > 0 %}
                                        <div class="mb-1" style="display: flex; gap: 4px; flex-wrap: wrap;">
                                            {% for bundle in item.product.bundles %}
                                                {% if bundle.type %}
                                                    <span class="bundle-pill" style="font-size: 0.55rem; padding: 2px 6px;">
                                                        {{ bundle.type == 'pocas_unidades' ? '¡Apurate, quedan pocas unidades!' : 
                                                           (bundle.type == 'oferta_sorpresa' ? '¡Oferta sorpresa!' : 
                                                           (bundle.type == 'ultimos_stock' ? '¡Últimos en stock!' : bundle.type)) }}
                                                    </span>
                                                {% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endif %}

                                    {% if item.variants %}
                                        <div class="cart-item__variants">
                                            {{ item.variants }}
                                        </div>
                                    {% endif %}
                                </div>

                                 <div class="cart-item__actions">
                                    <div class="qty-ctrl">
                                        <a href="{{ path('decrease_item', {id: item.compositeId}) }}" class="qty-btn js-qty-btn" data-action="decrease" title="Menos">
                                            <i class="bi bi-dash"></i>
                                        </a>
                                        <span class="qty-val js-qty-val">{{ item.quantity }}</span>
                                        <a href="{{ path('add_to_cart', {id: item.product.id, qty: 1, variants: item.variants}) }}" class="qty-btn js-qty-btn" data-action="increase" data-max-stock="{{ item.product.stock ?? 9999 }}"
                                           title="Más">
                                            <i class="bi bi-plus"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="cart-item__side">
                                <a href="{{ path('remove_cart_item', {id: item.compositeId}) }}" class="btn-remove-item js-remove-item" title="Eliminar">
                                    <i class="bi bi-trash3"></i>
                                </a>
                                <div class="cart-item__price-wrap">
                                    <span class="price-total js-price-total">ARS {{ (item.quantity * item.product.price)|number_format(2,',','.') }}</span>
                                    <span class="price-unit js-price-unit" style="{{ item.quantity > 1 ? '' : 'display:none;' }}">ARS {{ item.product.price|number_format(2,',','.') }} ud.</span>
                                </div>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            </main>

            <aside>
                <div class="cart-summary js-cart-summary">
                    <h2 class="summary-title">Resumen de Pedido</h2>
                

                    <div class="summary-row total mb-3">
                        <span class="total-label">Subtotal  <span class="js-cart-count">{{ totalQuantity }}</span> producto(s) </span>
                        <span class="total-amount js-cart-total-price" data-raw-price="{{ totalPrice }}">ARS {{ totalPrice|number_format(2,',','.') }}</span>
                    </div>
                    <hr>

                    <a href="{{ path('order') }}" class="btn-checkout">
                        <span>Seleccionar Dirección</span>
                        <i class="bi bi-arrow-right"></i>
                    </a>


                    <button type="button" class="btn-shipping-info" data-toggle="modal" data-target="#shippingMethodsModal">
                        <i class="bi bi-truck"></i>
                        Ver info de envíos
                    </button>

                    <div class="shipping-calculator mt-3 pb-3 border-bottom">
                        <label for="shipping-cp" class="small fw-bold text-muted mb-2">Calcular costo de envío</label>
                        <div class="input-group mb-2">
                            <input type="text" id="shipping-cp" class="form-control" placeholder="Tu código postal" style="border-radius: var(--radius-sm) 0 0 var(--radius-sm); border: 1px solid var(--c-border); font-size: 0.9rem;">
                            <button class="btn btn-dark" type="button" id="btn-calc-shipping" style="border-radius: 0 var(--radius-sm) var(--radius-sm) 0; font-size: 0.85rem; font-weight: 700;">
                                Calcular
                            </button>
                        </div>
                        <div id="shipping-results" class="d-none mt-2">
                            <!-- JS fills options here -->
                        </div>
                        <div id="shipping-error" class="text-danger small fw-bold d-none mt-1"></div>
                        <a href="https://www.correoargentino.com.ar/formularios/cpa" target="_blank" class="small text-decoration-none text-muted" style="font-size: 0.75rem;"><i class="bi bi-info-circle"></i> No sé mi código postal</a>
                    </div>
                    <div class="mt-2 pt-2 text-center opacity-75">
                        <small class="text-muted d-flex align-items-center justify-content-center gap-2" style="font-size: 0.75rem; font-weight: 700;">
                            <i class="bi bi-shield-check-fill " style="font-size: 1.1rem; color: #6ed197;"></i>
                            PAGO SEGURO Y PROTEGIDO
                        </small>
                    </div>
                </div>
            </aside>
        </div>

    {% else %}
        <div class="cart-empty py-5 text-center">
            <div class="d-inline-flex mb-4">
                <i class="bi bi-bag-x" style="font-size: 3rem; color: #cbd5e1;"></i>
            </div>
            <h2 class="order-title mb-3">Tu carrito está vacío</h2>
            <p class="text-muted mb-4">¡No te preocupes! Tenemos productos increíbles esperándote.</p>
            <a href="{{ path('home') }}" class="btn d-inline-flex w-auto px-5 rounded-pill fw-bold" style="background: #6c757d; color: #ffffff; border: none; padding-top: 0.8rem; padding-bottom: 0.8rem;">
                Ir de compras
            </a>
        </div>
    {% endif %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const formatPrice = (price) => {
        return 'ARS ' + (price).toLocaleString('es-AR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    };

    const updateTotals = (data) => {
        const cartCounts = document.querySelectorAll('.js-cart-count');
        const totalPrices = document.querySelectorAll('.js-cart-total-price');
        const badgeCounts = document.querySelectorAll('.cart-badge');

        cartCounts.forEach(el => el.textContent = data.cartCount);
        totalPrices.forEach(el => el.textContent = formatPrice(data.totalPrice));
        badgeCounts.forEach(el => el.textContent = data.cartCount);
        
        if (data.cartCount === 0) {
            location.reload(); 
        }
    };

    document.querySelectorAll('.js-qty-btn').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            const item = this.closest('.js-cart-item');
            const qtyVal = item.querySelector('.js-qty-val');
            const priceTotal = item.querySelector('.js-price-total');
            const priceUnit = item.querySelector('.js-price-unit');
            const unitPrice = parseInt(item.dataset.price);
            const action = this.dataset.action;
            
            let currentQty = parseInt(qtyVal.textContent);
            if (action === 'decrease' && currentQty === 1) return;
            if (action === 'increase' && currentQty >= parseInt(this.dataset.maxStock || 9999)) return;

            const url = new URL(this.href, window.location.origin);
            url.searchParams.set('ajax', '1');

            item.style.opacity = '0.5';
            item.style.pointerEvents = 'none';

            fetch(url, { 
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' } 
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const newQty = (action === 'increase') ? currentQty + 1 : currentQty - 1;
                    qtyVal.textContent = newQty;
                    priceTotal.textContent = formatPrice(newQty * unitPrice);
                    priceUnit.style.display = newQty > 1 ? 'block' : 'none';
                    updateTotals(data);
                }
            })
            .finally(() => {
                item.style.opacity = '1';
                item.style.pointerEvents = 'auto';
            });
        });
    });

    document.querySelectorAll('.js-remove-item').forEach(btn => {
        btn.addEventListener('click', function(e) {
            e.preventDefault();
            if (!confirm('¿Eliminar este producto?')) return;

            const item = this.closest('.js-cart-item');
            const url = new URL(this.href, window.location.origin);
            url.searchParams.set('ajax', '1');

            item.style.transform = 'scale(0.95)';
            item.style.opacity = '0.5';

            fetch(url, { 
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' } 
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    item.remove();
                    updateTotals(data);
                }
            });
        });
    });

    const btnCalcShipping = document.getElementById('btn-calc-shipping');
    const inputCp = document.getElementById('shipping-cp');
    const resultsContainer = document.getElementById('shipping-results');
    const errorContainer = document.getElementById('shipping-error');

    if (btnCalcShipping && inputCp) {
        btnCalcShipping.addEventListener('click', function() {
            const cp = inputCp.value.trim();
            if (!cp) {
                errorContainer.textContent = 'Ingresa un código postal';
                errorContainer.classList.remove('d-none');
                return;
            }

            errorContainer.classList.add('d-none');
            btnCalcShipping.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btnCalcShipping.disabled = true;

            fetch('{{ path('cart_shipping_estimate') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ postalCode: cp })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success && data.options) {
                    resultsContainer.innerHTML = '';
                    resultsContainer.classList.remove('d-none');
                    
                    data.options.forEach(opt => {
                        resultsContainer.innerHTML += `
                            <div class="d-flex justify-content-between align-items-center mb-1 pb-1 border-bottom" style="font-size: 0.85rem; padding-bottom: 5px;">
                                <div class="d-flex flex-column">
                                    <span class="text-dark fw-bold">${opt.name}</span>
                                    <span class="text-muted small">${opt.eta}</span>
                                </div>
                                <span class="fw-bold text-dark">${opt.formatted}</span>
                            </div>
                        `;
                    });
                } else {
                    errorContainer.textContent = data.error || 'Error al calcular';
                    errorContainer.classList.remove('d-none');
                    resultsContainer.classList.add('d-none');
                }
            })
            .catch(err => {
                errorContainer.textContent = 'Hubo un error de conexión';
                errorContainer.classList.remove('d-none');
            })
            .finally(() => {
                btnCalcShipping.innerHTML = 'Calcular';
                btnCalcShipping.disabled = false;
            });
        });
    }
});
</script>

<div class="modal fade" id="shippingMethodsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold">Métodos de Envío</h5>
                <button type="button" class="btn d-flex align-items-center justify-content-center" data-dismiss="modal" aria-label="Close" style="width: 38px; height: 38px; border-radius: 50%; padding: 0; background: var(--tertiary-color) !important; color: var(--primary-color) !important; border: 1px solid var(--primary-color) !important; transition: all 0.2s;">
                    <i class="bi bi-x-lg" style="font-size: 1.1rem;"></i>
                </button>
            </div>
            <div class="modal-body p-4">
                <div class="selection-list">
                    {# 1. Retiro en Sucursal (Manual/Configurado en Personalize) #}
                    <div class="selection-card">
                        <div class="selection-card__body">
                            <div class="selection-card__icon"><i class="bi bi-geo-alt"></i></div>
                            <div class="selection-card__info">
                                <div class="selection-card__name">Retiro en local <span class="text-success small fw-bold ms-1">GRATIS</span></div>
                                <div class="selection-card__desc">{{ personalize.address }}</div>
                            </div>
                        </div>
                    </div>

                    {# 2. Envíos Dinámicos desde el Backend (Costo Fijo) #}
                    {% for carrier in carriers %}
                        {% if carrier.type == 'standard' %}
                            <div class="selection-card">
                                <div class="selection-card__body">
                                    <div class="selection-card__icon"><i class="bi bi-truck"></i></div>
                                    <div class="selection-card__info">
                                        <div class="selection-card__name">
                                            {{ carrier.name }}
                                            <span class="text-success small fw-bold ml-2">
                                                {% if carrier.price == 0 %}
                                                    GRATIS
                                                {% else %}
                                                    ARS {{ carrier.price|number_format(2, ',', '.') }}
                                                {% endif %}
                                            </span>
                                        </div>
                                        <div class="selection-card__desc">{{ carrier.description }}</div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}

                    {# 3. Envíos por Coordinar (Manual/WhatsApp) #}
                    <div class="selection-card">
                        <div class="selection-card__body">
                            <div class="selection-card__icon text-success"><i class="bi bi-whatsapp"></i></div>
                            <div class="selection-card__info">
                                <div class="selection-card__name">Coordinar envío rápido</div>
                                <div class="selection-card__desc">Moto / Uber / Mensajería</div>
                            </div>
                            <a href="https://wa.me/{{ personalize.whatsapp|replace({'+': '', ' ': '', '-': ''}) }}" target="_blank" class="btn btn-success btn-sm rounded-pill fw-bold">
                                Consultar
                            </a>
                        </div>
                    </div>

                    {# 4. Nota informativa sobre otros métodos #}
                    <div class="selection-card">
                        <div class="selection-card__body">
                           <small class="text-muted">Calcularemos otros métodos (como correos nacionales) según tu Código Postal en el siguiente paso.</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-dark w-100 rounded-pill py-2" data-dismiss="modal">Entendido</button>
            </div>
        </div>
    </div>
</div>
</style>
{% endblock %}
