{% extends '@!EasyAdmin/crud/index.html.twig' %}

{% block head_stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
{% endblock %}

{% block main %}
    <div class="ea-modern-wrapper">
        
        {# DASHBOARD STATS SECTION #}
        {% block ea_stats_grid %}
        <div class="ea-stats-grid">
            <div class="ea-stat-card">
                <div class="ea-stat-icon" style="color: #6366f1; background: #f5f3ff;">
                    <i class="bi bi-layers-half"></i>
                </div>
                <div class="ea-stat-info">
                    <span class="label">Total {{ ea.crud.entityLabelInPlural }}</span>
                    <span class="value">{{ paginator.numResults }}</span>
                </div>
            </div>
        </div>
        {% endblock ea_stats_grid %}

        {# PREMIUM CARD LIST #}
        <div class="ea-list-container">
            
            {# HEADER #}
            {% if entities|length > 0 %}
                <div class="ea-list-header d-none d-lg-grid" style="grid-template-columns: repeat({{ entities|first.fields|length }}, 1fr) 100px; gap: 1.5rem;">
                    {% for field in entities|first.fields %}
                        <div>{{ field.label|raw }}</div>
                    {% endfor %}
                    <div class="text-end">Opciones</div>
                </div>
            {% endif %}

            {# ROWS #}
            {% for entity in entities %}
                <div class="ea-list-row" style="display: grid; grid-template-columns: repeat({{ entity.fields|length }}, 1fr) 100px; gap: 1.5rem; align-items: center;">
                    
                    {% for field in entity.fields %}
                        <div class="ea-list-cell" data-label="{{ field.label|e('html_attr') }}">
                            {# Intelligent Rendering #}
                            {% if 'image' in field.templatePath or 'avatar' in field.templatePath %}
                                <div class="cell-media">
                                    {{ include(field.templatePath, { field: field, entity: entity }, with_context = false) }}
                                </div>
                            {% elseif 'boolean' in field.templatePath %}
                                <div class="cell-status">
                                    {{ include(field.templatePath, { field: field, entity: entity }, with_context = false) }}
                                </div>
                            {% else %}
                                <div class="cell-text">
                                    {{ include(field.templatePath, { field: field, entity: entity }, with_context = false) }}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}

                    {# ACTION BUTTON #}
                    <div class="text-end">
                        {% if entity.actions.count > 0 %}
                            <div class="dropdown">
                                <a class="btn-modern-action" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-three-dots"></i>
                                </a>

                                <div class="dropdown-menu dropdown-menu-right p-2 shadow-lg border-0" style="border-radius: 18px; min-width: 180px;">
                                    {% for action in entity.actions %}
                                        {{ include(action.templatePath, { action: action, entity: entity, isIncludedInDropdown: true }, with_context = false) }}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% else %}
                <div class="p-5 text-center">
                    <div class="empty-state-icon mb-3" style="font-size: 4rem; opacity: 0.1;">
                        <i class="bi bi-folder2-open"></i>
                    </div>
                    <h5 class="text-muted fw-bold">No hay registros disponibles</h5>
                    <p class="text-muted small">Comienza agregando uno nuevo desde el botón superior.</p>
                </div>
            {% endfor %}
        </div>

        {# PAGINATION #}
        {% if entities|length > 0 %}
            <div class="mt-5 d-flex justify-content-center">
                {{ include(ea.templatePath('crud/paginator')) }}
            </div>
        {% endif %}
    </div>

{% endblock %}
