{% extends 'base.html.twig' %}

{% block title %}Archivo muy grande | {{ personalize.companyName ?? 'MONKAI' }}{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="text-center p-5 card-premium" style="background:#fff; border-radius: 2rem; border: 2px solid var(--tertiary-color); box-shadow: 0 40px 100px rgba(0,0,0,0.1);">
                <div style="background: #fff0f0; color: #dc3545; width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; font-size: 3rem;">
                    <i class="bi bi-file-earmark-excel"></i>
                </div>
                <h1 class="display-5 fw-800 mb-3" style="color: #1e293b; letter-spacing: -0.02em; font-weight: 800;">¡Archivo muy pesado!</h1>
                <p class="text-muted lead mb-5" style="line-height: 1.6;">El archivo que intentas subir excede el límite permitido por el servidor (error 413). Por favor comprime el archivo o usa uno más pequeño.</p>
                
                <div class="d-flex flex-column gap-3">
                    <button type="button" onclick="window.history.back()" class="btn w-100 py-3 fw-bold shadow-lg" style="border-radius: 1rem; font-size: 1.1rem; text-transform: uppercase; background: var(--tertiary-color) !important; color: var(--primary-color) !important; border: 1.5px solid var(--primary-color) !important;">
                        <i class="bi bi-arrow-left-circle mr-2"></i> Volver a donde estaba
                    </button>
                    <a href="/" class="btn btn-link text-muted fw-600 text-decoration-none mt-2">Ir a la página de inicio</a>
                </div>
            </div>
            
            <p class="text-center text-muted small mt-5">Error 413 - Request Entity Too Large</p>
        </div>
    </div>
</div>

<style>
    body.dark-mode .card-premium {
        background-color: #1e1e1e !important;
        border-color: var(--tertiary-color) !important;
    }
    body.dark-mode h1 { color: #fff !important; }
    body.dark-mode .text-muted { color: #b0b0b0 !important; }
</style>
{% endblock %}
