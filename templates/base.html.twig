    <script>
        // Global function to update cart count and animate the badge
        window.updateGlobalCartCount = function(count) {
            const badges = document.querySelectorAll('.cart-badge');
            if (badges.length > 0) {
                badges.forEach(b => {
                    b.textContent = count;
                    b.classList.remove('badge-pop-anim');
                    void b.offsetWidth; // trigger reflow to reset animation
                    b.classList.add('badge-pop-anim');
                });
            } else {
                document.querySelectorAll('.cart-btn').forEach(cartBtn => {
                    const badge = document.createElement('span');
                    badge.className = 'cart-badge badge-pop-anim';
                    badge.textContent = count;
                    cartBtn.appendChild(badge);
                });
            }
        };

        window.addEventListener('scroll', function() {
            const whatsappContainer = document.getElementById('whatsappFloatingContainer');
            const whatsappBtn = document.getElementById('whatsappBtn');
            const targetEl = whatsappContainer ? whatsappContainer : whatsappBtn;
            
            const scrollToTop = document.getElementById('scrollToTop');
            const scrollPos = window.scrollY;

            // Transparency logic: if scrolled more than 100px, make them semi-transparent
            if (scrollPos > 100) {
                if (targetEl) targetEl.classList.add('scrolled-control');
                if (scrollToTop) {
                    scrollToTop.classList.add('scrolled-control');
                }
            } else {
                if (targetEl) targetEl.classList.remove('scrolled-control');
                if (scrollToTop) {
                    scrollToTop.classList.remove('scrolled-control');
                }
            }

            // Scroll to Top visibility logic
            if (scrollToTop) {
                if (scrollPos > 300) {
                    scrollToTop.classList.add('show');
                } else {
                    scrollToTop.classList.remove('show');
                }
            }
        });

        const scrollToTopBtn = document.getElementById('scrollToTop');
        if (scrollToTopBtn) {
            scrollToTopBtn.addEventListener('click', function() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });
        }

        // WhatsApp Bot Bubble Hide Logic (7 seconds)
        const whatsappBotBubble = document.getElementById('whatsappBotBubble');
        if (whatsappBotBubble) {
            setTimeout(() => {
                whatsappBotBubble.style.opacity = '0';
                whatsappBotBubble.style.transform = 'translateX(20px) scale(0.8)';
                whatsappBotBubble.style.pointerEvents = 'none';
                setTimeout(() => whatsappBotBubble.remove(), 600);
            }, 7000);
        }
    </script>
    {% block javascripts %}{% endblock %}
    <script>
            // Global AJAX Cart Add logic for .pcard__buy-btn
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.pcard__buy-btn');
                if (!btn || btn.getAttribute('id') === 'pd-submit') return; 

                const item = btn.closest('.pcard');
                if (item && item.dataset.stock && parseInt(item.dataset.stock) <= 0) {
                    return;
                }
                
                e.preventDefault();
                const urlStr = btn.dataset.addCartUrl || btn.href;
                if (!urlStr) return;
                const url = new URL(urlStr, window.location.origin);
                url.searchParams.set('ajax', '1');
                
                const originalHtml = btn.innerHTML;
                const btnWidth = btn.offsetWidth;
                btn.style.minWidth = btnWidth + 'px';
                btn.classList.add('disabled');
                btn.style.pointerEvents = 'none';

                fetch(url.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (window.updateGlobalCartCount) {
                            window.updateGlobalCartCount(data.cartCount);
                        }
                        
                        const oldBg = btn.style.background;
                        btn.style.background = '#198754';
                        btn.innerHTML = '<span class="check-animated"><i class="bi bi-check-lg" style="font-size: 1.1rem;"></i></span>';
                        
                        setTimeout(() => {
                            btn.style.background = oldBg;
                            btn.innerHTML = originalHtml;
                            btn.classList.remove('disabled');
                            btn.style.pointerEvents = 'auto';
                            btn.style.minWidth = '';
                        }, 1000);
                    }
                })
                .catch(err => {
                    console.error(err);
                    btn.classList.remove('disabled');
                    btn.style.pointerEvents = 'auto';
                });
            });

            // Quick View Modal AJAX Add to Cart is handled in _quick_view_modal.html.twig

            // Cookie Banner Logic
            const banner = document.getElementById('cookieBanner');
            const acceptBtn = document.getElementById('acceptCookies');

            function getCookie(name) {
                let nameEQ = name + "=";
                let ca = document.cookie.split(';');
                for(let i=0; i < ca.length; i++) {
                    let c = ca[i];
                    while (c.charAt(0)==' ') c = c.substring(1, c.length);
                    if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
                }
                return null;
            }

            function setCookie(name, value, days) {
                let expires = "";
                if (days) {
                    let date = new Date();
                    date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                    expires = "; expires=" + date.toUTCString();
                }
                document.cookie = name + "=" + (value || "") + expires + "; path=/; SameSite=Lax";
            }

            if (banner && acceptBtn) {
                if (!getCookie('cookie_consent')) {
                    banner.style.display = 'flex';
                }

                acceptBtn.addEventListener('click', function() {
                    setCookie('cookie_consent', 'true', 365);
                    banner.style.opacity = '0';
                    setTimeout(() => {
                        banner.style.display = 'none';
                    }, 300);
                });
            }
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            function adjustBodyPadding() {
                const header = document.querySelector('.header-wrapper');
                if (header) {
                    document.body.style.paddingTop = header.offsetHeight + 'px';
                }
            }
            adjustBodyPadding();
            window.addEventListener('resize', adjustBodyPadding);
            setTimeout(adjustBodyPadding, 500);

            // Theme Toggle Logic
            const toggleBtn = document.getElementById('themeToggleBtn');
            const icon = document.getElementById('themeIcon');
            const body = document.body;

            if (toggleBtn && icon) {
                // Initialize icon state
                if (body.classList.contains('dark-mode')) {
                    icon.classList.replace('bi-moon-fill', 'bi-sun-fill');
                }
                
                toggleBtn.addEventListener('click', () => {
                    body.classList.toggle('dark-mode');
                    if (body.classList.contains('dark-mode')) {
                        localStorage.setItem('theme', 'dark');
                        icon.classList.replace('bi-moon-fill', 'bi-sun-fill');
                    } else {
                        localStorage.setItem('theme', 'light');
                        icon.classList.replace('bi-sun-fill', 'bi-moon-fill');
                    }
                });

                // Scroll behavior: Fade out theme toggle when scrolling
                window.addEventListener('scroll', () => {
                    if (window.scrollY > 80) {
                        toggleBtn.style.opacity = '0.5';
                    } else {
                        toggleBtn.style.opacity = '1';
                    }
                });
            }
        });

        // Session Expiration Heartbeat
        {% if app.user %}
            const checkSession = () => {
                fetch('{{ path('api_session_check') }}', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json())
                .then(data => {
                    if (!data.authenticated) {
                        const overlay = document.getElementById('sessionExpiredOverlay');
                        if (overlay) {
                            overlay.style.display = 'flex';
                            setTimeout(() => overlay.style.opacity = '1', 50);
                            document.body.style.overflow = 'hidden';
                        }
                    }
                })
                .catch(err => { console.log('Session check error:', err); });
            };
            setInterval(checkSession, 120000); 
            document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'visible') checkSession(); });
        {% endif %}

        // File Size Validation (Pre-upload 413 prevention)
        document.addEventListener('change', function(e) {
            const fileInput = e.target.closest('input[type="file"]');
            if (!fileInput || !fileInput.files || fileInput.files.length === 0) return;
            
            const MAX_SIZE_MB = 5; // 5MB limit
            const MAX_SIZE_BYTES = MAX_SIZE_MB * 1024 * 1024;
            
            for (let i = 0; i < fileInput.files.length; i++) {
                const file = fileInput.files[i];
                if (file.size > MAX_SIZE_BYTES) {
                    const fileSizeMB = (file.size / (1024 * 1024)).toFixed(2);
                    
                    // Clear input
                    fileInput.value = '';
                    
                    // Alert
                    const alertMsg = `¡Archivo muy pesado!\n\n"${file.name}" (${fileSizeMB}MB) excede el máximo permitido de ${MAX_SIZE_MB}MB.\n\nPor favor, reduce el peso de la imagen antes de subirla o usa una diferente.`;
                    
                    if (window.Swal) {
                        Swal.fire({
                            icon: 'warning',
                            title: '¡Peso Excedido!',
                            text: alertMsg,
                            confirmButtonColor: 'var(--tertiary-color, #000)',
                            confirmButtonText: 'Entendido'
                        });
                    } else {
                        alert(alertMsg);
                    }
                    return;
                }
            }
        });
    </script>
