<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="Una tienda genial, con muchos artículos genios y hermosos y todo...">
    <meta name="author" content="Mark Otto, Jacob Thornton, and Bootstrap contributors">
    <meta name="generator" content="Jekyll v4.1.1">
    <title>{% block title %}{{ personalize.companyName ?? 'Empresa' }}{% endblock %}</title>

    <link href="{{asset('assets/css/bootstrap.min.css')}}" rel="stylesheet">
    <link href="{{asset('assets/css/carousel.css')}}" rel="stylesheet">
    <link href="{{asset('assets/css/style.css')}}" rel="stylesheet">
    <link href="{{asset('assets/css/modern-theme.css')}}" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    
    {% if personalize and personalize.logo %}
        <link rel="icon" type="image/x-icon" href="{{ asset('uploads/logo/' ~ personalize.logo) }}">
    {% endif %}
    
    <style>
        :root {
            --bg-body: #f8f9fa;
            {% if personalize %}
                /* Variables base */
                {% if personalize.primarycolor %}--primary-color: {{ personalize.primarycolor }};{% endif %}
                {% if personalize.secondarycolor %}--secondary-color: {{ personalize.secondarycolor }};{% endif %}
                {% if personalize.tertiaryColor %}--tertiary-color: {{ personalize.tertiaryColor }};{% endif %}
            {% endif %}
        }
        
        body {
            background-color: var(--bg-body) !important;
        }

        {% if personalize %}
            /* Navbar & Footer refinements */
            .navbar {
                background-color: {{ headerIsLight ? 'rgba(255, 255, 255, 0.9)' : 'var(--primary-color)' }} !important;
                backdrop-filter: blur(10px);
                -webkit-backdrop-filter: blur(10px);
            }
            
            .footer-custom {
                background-color: var(--primary-color) !important;
                color: {{ headerIsLight ? '#333' : 'white' }} !important;
            }
            
            /* Dynamic text colors */
            .navbar-brand, .nav-link, .navbar .dropdown-toggle, .navbar .btn-cart-icon, .navbar .text-reset {
                color: {{ headerIsLight ? '#2d3436' : 'white' }} !important;
            }
            
            .nav-link:hover, .navbar .dropdown-toggle:hover {
                opacity: 0.8;
            }

            /* Secondary Color */
            .btn-modern, .btn-primary, .card-action-btn:hover {
                background-color: var(--secondary-color) !important;
                color: white !important;
                border-color: var(--secondary-color) !important;
            }
            
            .card-modern-price, .product-price, .text-primary {
                color: var(--secondary-color) !important;
            }

            /* Tertiary Color */
            .badge, .alert-info {
                background-color: var(--tertiary-color) !important;
                color: white !important;
                border: none;
            }
            
            .btn-modern-outline {
                border-color: var(--secondary-color) !important;
                color: var(--secondary-color) !important;
            }
            
            .btn-modern-outline:hover {
                background-color: var(--secondary-color) !important;
                color: white !important;
            }
        {% endif %}

        @media (max-width: 991px) {
            .main-content-wrap {
                margin-top: 1.5rem !important;
                padding-top: 2rem !important;
            }
        }
        
        body {
            overflow-x: hidden;
        }

        /* ── Global Bundle Pills (Responsive) ── */
        .bundle-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            vertical-align: middle;
            padding: 0.3rem 0.6rem;
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            border-radius: 99px;
            margin-left: 0.4rem;
            margin-top: 0.25rem;
            margin-bottom: 0.25rem;
            color: #fff;
            text-align: center;
            line-height: 1.2;
            animation: pillShake 5s infinite;
        }
        .bundle-pill--oferta_sorpresa { background-color: #198754; }
        .bundle-pill--ultimos_stock { background-color: #dc3545; }
        .bundle-pill--pocas_unidades { background-color: #ffc107; color: #000; }
        
        /* ── Top Right Badges (Envío, Recomendado, etc) ── */
        .top-badge-right {
            position: absolute;
            top: 0.8rem;
            right: 0.8rem;
            z-index: 10;
            padding: 0.35rem 0.6rem;
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            border-radius: 6px;
            color: #fff;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        .top-badge-right--envio_gratis { background-color: #198754; }
        .top-badge-right--recomendado { background-color: #ffb100; color: #111; }
        .top-badge-right--mas_vendido { background-color: #dc3545; }

        /* ── Diagonal line for unavailable options ── */
        .option-unavailable {
            position: relative;
            background-color: #f8f8f8 !important;
            color: #adb5bd !important;
            border-color: #e0e0e0 !important;
            text-decoration: none !important;
            opacity: 0.8;
            overflow: hidden;
        }
        .option-unavailable::after {
            content: "";
            position: absolute;
            top: 50%;
            left: -10%;
            width: 120%;
            height: 1.5px;
            background-color: #b0b0b0;
            transform: rotate(-15deg);
            pointer-events: none;
        }

        @keyframes pillShake {
            0%, 85% { transform: rotate(0deg); }
            88% { transform: rotate(-5deg) scale(1.05); }
            91% { transform: rotate(5deg) scale(1.05); }
            94% { transform: rotate(-5deg) scale(1.05); }
            97% { transform: rotate(5deg) scale(1.05); }
            100% { transform: rotate(0deg); }
        }

        /* ── Check Animation (Energetic 1s) ── */
        @keyframes checkPop {
            0% { transform: scale(0); opacity: 0; }
            40% { transform: scale(1.4); opacity: 1; }
            60% { transform: scale(0.9); }
            80% { transform: scale(1.1); }
            100% { transform: scale(1); opacity: 1; }
        }
        .check-animated {
            display: inline-flex;
            animation: checkPop 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }
        
        @media (max-width: 575px) {
            .bundle-pill {
                font-size: 0.55rem;
                padding: 0.2rem 0.4rem;
                margin-left: 0.2rem;
                white-space: normal;
                display: inline-block;
            }
        }
        /* ── Cookie Banner Styles ── */
        .cookie-banner {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #fff;
            padding: 1.5rem;
            box-shadow: 0 -5px 25px rgba(0,0,0,0.1);
            z-index: 10000;
            display: none;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
            border-top: 3px solid var(--primary-color);
        }
        .cookie-banner__text {
            font-size: 0.95rem;
            color: #444;
            flex: 1;
            margin: 0;
        }

        @media (max-width: 768px) {
            .cookie-banner {
                padding: 1rem;
                text-align: center;
                flex-direction: column;
                gap: 0.8rem;
            }
            .cookie-banner__text {
                font-size: 0.85rem;
            }
            .cookie-banner button {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <header>
        {% include "_nav.html.twig" %}
    </header>

    <main class="mb-5" role="main">
        {% if carousel is defined %}
            {% include "_carousel.html.twig" %}
        {% endif %}
        
        <div class="container main-content-wrap {% if carousel is not defined %}mt-5 pt-5{% else %}mt-5{% endif %}">
            {% for label, messages in app.flashes %}
                {% if label != 'success_contact' %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show rounded-pill px-4 shadow-sm border-0 mb-4" role="alert">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endif %}
            {% endfor %}
            {% block body %}{% endblock %}
        </div>
    </main>
        <footer class="footer-custom">
            {% include "_footer.html.twig" %}
        </footer>
    {% include "_quick_view_modal.html.twig" %}

    {# Floating Buttons #}
    {# Left Side: Scroll to Top (Only Home) #}
    {% if app.request.attributes.get('_route') == 'home' %}
        <button id="scrollToTop" class="btn rounded-circle shadow-lg d-none align-items-center justify-content-center" style="font-size: 1.5rem; position: fixed; bottom: 30px; left: 30px; z-index: 9999; width: 70px; height: 70px; transition: all 0.3s ease; opacity: 1; background-color: var(--primary-color, #000); color: white; border: 2px solid rgba(255,255,255,0.2);">
            <i class="bi bi-chevron-up"></i>
        </button>
    {% endif %}

    {# Right Side: WhatsApp Button #}
    {% if personalize.whatsapp %}
        <a href="https://wa.me/{{ personalize.whatsapp|replace({'+': '', ' ': '', '-': ''}) }}" target="_blank" id="whatsappBtn" class="btn btn-success rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="font-size: 1.5rem; position: fixed; bottom: 30px; right: 30px; z-index: 9999; width: 70px; height: 70px; transition: all 0.3s ease; opacity: 1; background-color: #25d366; border: none;">
            <i class="bi bi-whatsapp"></i>
        </a>
    {% endif %}

    <style>
        #whatsappBtn:hover, #scrollToTop:hover {
            opacity: 1 !important;
            transform: scale(1.1);
        }
        
        /* Class for scrolled state transparency */
        .scrolled-control {
            opacity: 0.4 !important;
        }

        #scrollToTop.show {
            display: flex !important;
            animation: fadeIn 0.3s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    <div id="cookieBanner" class="cookie-banner">
        <p class="cookie-banner__text">
            <i class="bi bi-info-circle-fill me-2" style="color: var(--primary-color);"></i>
            Utilizamos cookies propias y de terceros para mejorar tu experiencia de navegación y ofrecerte contenidos de interés. Al continuar navegando, aceptas nuestra política de cookies.
        </p>
        <button id="acceptCookies" class="btn btn-dark rounded-pill px-4 fw-bold">Entendido</button>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="{{asset('assets/js/bootstrap.bundle.js')}}"></script>
    <script>
        window.addEventListener('scroll', function() {
            const whatsappBtn = document.getElementById('whatsappBtn');
            const scrollToTop = document.getElementById('scrollToTop');
            const scrollPos = window.scrollY;

            // Transparency logic: if scrolled more than 100px, make them semi-transparent
            if (scrollPos > 100) {
                whatsappBtn.classList.add('scrolled-control');
                if (scrollToTop) {
                    scrollToTop.classList.add('scrolled-control');
                }
            } else {
                whatsappBtn.classList.remove('scrolled-control');
                if (scrollToTop) {
                    scrollToTop.classList.remove('scrolled-control');
                }
            }

            // Scroll to Top visibility logic
            if (scrollToTop) {
                if (scrollPos > 300) {
                    scrollToTop.classList.add('show');
                } else {
                    scrollToTop.classList.remove('show');
                }
            }
        });

        const scrollToTopBtn = document.getElementById('scrollToTop');
        if (scrollToTopBtn) {
            scrollToTopBtn.addEventListener('click', function() {
                window.scrollTo({
                    top: 0,
                    behavior: 'smooth'
                });
            });
        }
    </script>
    {% block javascripts %}{% endblock %}
    <script>
            // Global AJAX Cart Add logic for .pcard__buy-btn
            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.pcard__buy-btn');
                if (!btn || btn.getAttribute('id') === 'pd-submit') return; // pd-submit has its own logic
                
                e.preventDefault();
                const url = new URL(btn.href);
                url.searchParams.set('ajax', '1');
                
                const originalHtml = btn.innerHTML;
                btn.classList.add('disabled');
                btn.style.pointerEvents = 'none';

                fetch(url.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Update cart badges
                        const badges = document.querySelectorAll('.cart-badge');
                        if (badges.length > 0) {
                            badges.forEach(b => b.textContent = data.cartCount);
                        }
                        
                        // Check animation
                        const oldBg = btn.style.background;
                        btn.style.background = '#198754';
                        btn.innerHTML = '<span class="check-animated"><i class="bi bi-check-lg" style="font-size: 1.25rem;"></i></span>';
                        
                        setTimeout(() => {
                            btn.style.background = oldBg;
                            btn.innerHTML = originalHtml;
                            btn.classList.remove('disabled');
                            btn.style.pointerEvents = 'auto';
                        }, 1000);
                    }
                })
                .catch(err => {
                    console.error(err);
                    btn.classList.remove('disabled');
                    btn.style.pointerEvents = 'auto';
                });
            });

            // Quick View Modal AJAX Add to Cart
            document.addEventListener('DOMContentLoaded', function() {
                const quickViewModal = document.getElementById('quickViewModal');
                if (quickViewModal) {
                    quickViewModal.addEventListener('submit', function(e) {
                        const qvForm = e.target.closest('#quickViewModal form');
                        if (!qvForm) return;

                        e.preventDefault();
                        const qvSubmit = qvForm.querySelector('#pd-submit');
                        const originalHtml = qvSubmit.innerHTML;
                        const bsModal = bootstrap.Modal.getInstance(quickViewModal);

                        qvSubmit.disabled = true;
                        qvSubmit.style.pointerEvents = 'none';

                        const formData = new FormData(qvForm);
                        formData.append('ajax', '1');

                        fetch(qvForm.action, {
                            method: 'POST',
                            body: formData,
                            headers: { 'X-Requested-With': 'XMLHttpRequest' }
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                const badges = document.querySelectorAll('.cart-badge');
                                if (badges.length > 0) {
                                    badges.forEach(b => b.textContent = data.cartCount);
                                }

                                qvSubmit.innerHTML = '<span class="check-animated"><i class="bi bi-check-lg" style="font-size: 1.5rem;"></i></span>';
                                qvSubmit.style.background = '#198754';
                                
                                setTimeout(() => {
                                    if (bsModal) {
                                        bsModal.hide();
                                    } else if (window.jQuery) {
                                        $('#quickViewModal').modal('hide');
                                    }
                                    // reset state
                                    setTimeout(() => {
                                        qvSubmit.style.background = '';
                                        qvSubmit.innerHTML = originalHtml;
                                        qvSubmit.disabled = false;
                                        qvSubmit.style.pointerEvents = 'auto';
                                    }, 300);
                                }, 1000);
                            } else {
                                // Handle error or display message
                                console.error('Error adding to cart from quick view:', data.error);
                                qvSubmit.disabled = false;
                                qvSubmit.style.pointerEvents = 'auto';
                                qvSubmit.innerHTML = originalHtml;
                            }
                        })
                        .catch(error => {
                            console.error('Fetch error:', error);
                            qvSubmit.disabled = false;
                            qvSubmit.style.pointerEvents = 'auto';
                            qvSubmit.innerHTML = originalHtml;
                        });
                    });
                }
            });

            // Cookie Banner Logic
            const banner = document.getElementById('cookieBanner');
            const acceptBtn = document.getElementById('acceptCookies');

            function getCookie(name) {
                let nameEQ = name + "=";
                let ca = document.cookie.split(';');
                for(let i=0; i < ca.length; i++) {
                    let c = ca[i];
                    while (c.charAt(0)==' ') c = c.substring(1, c.length);
                    if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length, c.length);
                }
                return null;
            }

            function setCookie(name, value, days) {
                let expires = "";
                if (days) {
                    let date = new Date();
                    date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                    expires = "; expires=" + date.toUTCString();
                }
                document.cookie = name + "=" + (value || "") + expires + "; path=/; SameSite=Lax";
            }

            if (banner && acceptBtn) {
                if (!getCookie('cookie_consent')) {
                    banner.style.display = 'flex';
                }

                acceptBtn.addEventListener('click', function() {
                    setCookie('cookie_consent', 'true', 365);
                    banner.style.opacity = '0';
                    setTimeout(() => {
                        banner.style.display = 'none';
                    }, 300);
                });
            }
        });
    </script>
</body>
</html>