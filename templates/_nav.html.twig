body.dark-mode .drawer-avatar { background-color: #2a2a2a !important; color: #fff !important; }

/* ══════════════════════════════
   MOBILE  ≤ 991px
══════════════════════════════ */
@media (max-width: 991px) {
    .navbar-inner {
        padding: .5rem 1rem;
        gap: .5rem;
        display: flex;
        align-items: center;
    }

    .hamburger-btn { display: flex; order: 1; }

    /* Logo solo a la derecha */
    .navbar-brand-custom {
        margin-left: auto;
        order: 10;
    }
    .navbar-logo { height: 60px; }

    /* Centro: icono búsqueda pegado a hamburguesa */
    .navbar-center {
        order: 3;
        flex: 0 0 auto;
        gap: 0;
    }

    /* Carrito junto al grupo izquierdo */
    .navbar-right {
        order: 2;
        gap: 0;
    }

    /* Ocultar elementos desktop en mobile */
    .search-wrapper,
    .user-name,
    .arrow-icon,
    .btn-login-label,
    .categories-label,
    .categories-arrow,
    .desktop-categories,
    .desktop-user,
    .desktop-login { 
        display: none !important; 
    }

    /* Iconos modo móvil */
    .cart-btn {
        width: 44px !important;
        height: 44px !important;
        border-radius: 12px !important;
        padding: 0 !important;
        background: transparent !important;
        border: none !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        color: var(--tertiary-color) !important;
    }
    .search-toggle-btn {
        width: 44px !important;
        height: 44px !important;
        border-radius: 12px !important;
        padding: 0 !important;
        background: transparent !important;
        border: none !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        color: #fff !important;
    }
    .cart-btn:active, .search-toggle-btn:active {
        background: rgba(255,255,255,.12) !important;
    }

    /* Search overlay en mobile */
    .search-overlay {
        position: absolute !important;
        left: 0 !important;
        right: 0 !important;
        width: 100% !important;
        top: 100% !important;
        border-radius: 0 0 16px 16px !important;
        padding: 0.75rem 1rem !important;
        border-top: none !important;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Search overlay ── */
    const searchToggle = document.getElementById('searchToggle');
    const searchClose = document.getElementById('searchClose');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('searchOverlayInput');

    if (searchToggle && searchOverlay) {
        searchToggle.addEventListener('click', function () {
            searchOverlay.classList.add('active');
            setTimeout(() => { if (searchInput) searchInput.focus(); }, 100);
        });
    }
    if (searchClose && searchOverlay) {
        searchClose.addEventListener('click', function () {
            searchOverlay.classList.remove('active');
        });
    }
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && searchOverlay && searchOverlay.classList.contains('active')) {
            searchOverlay.classList.remove('active');
        }
    });

    /* ── Mobile Drawer ── */
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const drawerOverlay = document.getElementById('drawerOverlay');
    const mobileDrawer = document.getElementById('mobileDrawer');
    const drawerClose = document.getElementById('drawerClose'); // This is the old close button

    function openDrawer() {
        mobileDrawer.classList.add('active');
        drawerOverlay.classList.add('active');
        hamburgerBtn.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    window.closeDrawer = function() { // New closeDrawer function
        mobileDrawer.classList.remove('active');
        drawerOverlay.classList.remove('active');
        if (hamburgerBtn) hamburgerBtn.classList.remove('open'); // Ensure hamburger state is reset
        document.body.style.overflow = '';
    };

    if (hamburgerBtn) {
        hamburgerBtn.addEventListener('click', function() {
            if (mobileDrawer.classList.contains('active')) {
                window.closeDrawer();
            } else {
                openDrawer();
            }
        });
    }
    if (drawerOverlay) drawerOverlay.addEventListener('click', window.closeDrawer);

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && mobileDrawer && mobileDrawer.classList.contains('active')) {
            window.closeDrawer(); // Updated to new closeDrawer
        }
    });

    // New listener for the modern close button
    const drawerCloseModern = document.getElementById('drawerCloseModern');
    if (drawerCloseModern) drawerCloseModern.addEventListener('click', window.closeDrawer);


    /* ── Hover highlight (desktop) ── */
    const items = ['.nav-user-btn', '.cart-btn', '.btn-login', '.search-toggle-btn', '.categories-btn'];
    items.forEach(sel => {
        document.querySelectorAll(sel).forEach(el => {
            el.addEventListener('mousedown', () => el.style.backgroundColor = 'rgba(255,255,255,0.12)');
            el.addEventListener('mouseup', () => el.style.backgroundColor = '');
            el.addEventListener('mouseleave', () => el.style.backgroundColor = '');
        });
    });

    /* ── Live Search AJAX logic ── */
    function setupHeaderLiveSearch(inputId, dropdownId, resultsId, loadingId, emptyId) {
        const input = document.getElementById(inputId);
        const dropdown = document.getElementById(dropdownId);
        const resultsContainer = document.getElementById(resultsId);
        const loading = document.getElementById(loadingId);
        const empty = document.getElementById(emptyId);
        
        if (!input || !dropdown) return;
        
        let timeout = null;
        let controller = null;
        
        // Hide dropdown when clicking outward
        document.addEventListener('click', (e) => {
            if (!input.contains(e.target) && !dropdown.contains(e.target)) {
                dropdown.style.display = 'none';
            }
        });
        
        // Re-show if has query
        input.addEventListener('focus', () => {
            if (input.value.trim().length > 1) {
                dropdown.style.display = 'block';
            }
        });

        input.addEventListener('input', () => {
            const query = input.value.trim();
            
            if (query.length < 2) {
                dropdown.style.display = 'none';
                if (controller) controller.abort();
                return;
            }
            
            dropdown.style.display = 'block';
            resultsContainer.innerHTML = '';
            empty.classList.add('d-none');
            loading.classList.remove('d-none');
            
            clearTimeout(timeout);
            
            timeout = setTimeout(() => {
                if (controller) controller.abort();
                controller = new AbortController();
                
                fetch(`/search-ajax?q=${encodeURIComponent(query)}`, { signal: controller.signal })
                    .then(res => res.json())
                    .then(data => {
                        loading.classList.add('d-none');
                        if (data.length === 0) {
                            empty.classList.remove('d-none');
                        } else {
                            empty.classList.add('d-none');
                            let html = '';
                            data.forEach(p => {
                                const imgHtml = p.image 
                                    ? `<img src="${p.image}" alt="${p.name}" style="width: 44px; height: 44px; object-fit: cover; border-radius: 8px; margin-right: 12px; flex-shrink: 0;">` 
                                    : `<div style="width: 44px; height: 44px; background: #f8fafc; border-radius: 8px; margin-right: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"><i class="bi bi-bag text-muted"></i></div>`;
                                
                                const priceFormat = p.oldPrice 
                                    ? `<span class="text-danger fw-bold" style="font-size: 0.85rem;">$${p.price}</span> <span class="text-decoration-line-through text-muted ms-1" style="font-size: 0.75rem;">$${p.oldPrice}</span>` 
                                    : `<span class="fw-bold" style="font-size: 0.85rem; color: var(--tertiary-color, #1e293b);">$${p.price}</span>`;
                                    
                                html += `
                                    <a href="/products/${p.slug}" class="list-group-item list-group-item-action d-flex align-items-center py-2 px-3 border-0 border-bottom" style="transition: background 0.2s;">
                                        ${imgHtml}
                                        <div class="flex-grow-1 overflow-hidden d-flex flex-column justify-content-center">
                                            <div class="text-truncate fw-semibold mb-1" style="font-size: 0.85rem; line-height: 1.2; color: #334155;">${p.name}</div>
                                            <div>${priceFormat}</div>
                                        </div>
                                    </a>
                                `;
                            });
                            resultsContainer.innerHTML = html;
                        }
                    })
                    .catch(err => {
                        if (err.name === 'AbortError') return;
                        loading.classList.add('d-none');
                    });
            }, 300);
        });
    }

    // Init for Desktop Setup
    setupHeaderLiveSearch('desktopSearchInput', 'desktopSearchDropdown', 'desktopSearchResults', 'desktopSearchLoading', 'desktopSearchEmpty');
    
    // Init for Mobile Overlay
    setupHeaderLiveSearch('searchOverlayInput', 'mobileSearchDropdown', 'mobileSearchResults', 'mobileSearchLoading', 'mobileSearchEmpty');

    /* ── Modern Drawer Helpers ── */
    window.toggleDrawerSubModern = function(id, trigger) {
        const sub = document.getElementById(id);
        if (!sub) return;
        
        const isOpen = sub.classList.contains('show');
        
        if (isOpen) {
            sub.classList.remove('show');
            trigger.classList.remove('open');
            const icon = trigger.querySelector('.bi-dash-lg');
            if (icon) {
                icon.classList.remove('bi-dash-lg');
                icon.classList.add('bi-plus-lg');
            }
        } else {
            sub.classList.add('show');
            trigger.classList.add('open');
            const icon = trigger.querySelector('.bi-plus-lg');
            if (icon) {
                icon.classList.remove('bi-plus-lg');
                icon.classList.add('bi-dash-lg');
            }
        }
    };

});

window.showCartNotification = function() {
    const toast = document.getElementById('cartNotification');
    if (!toast) return;
    
    toast.classList.add('show');
    setTimeout(() => {
        toast.classList.remove('show');
    }, 2500);
};
</script>