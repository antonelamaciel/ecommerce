══════════════════════════════ */
@media (max-width: 991px) {
    .navbar-inner {
        padding: .5rem 1rem;
        gap: .5rem;
        display: flex;
        align-items: center;
    }

    .hamburger-btn { display: flex; order: 1; }

    /* Logo solo a la derecha */
