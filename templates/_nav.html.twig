<nav class="navbar-custom fixed-top">
    <div class="navbar-inner">

        <!-- IZQUIERDA: HAMBURGUESA (mobile) -->
        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menú" type="button">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>

        <!-- LOGO -->
        <a class="navbar-brand-custom" href="{{ path('home') }}">
            {% if personalize and personalize.logo %}
                <img src="{{ asset('uploads/logo/' ~ personalize.logo) }}" alt="Logo" class="navbar-logo">
            {% else %}
                <span class="brand-text">{{ personalize.companyName ?? 'Empresa' }}</span>
            {% endif %}
        </a>

        <!-- CENTRO: BUSCADOR + CATEGORÍAS -->
        <div class="navbar-center">
            <form action="{{ path('product') }}" method="GET" class="search-wrapper">
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="search" name="string" placeholder="Buscar…" autocomplete="off">
                </div>
            </form>
            <button class="search-toggle-btn" id="searchToggle" aria-label="Buscar" type="button">
                <i class="bi bi-search"></i>
            </button>

            <div class="search-overlay" id="searchOverlay">
                <form action="{{ path('product') }}" method="GET" class="search-overlay-form">
                    <i class="bi bi-search search-overlay-icon"></i>
                    <input type="search" name="string" id="searchOverlayInput"
                        placeholder="Buscar…" autocomplete="off">
                    <button type="button" class="search-close-btn" id="searchClose">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </form>
            </div>

            <div class="dropdown desktop-categories">
                <button class="nav-pill-btn categories-btn" type="button"
                        id="dropdownMenuCategories"
                        data-toggle="dropdown"
                        data-display="static"
                        aria-haspopup="true"
                        aria-expanded="false">
                    <i class="bi bi-tags categories-icon-mobile"></i>
                    <span class="categories-label">Productos</span>
                    <i class="bi bi-chevron-down arrow-icon categories-arrow"></i>
                </button>
                <div class="dropdown-menu nav-dropdown shadow-xl dropdown-animated"
                     aria-labelledby="dropdownMenuCategories">
                    <a class="nav-dropdown-item fw-semibold" href="{{ path('product') }}">
                        <b>Categorías de productos</b>
                    </a>
                    <div class="dropdown-divider"></div>
                    {% for category in allCategories %}
                        {% if category.subcategories|length > 0 %}
                            <div class="nav-category-group">
                                <a class="nav-dropdown-item d-flex align-items-center justify-content-between" href="#" data-bs-toggle="collapse" data-bs-target="#collapseDesktopCat{{ category.id }}" aria-expanded="false" onclick="event.preventDefault(); event.stopPropagation(); $('#collapseDesktopCat{{ category.id }}').collapse('toggle'); let exp = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !exp);">
                                    <span><i class="bi bi-tag opacity-50 me-2"></i>{{ category.name }}</span>
                                    <i class="bi bi-chevron-down opacity-50 ms-2" style="font-size: 0.75rem; transition: transform 0.2s;"></i>
                                </a>
                                <div class="collapse" id="collapseDesktopCat{{ category.id }}">
                                    <div class="ps-4 pe-2 py-1 mb-1 border-start ms-3 mt-1" style="border-color: #eee !important;">
                                        <a class="nav-dropdown-item py-1 text-primary fw-semibold" href="{{ path('product', {'categories[]': category.id}) }}" style="font-size: 0.8rem;">
                                            Ver todo en {{ category.name }}
                                        </a>
                                        {% for sub in category.subcategories %}
                                            <a class="nav-dropdown-item py-1 text-muted" href="{{ path('product', {'categories[]': category.id, 'subcategories[]': sub.id}) }}" style="font-size: 0.8rem;">
                                                {{ sub.name }}
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <a class="nav-dropdown-item" href="{{ path('product', {'categories[]': category.id}) }}">
                                <i class="bi bi-tag opacity-50 me-2"></i>{{ category.name }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- DERECHA: USUARIO + CARRITO -->
        <div class="navbar-right">
            {% if app.user %}
                <div class="dropdown desktop-user">
                    <a class="nav-user-btn" href="#" role="button"
                       data-toggle="dropdown" data-display="static" aria-haspopup="true" aria-expanded="false">
                        <div class="user-avatar"><i class="bi bi-person"></i></div>
                        <span class="user-name">{{ app.user.firstname }}</span>
                        <i class="bi bi-chevron-down arrow-icon"></i>
                    </a>
                    <ul class="dropdown-menu nav-dropdown shadow-xl dropdown-animated dropdown-menu-right">
                        <li class="dropdown-user-header">
                            <div class="user-avatar user-avatar-lg"><i class="bi bi-person"></i></div>
                            <div>
                                <div class="fw-semibold">{{ app.user.firstname }}</div>
                                <small class="text-muted">Mi cuenta</small>
                            </div>
                        </li>
                        <li><div class="dropdown-divider"></div></li>
                        <li><a class="nav-dropdown-item" href="{{ path('account') }}"><i class="bi bi-person me-2"></i>Mi Perfil</a></li>
                        <li><a class="nav-dropdown-item" href="{{ path('account_orders') }}"><i class="bi bi-bag-check me-2"></i>Mis Pedidos</a></li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><div class="dropdown-divider"></div></li>
                            <li><a class="nav-dropdown-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Administración</a></li>
                        {% endif %}
                        <li><div class="dropdown-divider"></div></li>
                        <li><a class="nav-dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</a></li>
                    </ul>
                </div>
            {% else %}
                <a class="btn-login desktop-login" href="{{ path('app_login') }}">
                    <i class="bi bi-person me-1"></i><span class="btn-login-label">Ingresar</span>
                </a>
            {% endif %}

            <a href="{{ path('cart') }}" class="cart-btn" aria-label="Ver carrito">
                <i class="bi bi-bag fs-5"></i>
                {% if cartCount > 0 %}
                    <span class="cart-badge">{{ cartCount }}</span>
                {% endif %}
            </a>
        </div>

    </div>
</nav>

<!-- MOBILE DRAWER -->
<div class="mobile-drawer-overlay" id="drawerOverlay"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header">
        <span class="drawer-title">Menú</span>
        <button class="drawer-close-btn" id="drawerClose" aria-label="Cerrar menú">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="drawer-body">

        <!-- SECCIÓN CATEGORÍAS (primero en mobile) -->
        <div class="drawer-section">
            <div class="drawer-section-title">
                <i class="bi bi-tags me-2"></i>Categorías
            </div>
            <div class="drawer-section-content">
                <a class="drawer-item fw-semibold" href="{{ path('product') }}">
                    <i class="bi bi-grid me-2"></i><b>Todas las categorías</b>
                </a>
                <div class="drawer-divider"></div>
                {% for category in allCategories %}
                    {% if category.subcategories|length > 0 %}
                        <div class="nav-drawer-category-group">
                            <a class="drawer-item d-flex align-items-center justify-content-between drawer-cat-toggle" href="#" data-target="collapseMobileCat{{ category.id }}" onclick="event.preventDefault(); toggleDrawerSub(this);">
                                <span><i class="bi bi-tag opacity-50 me-2"></i>{{ category.name }}</span>
                                <i class="bi bi-chevron-down drawer-cat-arrow opacity-50 ms-2" style="font-size: 0.85rem; transition: transform 0.25s;"></i>
                            </a>
                            <div class="drawer-subcats" id="collapseMobileCat{{ category.id }}" style="max-height: 0; overflow: hidden; transition: max-height 0.35s ease;">
                                <div class="ps-4 pe-2 py-1 mb-2 border-start ms-3 mt-1" style="border-color: rgba(255,255,255,0.18) !important;">
                                    <a class="drawer-item py-1 fw-bold text-primary fw-semibold" href="{{ path('product', {'categories[]': category.id}) }}" style="font-size: 0.85rem; color: #fff;">
                                        Ver todo en {{ category.name }}
                                    </a>
                                    {% for sub in category.subcategories %}
                                        <a class="drawer-item py-1" href="{{ path('product', {'categories[]': category.id, 'subcategories[]': sub.id}) }}" style="font-size: 0.85rem; opacity: 0.8;">
                                            {{ sub.name }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <a class="drawer-item" href="{{ path('product', {'categories[]': category.id}) }}">
                            <i class="bi bi-tag opacity-50 me-2"></i>{{ category.name }}
                        </a>
                    {% endif %}
                {% endfor %}
            </div>
        </div>

        <!-- SECCIÓN USUARIO (segundo en mobile) -->
        <div class="drawer-section">
            <div class="drawer-section-title">
                <i class="bi bi-person-circle me-2"></i>
                {% if app.user %}{{ app.user.firstname }}{% else %}Mi Cuenta{% endif %}
            </div>
            <div class="drawer-section-content">
                {% if app.user %}
                    <a class="drawer-item" href="{{ path('account') }}"><i class="bi bi-person me-2"></i>Mi Perfil</a>
                    <a class="drawer-item" href="{{ path('account_orders') }}"><i class="bi bi-bag-check me-2"></i>Mis Pedidos</a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="drawer-divider"></div>
                        <a class="drawer-item" href="/admin"><i class="bi bi-speedometer2 me-2"></i>Administración</a>
                    {% endif %}
                    <div class="drawer-divider"></div>
                    <a class="drawer-item drawer-item-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión</a>
                {% else %}
                    <a class="drawer-item" href="{{ path('app_login') }}"><i class="bi bi-box-arrow-in-right me-2"></i>Ingresar</a>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<style>
/* ── Base ── */
.navbar-custom {
    background: var(--primary-color);
    border-bottom: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 4px 24px rgba(0,0,0,.15);
    z-index: 1030;
}
.navbar-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: .65rem 2rem;
}

/* Desktop: logo a la izquierda, items a la derecha */
@media (min-width: 992px) {
    .navbar-center {
        margin-left: auto;
    }
}

/* ── Hamburguesa (oculto en desktop) ── */
.hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px; height: 44px;
    background: transparent;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background .2s;
}
.hamburger-btn:hover { background: rgba(255,255,255,.15); }
.hamburger-btn:active { background: rgba(255,255,255,.12); }
.hamburger-line {
    display: block;
    width: 22px; height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform .25s, opacity .2s;
}
.hamburger-btn.open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger-btn.open .hamburger-line:nth-child(2) { opacity: 0; }
.hamburger-btn.open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Logo ── */
.navbar-brand-custom {
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity .2s, transform .2s;
}
.navbar-brand-custom:hover { opacity: .8; transform: scale(1.02); }
.navbar-logo {
    width: 68px; height: 68px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255,255,255,.2);
    display: block;
}
.brand-text { font-size: 1.5rem; font-weight: 800; color: #fff; }

/* ── Centro ── */
.navbar-center {
    display: flex;
    align-items: center;
    gap: .75rem;
}
.search-wrapper { width: 260px; }
.search-box { position: relative; display: flex; align-items: center; }
.search-icon {
    position: absolute; left: 11px;
    color: rgba(255,255,255,.65); font-size: .78rem;
    pointer-events: none;
}
.search-box input {
    width: 100%;
    /* Misma altura que .nav-pill-btn: padding .5rem + line-height 1.25 + font .875rem = ~34px */
    padding: .63rem .85rem .63rem 2.1rem;
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 999px;
    color: #fff; font-size: .875rem; line-height: 1.25;
    outline: none;
    transition: background .2s, border-color .2s;
}
.search-box input::placeholder { color: rgba(255,255,255,.5); }
.search-box input:focus {
    background: rgba(255,255,255,.22);
    border-color: rgba(255,255,255,.28);
}

/* ── Botón Categorías (desktop) ── */
.nav-pill-btn {
    display: flex; align-items: center; gap: .4rem;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.12);
    color: #fff;
    border-radius: 999px;
    padding: .5rem 1.15rem;
    font-size: .875rem; font-weight: 600;
    white-space: nowrap; cursor: pointer;
    transition: background .2s;
}
.nav-pill-btn:hover, .dropdown.show .nav-pill-btn {
    background: rgba(255,255,255,.25);
}

/* ── Derecha (usuario + carrito) ── */
.navbar-right {
    display: flex; align-items: center;
    gap: .6rem;
}

/* Usuario */
.nav-user-btn {
    display: flex; align-items: center; gap: .5rem;
    text-decoration: none; color: #fff;
    border-radius: 999px;
    padding: .5rem 0.5rem;
    border: 1px solid transparent;
    font-size: .9rem; font-weight: 600;
    transition: background .2s;
}
.nav-user-btn:hover, .dropdown.show .nav-user-btn {
    background: rgba(255,255,255,.15);
    border-color: rgba(255,255,255,.12);
}
.user-avatar {
    width: 20px; height: 20px; border-radius: 50%;
    font-size: 1.2rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: #fff;
}
.user-avatar-lg { width: 44px; height: 44px; font-size: 1.2rem; }
.dropdown-user-header {
    display: flex; align-items: center; gap: .85rem;
    padding: 1rem 1.25rem; list-style: none;
}

/* Login */
.btn-login {
    display: flex; align-items: center;
    text-decoration: none; color: #fff;
    border: 1px solid rgba(255,255,255,.3);
    border-radius: 999px;
    padding: .45rem 1.1rem;
    font-size: .875rem; font-weight: 600;
    white-space: nowrap;
    transition: background .2s, color .2s;
}
.btn-login:hover { background: #fff; color: var(--primary-color); }

/* Carrito */
.cart-btn {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    color: #fff; text-decoration: none;
    border: 1px solid transparent;
    transition: background .2s;
}
.cart-btn:hover { background: rgba(255,255,255,.15); color: #fff; }
.cart-badge {
    position: absolute; top: 1px; right: 1px;
    background: #fff; color: var(--primary-color);
    font-size: .63rem; font-weight: 900;
    min-width: 17px; height: 17px;
    border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    padding: 0 3px;
    border: 1.5px solid var(--primary-color);
}

/* ── Dropdown ── */
.navbar-center .dropdown,
.navbar-right .dropdown {
    position: relative;
}

.nav-dropdown {
    border: 1px solid rgba(0,0,0,.06) !important;
    border-radius: 14px !important;
    padding: .5rem !important;
    min-width: 220px;
    margin-top: 0 !important;
    z-index: 1050;
    overflow: hidden;
    position: absolute !important;
    top: 100% !important;
    left: 0 !important;
    right: auto !important;
}

/* Dropdown usuario: alineado a la derecha del botón */
.dropdown-menu-right.nav-dropdown {
    left: auto !important;
    right: 0 !important;
}

.nav-user-btn, .cart-btn, .btn-login, .categories-btn, .search-toggle-btn {
    outline: none !important;
    box-shadow: none !important;
    transition: background-color 0.2s ease;
}
.nav-user-btn:active, .cart-btn:active, .btn-login:active,
.categories-btn:active, .search-toggle-btn:active {
    background-color: rgba(255, 255, 255, 0.15) !important;
}
*:focus { outline: none !important; }

.nav-dropdown-item {
    display: flex; align-items: center;
    border-radius: 9px;
    padding: .6rem 1rem;
    font-size: .875rem; color: #374151;
    text-decoration: none;
    transition: background .15s, color .15s, transform .15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
}
.nav-dropdown-item span,
.nav-dropdown-item b {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.nav-dropdown-item:hover { background: #f3f4f6; color: #111; transform: translateX(3px); }
.nav-dropdown-item.text-danger:hover { background: #fef2f2; color: #ef4444; }
.shadow-xl { box-shadow: 0 16px 48px rgba(0,0,0,.14) !important; }
.arrow-icon { font-size: .75rem; opacity: .7; transition: transform .25s; }
.dropdown.show .arrow-icon { transform: rotate(180deg); opacity: 1; }
[aria-expanded="true"] .bi-chevron-down { transform: rotate(180deg); opacity: 1; }

@media (min-width: 992px) {
    .dropdown-animated {
        display: block !important;
        visibility: hidden; opacity: 0;
        transform: translateY(-8px) scale(.97);
        pointer-events: none;
        transition: opacity .2s, transform .2s cubic-bezier(.16,1,.3,1), visibility .2s;
    }
    .dropdown.show .dropdown-animated {
        visibility: visible; opacity: 1;
        transform: none; pointer-events: auto;
    }
    .search-toggle-btn { display: none !important; }
    .categories-icon-mobile { display: none !important; }
}

/* ══════════════════════════════
   SEARCH OVERLAY (mobile)
══════════════════════════════ */
.search-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 2000;
    padding: .75rem 1rem;
    background: var(--primary-color);
    border-bottom: 1px solid rgba(255,255,255,.15);
    box-shadow: 0 8px 24px rgba(0,0,0,.2);
    animation: slideDown .2s cubic-bezier(.16,1,.3,1);
}
.search-overlay.active { display: block; }
.search-overlay-form {
    display: flex;
    align-items: center;
    gap: .6rem;
    max-width: 1400px;
    margin: 0 auto;
}
.search-overlay-icon {
    color: rgba(255,255,255,.6);
    font-size: .9rem; flex-shrink: 0;
}
.search-overlay-form input {
    flex: 1;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 999px;
    padding: .55rem 1rem;
    color: #fff; font-size: .95rem;
    outline: none;
}
.search-overlay-form input::placeholder { color: rgba(255,255,255,.5); }
.search-close-btn {
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.2);
    border-radius: 50%;
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; cursor: pointer; flex-shrink: 0;
    transition: background .2s;
}
.search-close-btn:hover { background: rgba(255,255,255,.28); }

@keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════
   MOBILE DRAWER
══════════════════════════════ */
.mobile-drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1040;
    backdrop-filter: blur(2px);
    opacity: 0;
    transition: opacity .3s;
}
.mobile-drawer-overlay.active {
    display: block;
    opacity: 1;
}

.mobile-drawer {
    position: fixed;
    top: 0; left: 0; bottom: 0;
    width: 300px;
    background: #fff;
    z-index: 1050;
    transform: translateX(-100%);
    transition: transform .3s cubic-bezier(.16,1,.3,1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 8px 0 40px rgba(0,0,0,.2);
}
.mobile-drawer.active {
    transform: translateX(0);
}

.drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: var(--primary-color);
    flex-shrink: 0;
}
.drawer-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
}
.drawer-close-btn {
    background: rgba(255,255,255,.15);
    border: none;
    border-radius: 50%;
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    cursor: pointer;
    transition: background .2s;
    font-size: .9rem;
}
.drawer-close-btn:hover { background: rgba(255,255,255,.28); }

.drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: .75rem 0;
}

/* Sección del drawer (siempre expandida) */
.drawer-section {
    margin-bottom: .25rem;
}

.drawer-section-title {
    display: flex;
    align-items: center;
    padding: .75rem 1.25rem .5rem;
    font-size: .7rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #9ca3af;
}

.drawer-section-content {
    /* Siempre visible, sin colapso */
}

.drawer-item {
    display: flex;
    align-items: center;
    padding: .65rem 1.25rem;
    font-size: .9rem;
    color: #374151;
    text-decoration: none;
    transition: background .15s, color .15s;
    border-radius: 0;
}
.drawer-item:hover {
    background: #f3f4f6;
    color: #111;
}
.drawer-item.fw-semibold { font-weight: 600; }
.drawer-item-danger { color: #ef4444 !important; }
.drawer-item-danger:hover { background: #fef2f2 !important; }

.drawer-divider {
    height: 1px;
    background: #f0f0f0;
    margin: .35rem 1.25rem;
}

/* ══════════════════════════════
   MOBILE  ≤ 991px
══════════════════════════════ */
@media (max-width: 991px) {
    .navbar-inner {
        padding: .5rem 1rem;
        gap: .5rem;
        display: flex;
        align-items: center;
    }

    .hamburger-btn { display: flex; order: 1; }

    /* Logo solo a la derecha */
    .navbar-brand-custom {
        margin-left: auto;
        order: 10;
    }
    .navbar-logo { width: 38px; height: 38px; }

    /* Centro: icono búsqueda pegado a hamburguesa */
    .navbar-center {
        order: 3;
        flex: 0 0 auto;
        gap: 0;
    }

    /* Carrito junto al grupo izquierdo */
    .navbar-right {
        order: 2;
        gap: 0;
    }

    /* Ocultar elementos desktop en mobile */
    .search-wrapper,
    .user-name,
    .arrow-icon,
    .btn-login-label,
    .categories-label,
    .categories-arrow,
    .desktop-categories,
    .desktop-user,
    .desktop-login { 
        display: none !important; 
    }

    /* Iconos modo móvil */
    .cart-btn,
    .search-toggle-btn {
        width: 44px !important;
        height: 44px !important;
        border-radius: 12px !important;
        padding: 0 !important;
        background: transparent !important;
        border: none !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        color: #fff !important;
    }
    .cart-btn:active, .search-toggle-btn:active {
        background: rgba(255,255,255,.12) !important;
    }

    /* Search overlay en mobile */
    .search-overlay {
        left: 1rem !important;
        right: 1rem !important;
        width: calc(100% - 2rem) !important;
        top: 8px !important;
        border-radius: 16px !important;
        padding: 0.5rem 1rem !important;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ── Search overlay ── */
    const searchToggle = document.getElementById('searchToggle');
    const searchClose = document.getElementById('searchClose');
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('searchOverlayInput');

    if (searchToggle && searchOverlay) {
        searchToggle.addEventListener('click', function () {
            searchOverlay.classList.add('active');
            setTimeout(() => { if (searchInput) searchInput.focus(); }, 100);
        });
    }
    if (searchClose && searchOverlay) {
        searchClose.addEventListener('click', function () {
            searchOverlay.classList.remove('active');
        });
    }
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && searchOverlay && searchOverlay.classList.contains('active')) {
            searchOverlay.classList.remove('active');
        }
    });

    /* ── Mobile Drawer ── */
    const hamburgerBtn = document.getElementById('hamburgerBtn');
    const drawerOverlay = document.getElementById('drawerOverlay');
    const mobileDrawer = document.getElementById('mobileDrawer');
    const drawerClose = document.getElementById('drawerClose');

    function openDrawer() {
        mobileDrawer.classList.add('active');
        drawerOverlay.classList.add('active');
        hamburgerBtn.classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
        mobileDrawer.classList.remove('active');
        drawerOverlay.classList.remove('active');
        hamburgerBtn.classList.remove('open');
        document.body.style.overflow = '';
    }

    if (hamburgerBtn) hamburgerBtn.addEventListener('click', openDrawer);
    if (drawerClose) drawerClose.addEventListener('click', closeDrawer);
    if (drawerOverlay) drawerOverlay.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && mobileDrawer && mobileDrawer.classList.contains('active')) {
            closeDrawer();
        }
    });

    /* ── Hover highlight (desktop) ── */
    const items = ['.nav-user-btn', '.cart-btn', '.btn-login', '.search-toggle-btn', '.categories-btn'];
    items.forEach(sel => {
        document.querySelectorAll(sel).forEach(el => {
            el.addEventListener('mousedown', () => el.style.backgroundColor = 'rgba(255,255,255,0.12)');
            el.addEventListener('mouseup', () => el.style.backgroundColor = '');
            el.addEventListener('mouseleave', () => el.style.backgroundColor = '');
        });
    });
});

/* ── Drawer subcategory accordion (vanilla JS, no jQuery/BS collapse needed) ── */
function toggleDrawerSub(trigger) {
    const targetId = trigger.getAttribute('data-target');
    const panel = document.getElementById(targetId);
    const arrow = trigger.querySelector('.drawer-cat-arrow');
    const isOpen = panel.style.maxHeight && panel.style.maxHeight !== '0px';

    // Close all other open panels first
    document.querySelectorAll('.drawer-subcats').forEach(function(p) {
        p.style.maxHeight = '0px';
    });
    document.querySelectorAll('.drawer-cat-toggle').forEach(function(t) {
        t.setAttribute('aria-expanded', 'false');
        const a = t.querySelector('.drawer-cat-arrow');
        if (a) a.style.transform = 'rotate(0deg)';
    });

    // Toggle the clicked one
    if (!isOpen) {
        panel.style.maxHeight = panel.scrollHeight + 200 + 'px';
        trigger.setAttribute('aria-expanded', 'true');
        if (arrow) arrow.style.transform = 'rotate(180deg)';
    }
}
</script>