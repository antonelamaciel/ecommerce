<div class="header-wrapper fixed-top" style="z-index: 1030; transition: all 0.3s ease;">
<nav class="navbar-custom">
    <div class="navbar-inner">


        <!-- IZQUIERDA: HAMBURGUESA (mobile) -->
        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Menú" type="button">
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
            <span class="hamburger-line"></span>
        </button>

        <!-- LOGO -->
        <a class="navbar-brand-custom" href="{{ path('home') }}">
            {% if personalize and personalize.logo %}
                <img src="{{ asset('uploads/logo/' ~ personalize.logo) }}" alt="Logo" class="navbar-logo">
            {% else %}
                <span class="brand-text">{{ personalize.companyName ?? 'Empresa' }}</span>
            {% endif %}
        </a>

        <!-- CENTRO: BUSCADOR + CATEGORÍAS -->
        <div class="navbar-center">
            <form action="{{ path('product') }}" method="GET" class="search-wrapper position-relative" id="desktopSearchForm">
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="search" name="string" id="desktopSearchInput" placeholder="Buscar…" autocomplete="off">
                </div>
                <!-- Desktop Live Search Dropdown -->
                <div id="desktopSearchDropdown" class="dropdown-menu w-100 shadow-lg border-0" style="display:none; position: absolute; top: 100%; left: 0; right: 0; margin-top: 0.5rem; max-height: 400px; overflow-y: auto; z-index: 1050; border-radius: 14px;">
                    <div id="desktopSearchResults" class="list-group list-group-flush"></div>
                    <div id="desktopSearchLoading" class="text-center py-3 d-none text-muted"><div class="spinner-border spinner-border-sm"></div></div>
                    <div id="desktopSearchEmpty" class="text-center py-3 d-none text-muted small">No se encontraron coincidencias.</div>
                </div>
            </form>
            <button class="search-toggle-btn" id="searchToggle" aria-label="Buscar" type="button">
                <i class="bi bi-search"></i>
            </button>

            <div class="search-overlay position-relative" id="searchOverlay">
                <form action="{{ path('product') }}" method="GET" class="search-overlay-form position-relative" id="mobileSearchForm">
                    <i class="bi bi-search search-overlay-icon"></i>
                    <input type="search" name="string" id="searchOverlayInput" placeholder="Buscar…" autocomplete="off">
                    <button type="button" class="search-close-btn" id="searchClose">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    <!-- Mobile Live Search Dropdown -->
                    <div id="mobileSearchDropdown" class="dropdown-menu w-100 shadow-lg border-0" style="display:none; position: absolute; top: 100%; left: 0; right: 0; margin-top: 0.5rem; max-height: 250px; overflow-y: auto; z-index: 1050; border-radius: 14px;">
                        <div id="mobileSearchResults" class="list-group list-group-flush"></div>
                        <div id="mobileSearchLoading" class="text-center py-3 d-none text-muted"><div class="spinner-border spinner-border-sm"></div></div>
                        <div id="mobileSearchEmpty" class="text-center py-3 d-none text-muted small">No se encontraron productos.</div>
                    </div>
                </form>
            </div>

            <div class="dropdown desktop-categories">
                <button class="nav-pill-btn categories-btn" type="button"
                        id="dropdownMenuCategories"
                        data-toggle="dropdown"
                        data-display="static"
                        aria-haspopup="true"
                        aria-expanded="false">
                    <i class="bi bi-tags categories-icon-mobile"></i>
                    <span class="categories-label">Productos</span>
                    <i class="bi bi-chevron-down arrow-icon categories-arrow"></i>
                </button>
                <div class="dropdown-menu nav-dropdown shadow-xl dropdown-animated"
                     aria-labelledby="dropdownMenuCategories">
                    <a class="nav-dropdown-item fw-semibold" href="{{ path('product') }}">
                        <b>Todos los productos</b>
                    </a>
                    <div class="dropdown-divider"></div>
                    {% for category in allCategories %}
                        {% if category.subcategories|length > 0 %}
                            <div class="nav-category-group">
                                <a class="nav-dropdown-item d-flex align-items-center justify-content-between" href="#" data-bs-toggle="collapse" data-bs-target="#collapseDesktopCat{{ category.id }}" aria-expanded="false" onclick="event.preventDefault(); event.stopPropagation(); $('#collapseDesktopCat{{ category.id }}').collapse('toggle'); let exp = this.getAttribute('aria-expanded') === 'true'; this.setAttribute('aria-expanded', !exp);">
                                    <span><i class="bi bi-tag opacity-50 mr-2"></i>{{ category.name }}</span>
                                    <i class="bi bi-chevron-down opacity-50 ms-2" style="font-size: 0.75rem; transition: transform 0.2s;"></i>
                                </a>
                                <div class="collapse" id="collapseDesktopCat{{ category.id }}">
                                    <div class="ps-4 pe-2 py-1 mb-1 border-start ms-3 mt-1" style="border-color: #eee !important;">
                                        <a class="nav-dropdown-item py-1 text-primary fw-semibold" href="{{ path('product', {'categories[]': category.id}) }}" style="font-size: 0.8rem;">
                                            Ver todo en {{ category.name }}
                                        </a>
                                        {% for sub in category.subcategories %}
                                            <a class="nav-dropdown-item py-1 text-muted" href="{{ path('product', {'categories[]': category.id, 'subcategories[]': sub.id}) }}" style="font-size: 0.8rem;">
                                                {{ sub.name }}
                                            </a>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <a class="nav-dropdown-item" href="{{ path('product', {'categories[]': category.id}) }}">
                                <i class="bi bi-tag opacity-50 mr-2"></i>{{ category.name }}
                            </a>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- DERECHA: USUARIO + CARRITO -->
        <div class="navbar-right">
            {% if app.user %}
                <div class="dropdown desktop-user">
                    <a class="nav-user-btn" href="#" role="button"
                       data-toggle="dropdown" data-display="static" aria-haspopup="true" aria-expanded="false">
                        <div class="user-avatar"><i class="bi bi-person"></i></div>
                        <span class="user-name">{{ app.user.firstname }}</span>
                        <i class="bi bi-chevron-down arrow-icon"></i>
                    </a>
                    <ul class="dropdown-menu nav-dropdown shadow-xl dropdown-animated dropdown-menu-right">
                        <li class="dropdown-user-header">
                            <div class="user-avatar user-avatar-lg"><i class="bi bi-person-fill text-dark"></i></div>
                            <div>
                                <div class="fw-semibold">{{ app.user.firstname }}</div>
                                <small class="text-muted">Mi cuenta</small>
                            </div>
                        </li>
                        <li><div class="dropdown-divider"></div></li>
                        <li><a class="nav-dropdown-item" href="{{ path('account') }}"><i class="bi bi-person mr-2"></i>Mi Perfil</a></li>
                        <li><a class="nav-dropdown-item" href="{{ path('account_orders') }}"><i class="bi bi-bag-check mr-2"></i>Mis Pedidos</a></li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><div class="dropdown-divider"></div></li>
                            <li><a class="nav-dropdown-item" href="/admin"><i class="bi bi-speedometer2 mr-2"></i>Administración</a></li>
                        {% endif %}
                        <li><div class="dropdown-divider"></div></li>
                        <li><a class="nav-dropdown-item text-danger" href="{{ path('app_logout') }}"><i class="bi bi-box-arrow-right mr-2"></i>Cerrar Sesión</a></li>
                    </ul>
                </div>
            {% else %}
                <a class="btn-login desktop-login" href="{{ path('app_login') }}">
                    <i class="bi bi-person mr-1"></i><span class="btn-login-label">Ingresar/Registrarse</span>
                </a>
            {% endif %}

            <div class="cart-btn-container">
                <a href="{{ path('cart') }}" class="cart-btn" aria-label="Ver carrito">
                    <i class="bi bi-cart2 fs-5"></i>
                    {% if cartCount > 0 %}
                        <span class="cart-badge">{{ cartCount }}</span>
                    {% endif %}
                </a>
                <div id="cartNotification" class="cart-added-toast">
                    <i class="bi bi-check-lg"></i>
                    <span>Producto agregado</span>
                </div>
            </div>
        </div>

    </div>
</nav>

{% if bannerBundles is defined and bannerBundles %}
    {% for bundle in bannerBundles %}
        <div class="bundle-banner-full marquee-container" style="background-color: {{ bundle.bannerColor ?? '#1a1a1a' }}; width: 100vw; padding: 0.6rem 0; color: white; border-bottom: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
            <div class="marquee-content" style="font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.05rem; letter-spacing: 0.02em;">
                {% set repeatedText %}
                    {{ bundle.bannerText }} &nbsp;&nbsp;•&nbsp;&nbsp;
                    {{ bundle.bannerText }} &nbsp;&nbsp;•&nbsp;&nbsp;
                    {{ bundle.bannerText }} &nbsp;&nbsp;•&nbsp;&nbsp;
                    {{ bundle.bannerText }} &nbsp;&nbsp;•&nbsp;&nbsp;
                {% endset %}
                <span>{{ repeatedText|raw }}</span>
                <span>{{ repeatedText|raw }}</span>
            </div>
        </div>
    {% endfor %}
{% endif %}
</div>

<!-- MOBILE DRAWER REVAMP -->
<div class="mobile-drawer-overlay" id="drawerOverlay"></div>
<div class="mobile-drawer" id="mobileDrawer">
    <div class="drawer-header-modern">
        <div class="d-flex align-items-center gap-3">
             {% if personalize and personalize.logo %}
                <img src="{{ asset('uploads/logo/' ~ personalize.logo) }}" alt="Logo" class="mini-drawer-logo">
            {% else %}
                <span class="mini-brand-text">{{ personalize.companyName ?? 'Empresa' }}</span>
            {% endif %}
        </div>
        <button class="drawer-close-btn-modern" id="drawerCloseModern" aria-label="Cerrar menú">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>

    <div class="drawer-body-modern">
        {# User Section #}
        {% if app.user %}
            <div class="drawer-user-section animate-item" style="--delay: 1">
                <div class="drawer-avatar">
                    {{ app.user.firstname|first|upper }}
                </div>
                <div class="drawer-user-info">
                    <span class="drawer-greeting">Hola,</span>
                    <span class="drawer-username">{{ app.user.firstname }} <span class="wave-emoji">👋</span></span>
                </div>
            </div>
        {% else %}
            <a href="{{ path('app_login') }}" class="drawer-login-prompt animate-item" style="--delay: 1">
                <div class="icon-circle">
                    <i class="bi bi-person"></i>
                </div>
                <span>Ingresar / Registrarse</span>
                <i class="bi bi-chevron-right ms-auto small opacity-50"></i>
            </a>
        {% endif %}

        <div class="drawer-nav-group mt-4">
            <a class="drawer-link animate-item" style="--delay: 2" href="{{ path('home') }}">
                <i class="bi bi-house-door"></i>
                <span>Inicio</span>
            </a>

            <div class="drawer-link-expandable animate-item" style="--delay: 3">
                <button class="drawer-link w-100 border-0 bg-transparent mb-1" onclick="toggleDrawerSubModern('drawerSubProducts', this)">
                    <i class="bi bi-grid"></i>
                    <span>Productos</span>
                    <i class="bi bi-chevron-down ms-auto chevron-anim"></i>
                </button>
                <div class="drawer-sub-container" id="drawerSubProducts">
                    <a href="{{ path('product') }}" class="drawer-sub-link fw-bold text-primary">Ver toda la tienda</a>
                    {% for category in allCategories %}
                        <div class="category-item-wrap">
                            <a href="{{ path('product', {'categories[]': category.id}) }}" class="drawer-sub-link d-flex justify-content-between align-items-center">
                                <span>{{ category.name }}</span>
                                {% if category.subcategories|length > 0 %}
                                    <button class="sub-toggle-btn" onclick="event.preventDefault(); event.stopPropagation(); toggleDrawerSubModern('sub-cat-{{ category.id }}', this.parentElement)">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                {% endif %}
                            </a>
                            {% if category.subcategories|length > 0 %}
                                <div class="drawer-inner-sub" id="sub-cat-{{ category.id }}">
                                    {% for sub in category.subcategories %}
                                        <a href="{{ path('product', {'categories[]': category.id, 'subcategories[]': sub.id}) }}" class="drawer-inner-link">
                                            {{ sub.name }}
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="drawer-separator animate-item" style="--delay: 4"></div>

        <div class="drawer-nav-group">
            <span class="drawer-label animate-item" style="--delay: 5">Mi Cuenta</span>
            {% if app.user %}
                <a class="drawer-link animate-item" style="--delay: 6" href="{{ path('account') }}">
                    <i class="bi bi-person"></i>
                    <span>Mi Perfil</span>
                </a>
                <a class="drawer-link animate-item" style="--delay: 7" href="{{ path('account_orders') }}">
                    <i class="bi bi-bag-check"></i>
                    <span>Mis Pedidos</span>
                </a>
                {% if is_granted('ROLE_ADMIN') %}
                    <a class="drawer-link animate-item text-danger" style="--delay: 8" href="/admin">
                        <i class="bi bi-speedometer2"></i>
                        <span class="fw-bold">Administración</span>
                    </a>
                {% endif %}
                <a class="drawer-link animate-item text-muted mt-2" style="--delay: 9" href="{{ path('app_logout') }}">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Cerrar Sesión</span>
                </a>
            {% else %}
                 <a class="drawer-link animate-item" style="--delay: 6" href="{{ path('app_login') }}">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Iniciar Sesión</span>
                </a>
            {% endif %}
        </div>
    </div>
</div>

<style>
/* ── Marquee Animation ── */
.marquee-container {
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    display: flex;
    align-items: center;
}
.marquee-content {
    display: inline-block;
    animation: marquee-animation 40s linear infinite;
}
.marquee-content span {
    display: inline-block;
}
@keyframes marquee-animation {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}

/* ── Base ── */
.navbar-custom {
    background: var(--primary-color);
    border-bottom: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 4px 24px rgba(0,0,0,.15);
    z-index: 1030;
}
.navbar-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: .65rem 2rem;
}

/* Desktop: logo a la izquierda, items a la derecha */
@media (min-width: 992px) {
    .navbar-center {
        margin-left: auto;
    }
}

/* ── Hamburguesa (oculto en desktop) ── */
.hamburger-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px; height: 44px;
    background: transparent;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: background .2s;
}
.hamburger-btn:hover { background: rgba(255,255,255,.15); }
.hamburger-btn:active { background: rgba(255,255,255,.12); }
.hamburger-line {
    display: block;
    width: 22px; height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: transform .25s, opacity .2s;
}
.hamburger-btn.open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger-btn.open .hamburger-line:nth-child(2) { opacity: 0; }
.hamburger-btn.open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Logo ── */
.navbar-brand-custom {
    flex-shrink: 0;
    text-decoration: none;
    transition: opacity .2s, transform .2s;
}
.navbar-brand-custom:hover { opacity: .8; transform: scale(1.02); }
.navbar-logo {
    height: 100px;
    object-fit: cover;
    display: block;
}
.brand-text { font-size: 1.5rem; font-weight: 800; color: #fff; }

/* ── Centro ── */
.navbar-center {
    display: flex;
    align-items: center;
    gap: .75rem;
}
.search-wrapper { width: 260px; }
.search-box { position: relative; display: flex; align-items: center; }
.search-icon {
    position: absolute; left: 11px;
    color: rgba(255,255,255,.65); font-size: .78rem;
    pointer-events: none;
}
.search-box input {
    width: 100%;
    /* Misma altura que .nav-pill-btn: padding .5rem + line-height 1.25 + font .875rem = ~34px */
    padding: .63rem .85rem .63rem 2.1rem;
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,0.2) !important;
    border-radius: 999px;
    color: #fff; font-size: .875rem; line-height: 1.25;
    outline: none;
    transition: background .2s, border-color .2s;
}
.search-box input::placeholder { color: rgba(255,255,255,.5); }
.search-box input:focus {
    background: rgba(255,255,255,.22);
    border-color: transparent !important;
}

/* ── Botón Categorías (desktop) ── */
.nav-pill-btn {
    display: flex; align-items: center; gap: .4rem;
    background: rgba(255,255,255,.15);
    border: none !important;
    color: #fff;
    border-radius: 999px;
    padding: .5rem 1.15rem;
    font-size: .875rem; font-weight: 600;
    white-space: nowrap; cursor: pointer;
    transition: background .2s;
}
.nav-pill-btn:hover, .dropdown.show .nav-pill-btn {
    background: rgba(255,255,255,.25);
}

/* ── Derecha (usuario + carrito) ── */
.navbar-right {
    display: flex; align-items: center;
    gap: .6rem;
}

/* Usuario */
.nav-user-btn {
    display: flex; align-items: center; gap: .5rem;
    text-decoration: none; color: #fff;
    border-radius: 999px;
    padding: .5rem 0.5rem;
    border: none !important;
    font-size: .9rem; font-weight: 600;
    transition: background .2s;
}
.nav-user-btn:hover, .dropdown.show .nav-user-btn {
    background: rgba(255,255,255,.15);
}
.user-avatar {
    width: 20px; height: 20px; border-radius: 50%;
    font-size: 1.2rem;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; color: #fff;
}
.user-avatar-lg { width: 44px; height: 44px; font-size: 1.2rem; }
.dropdown-user-header {
    display: flex; align-items: center; gap: .85rem;
    padding: 1rem 1.25rem; list-style: none;
}

/* Login */
.btn-login {
    display: flex; align-items: center;
    text-decoration: none; color: #fff;
    border: none !important;
    border-radius: 999px;
    padding: .45rem 1.1rem;
    font-size: .875rem; font-weight: 600;
    white-space: nowrap;
    transition: background .2s, color .2s;
}
.btn-login:hover { background: #fff; color: var(--primary-color); }

/* Carrito */
.cart-btn {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    color: #fff; text-decoration: none;
    border: none !important;
    transition: background .2s;
}
.cart-btn:hover { background: rgba(255,255,255,.15); color: #fff; }
.cart-badge {
    position: absolute; top: 1px; right: 1px;
    background: #000000 !important; color: #ffffff !important;
    font-size: .63rem; font-weight: 900;
    min-width: 17px; height: 17px;
    border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    padding: 0 3px;
    border: none !important;
}

/* ── Cart Notification Toast ── */
.cart-btn-container {
    position: relative;
    display: flex;
}
.cart-added-toast {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    background: #ffffff;
    color: #111;
    padding: 10px 18px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
    z-index: 2000;
    border: 1px solid #eee;
    opacity: 0;
    transform: translateY(-10px) scale(0.95);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
    font-weight: 600;
}
body.dark-mode .cart-added-toast {
    background: #1a1a1a !important;
    color: #ffffff !important;
    border-color: rgba(255,255,255,0.1) !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4) !important;
}
.cart-added-toast.show {
    opacity: 1;
    transform: translateY(0) scale(1);
}
.cart-added-toast i {
    color: #2fb344;
    font-size: 1.2rem;
    background: rgba(47, 179, 68, 0.1);
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
}
.cart-added-toast span {
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 700;
}
@media (max-width: 991px) {
    .cart-added-toast {
        right: -65px;
        padding: 6px 12px;
        gap: 6px;
    }
    .cart-added-toast i {
        width: 24px; height: 24px; font-size: 1rem;
    }
    .cart-added-toast span {
        font-size: 0.8rem;
    }
}


/* ── Dropdown ── */
.navbar-center .dropdown,
.navbar-right .dropdown {
    position: relative;
}

.nav-dropdown {
    border: 1px solid rgba(0,0,0,.06) !important;
    border-radius: 14px !important;
    padding: .5rem !important;
    min-width: 220px;
    margin-top: 0 !important;
    z-index: 1050;
    overflow: hidden;
    position: absolute !important;
    top: 100% !important;
    left: 0 !important;
    right: auto !important;
}

/* Dropdown usuario: alineado a la derecha del botón */
.dropdown-menu-right.nav-dropdown {
    left: auto !important;
    right: 0 !important;
}

.nav-user-btn, .cart-btn, .btn-login, .categories-btn, .search-toggle-btn {
    outline: none !important;
    box-shadow: none !important;
    transition: background-color 0.2s ease;
}
.nav-user-btn:active, .cart-btn:active, .btn-login:active,
.categories-btn:active, .search-toggle-btn:active {
    background-color: rgba(255, 255, 255, 0.15) !important;
}
*:focus { outline: none !important; }

.nav-dropdown-item {
    display: flex; align-items: center;
    border-radius: 9px;
    padding: .6rem 1rem;
    font-size: .875rem; color: #374151;
    text-decoration: none;
    transition: background .15s, color .15s, transform .15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
}
.nav-dropdown-item span,
.nav-dropdown-item b {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.nav-dropdown-item:hover { background: #f3f4f6; color: #111; transform: translateX(3px); }
.nav-dropdown-item.text-danger:hover { background: #fef2f2; color: #ef4444; }

body.dark-mode .nav-dropdown-item:hover { background: #111 !important; color: #fff !important; }
body.dark-mode .nav-dropdown-item.text-danger:hover { background: #3c1414 !important; color: #ff6b6b !important; }
.shadow-xl { box-shadow: 0 16px 48px rgba(0,0,0,.14) !important; }
.arrow-icon { font-size: .75rem; opacity: .7; transition: transform .25s; }
.dropdown.show .arrow-icon { transform: rotate(180deg); opacity: 1; }
[aria-expanded="true"] .bi-chevron-down { transform: rotate(180deg); opacity: 1; }

@media (min-width: 992px) {
    .dropdown-animated {
        display: block !important;
        visibility: hidden; opacity: 0;
        transform: translateY(-8px) scale(.97);
        pointer-events: none;
        transition: opacity .2s, transform .2s cubic-bezier(.16,1,.3,1), visibility .2s;
    }
    .dropdown.show .dropdown-animated {
        visibility: visible; opacity: 1;
        transform: none; pointer-events: auto;
    }
    .search-toggle-btn { display: none !important; }
    .categories-icon-mobile { display: none !important; }
}

/* ══════════════════════════════
   SEARCH OVERLAY (mobile)
══════════════════════════════ */
.search-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 2000;
    padding: .75rem 1rem;
    background: var(--primary-color);
    border-bottom: 1px solid rgba(255,255,255,.15);
    box-shadow: 0 8px 24px rgba(0,0,0,.2);
    animation: slideDown .2s cubic-bezier(.16,1,.3,1);
}
.search-overlay.active { display: block; }
.search-overlay-form {
    display: flex;
    align-items: center;
    gap: .6rem;
    max-width: 1400px;
    margin: 0 auto;
}
.search-overlay-icon {
    color: rgba(255,255,255,.6);
    font-size: .9rem; flex-shrink: 0;
}
.search-overlay-form input {
    flex: 1;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,0.2) !important;
    border-radius: 999px;
    padding: .55rem 1rem;
    color: #fff; font-size: .95rem;
    outline: none;
}
.search-overlay-form input::placeholder { color: rgba(255,255,255,.5); }
.search-close-btn {
    background: rgba(255, 255, 255, 0.15);
    border: none !important;
    border-radius: 50%;
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: var(--secondary-color, #fff) !important; cursor: pointer; flex-shrink: 0;
    transition: background .2s;
}
.search-close-btn:hover { background: rgba(255,255,255,.28); }

input[type="search"]::-webkit-search-cancel-button {
    filter: invert(1);
    cursor: pointer;
}
@keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════
   MOBILE DRAWER (Modern Revamp)
   ══════════════════════════════ */
.mobile-drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 2000;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transition: opacity 0.4s ease;
}
.mobile-drawer-overlay.active { display: block; opacity: 1; }

.mobile-drawer {
    position: fixed;
    top: 0; left: 0; bottom: 0;
    width: 320px;
    background: #ffffff;
    z-index: 2001;
    transform: translateX(-100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 15px 0 60px rgba(0,0,0,0.12);
    border-radius: 0 30px 30px 0;
}
.mobile-drawer.active { transform: translateX(0); }

.drawer-header-modern {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
    flex-shrink: 0;
}
.mini-drawer-logo { height: 40px; }
.mini-brand-text { font-weight: 800; font-size: 1.2rem; color: var(--primary-color); }

.drawer-close-btn-modern {
    background: #f1f3f5;
    border: none;
    border-radius: 12px;
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    color: #333;
    transition: all 0.2s ease;
}
.drawer-close-btn-modern:active { transform: scale(0.9); background: #e9ecef; }

.drawer-body-modern {
    flex: 1;
    overflow-y: auto;
    padding: 0 1.25rem 2rem;
    scrollbar-width: none;
}
.drawer-body-modern::-webkit-scrollbar { display: none; }

/* User Profile */
.drawer-user-section {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: #f8f9fa;
    border-radius: 20px;
    margin-bottom: 1rem;
}
.drawer-avatar {
    width: 50px; height: 50px;
    background: var(--primary-color);
    color: #fff;
    border-radius: 15px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; font-weight: 700;
}
.drawer-user-info { display: flex; flex-direction: column; }
.drawer-greeting { font-size: 0.8rem; color: #888; }
.drawer-username { font-weight: 700; font-size: 1.1rem; color: #222; }

.drawer-login-prompt {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: #f8f9fa;
    border-radius: 20px;
    text-decoration: none;
    color: #222;
    font-weight: 700;
}
.icon-circle {
    width: 44px; height: 44px;
    background: var(--primary-color);
    color: white;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem;
}

/* Nav links */
.drawer-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1.25rem;
    color: #333;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 0;
    transition: all 0.2s ease;
    text-align: left;
    border-bottom: 1px solid #f1f3f5;
}
.drawer-link i:first-child { font-size: 1.1rem; color: var(--primary-color); width: 22px; text-align: center; }
.drawer-link:hover, .drawer-link.active { background: #f8f9fa; color: #000; }

.chevron-anim { transition: transform 0.3s ease; font-size: 0.75rem; }
.drawer-link.open .chevron-anim { transform: rotate(180deg); }

.drawer-sub-container {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    padding-left: 1.5rem;
}
.drawer-sub-container.show { max-height: 2000px; padding-bottom: 1rem; }

.drawer-sub-link {
    display: flex;
    align-items: center;
    padding: 0.55rem 1.25rem;
    font-size: 0.85rem;
    color: #555;
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid #f8f9fa;
}
.sub-toggle-btn {
    border: none; background: #eee;
    width: 24px; height: 24px;
    border-radius: 6px; font-size: 0.7rem;
    display: flex; align-items: center; justify-content: center;
}

.drawer-inner-sub {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    padding-left: 1.5rem;
    border-left: 2px solid #f1f3f5;
    margin-left: 1.25rem;
}
.drawer-inner-sub.show { max-height: 500px; padding: 0.25rem 0; }
.drawer-inner-link {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 0.85rem;
    color: #888;
    text-decoration: none;
}

.drawer-separator { height: 1px; background: #f1f3f5; margin: 1.5rem 0.5rem; }
.drawer-label { display: block; padding: 0 1.25rem 0.75rem; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; color: #adb5bd; letter-spacing: 0.05em; }

/* Staggered load animation */
.mobile-drawer.active .animate-item {
    animation: drawerEntry 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--delay) * 0.04s);
    opacity: 0;
}

@keyframes drawerEntry {
    from { opacity: 0; transform: translateX(-15px); }
    to { opacity: 1; transform: translateX(0); }
}

.wave-emoji {
    display: inline-block;
    animation: handWave 2s infinite;
    transform-origin: 70% 70%;
    font-size: 1.1rem;
    vertical-align: middle;
}

@keyframes handWave {
    0% { transform: rotate( 0.0deg) }
   10% { transform: rotate(14.0deg) }
   20% { transform: rotate(-8.0deg) }
   30% { transform: rotate(14.0deg) }
   40% { transform: rotate(-4.0deg) }
   50% { transform: rotate(10.0deg) }
   60% { transform: rotate( 0.0deg) }
  100% { transform: rotate( 0.0deg) }
}

