    transition: background .2s;
}
.search-close-btn:hover { background: rgba(255,255,255,.28); }

input[type="search"]::-webkit-search-cancel-button {
    filter: invert(1);
    cursor: pointer;
}
@keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
}

/* ══════════════════════════════
