        </div>
        {% set firstVariant = null %}
        {% for option in product.options %}
            {% if option.isAvailable and not firstVariant %}
                {% for value in option.productOptionValues %}
                    {% if value.isAvailable and not firstVariant %}
                        {% set firstVariant = option.name ~ ': ' ~ value.name %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endfor %}
        {% set variantString = firstVariant %}
        <a href="{{ path('add_to_cart', {id: product.id, variants: variantString}) }}" class="pcard__buy-btn">
