                    {% for option in product.options %}
                        {% if option.isAvailable %}
                            <div class="qv-option-values {% if not loop.first %}d-none{% endif %}" 
                                 id="qv-option-all-{{ product.id }}-{{ option.id }}"
                                 data-group-name="{{ option.name }}">
                                <div class="d-flex flex-wrap gap-1 justify-content-center">
                                    {% for value in option.productOptionValues %}
                                        <button type="button" 
                                              class="btn btn-sm qv-value-btn {{ value.isAvailable ? '' : 'option-unavailable' }}" 
                                              data-value-name="{{ value.name }}"
                                              {% if not value.isAvailable %}disabled{% endif %}
                                              style="border: 1px solid {{ value.isAvailable ? 'var(--primary-color, #333)' : '#ccc' }}; color: {{ value.isAvailable ? '#000' : '#adb5bd' }}; background: transparent; font-size: 0.75rem; padding: 0.2rem 0.5rem; transition: all 0.2s;">
                                            {{ value.name }}
