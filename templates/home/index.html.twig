                            {% if option.isAvailable %}
                                <button type="button" 
                                        class="btn btn-sm btn-outline-dark rounded-pill px-3 qv-parent-btn {% if loop.first %}active{% endif %}" 
                                        data-target="qv-option-all-{{ product.id }}-{{ option.id }}"
                                        style="font-size: 0.7rem; border: 1.5px solid #ddd; font-weight: 700;">
                                    {{ option.name }}
                                </button>
                            {% endif %}
                        {% endfor %}
                    </div>

                    {# Children Containers #}
                    {% for option in product.options %}
                        {% if option.isAvailable %}
                            <div class="qv-option-values {% if not loop.first %}d-none{% endif %}" 
                                 id="qv-option-all-{{ product.id }}-{{ option.id }}"
                                 data-group-name="{{ option.name }}">
                                <div class="d-flex flex-wrap gap-1 justify-content-center">
                                    {% for value in option.productOptionValues %}
                                        <button type="button" 
                                              class="btn btn-sm qv-value-btn {{ value.isAvailable ? '' : 'option-unavailable' }}" 
                                              data-value-name="{{ value.name }}"
                                              {% if not value.isAvailable %}disabled{% endif %}
                                              style="border: 1px solid {{ value.isAvailable ? 'var(--primary-color, #333)' : '#ccc' }}; color: {{ value.isAvailable ? '#000' : '#adb5bd' }}; background: transparent; font-size: 0.75rem; padding: 0.2rem 0.5rem; transition: all 0.2s;">
                                            {{ value.name }}
                                        </button>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
      </article>
    {% endfor %}
  </div>

  <div class="text-center mt-5" id="load-more-container">
    <button id="load-more-btn" class="btn-load-more">
      Ver más productos <i class="bi bi-chevron-down"></i>
    </button>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const grid = document.getElementById('all-products-grid');
  if (!grid) return;

  const items = grid.querySelectorAll('.pcard');
  const btn = document.getElementById('load-more-btn');
  const container = document.getElementById('load-more-container');
  
  let visibleRows = 3;

  function getColumns() {
    return window.getComputedStyle(grid).getPropertyValue('grid-template-columns').split(' ').length;
  }

  function updateVisibility() {
    const cols = getColumns();
    const limit = visibleRows * cols;
    
    items.forEach((item, index) => {
      if (index < limit) {
        item.classList.remove('is-hidden');
      } else {
        item.classList.add('is-hidden');
      }
    });

    if (limit >= items.length) {
      container.style.display = 'none';
    } else {
      container.style.display = 'block';
    }
  }

  btn.addEventListener('click', function() {
    visibleRows += 3;
    updateVisibility();
  });

  // Re-calculate on resize to ensure exactly 3 rows are shown
  window.addEventListener('resize', updateVisibility);
  
  // Initial run
  updateVisibility();
});
</script>

{% endblock %}