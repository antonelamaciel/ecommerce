{% extends 'base.html.twig' %}

{% block title %}Envíos y devoluciones - {{ personalize.companyName ?? 'Empresa' }}{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --c-brand: var(--tertiary-color, #1a1a1a);
    --radius-md: 16px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --font-main: 'Outfit', sans-serif;
  }

  .content-wrap {
    font-family: var(--font-main);
    color: var(--c-ink);
    padding: 4rem 0 6rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 4rem;
    text-align: center;
  }
  .page-title {
    font-size: clamp(2.2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .card-premium {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    padding: 3rem;
    box-shadow: var(--shadow-soft);
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--c-brand);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  p {
    line-height: 1.7;
    color: var(--c-muted);
    margin-bottom: 1.5rem;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
    position: relative;
    color: var(--c-muted);
  }

  li::before {
    content: "\F26E";
    font-family: "bootstrap-icons";
    position: absolute;
    left: 0;
    color: var(--c-brand);
    font-weight: bold;
  }

  @media (max-width: 767px) {
    .card-premium { padding: 2rem; }
  }
</style>

<div class="content-wrap">
  <header class="page-header">
    <h1 class="page-title">Envíos y devoluciones</h1>
  </header>

  {% for item in contents %}
    <div class="card-premium">
      <h2>
        {% if item.icon %}
            <i class="bi {{ item.icon }}"></i>
        {% endif %}
        {{ item.title }}
      </h2>
      <div class="policy-content">
        {{ item.content|raw }}
      </div>
    </div>
  {% else %}
    <div class="text-center py-5">
        <p class="text-muted">No hay información de envíos o devoluciones disponible en este momento.</p>
    </div>
  {% endfor %}
</div>
{% endblock %}
