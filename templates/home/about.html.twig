{% extends 'base.html.twig' %}

{% block title %}Nosotros - {{ personalize.companyName ?? 'Empresa' }}{% endblock %}

{% block body %}
<style>

  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --c-brand: var(--tertiary-color, #1a1a1a);
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: var(--font-main), sans-serif;
  }

  .about-wrap {
    font-family: var(--font-main);
    color: var(--c-ink);
    padding: 2rem 0 6rem;
  }

  .hero-section {
    text-align: center;
    margin-bottom: 5rem;
    animation: fadeIn 0.8s var(--transition);
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: color-mix(in srgb, var(--c-brand) 8%, transparent);
    color: var(--c-brand);
    border-radius: 99px;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero-lead {
    font-size: 1.25rem;
    color: var(--c-muted);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .card-premium {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    padding: 3.5rem;
    box-shadow: var(--shadow-soft);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 767px) {
    .hero-title { font-size: 2.5rem; }
    .card-premium { padding: 2rem; }
  }

  /* ── Dark Mode Overrides for About Page ── */
  body.dark-mode {
    --c-bg: #121212;
    --c-surface: #1e1e1e;
    --c-border: #333;
    --c-ink: #f5f5f5;
    --c-muted: #b0b0b0;
    color: #f5f5f5;
  }
  body.dark-mode .hero-title { color: #ffffff; }
  body.dark-mode .card-premium {
    background-color: #1e1e1e !important;
    border-color: #333 !important;
    color: #ffffff !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2) !important;
  }
  body.dark-mode .content-body { color: #d0d0d0 !important; }
</style>

<div class="about-wrap">
  <section class="hero-section">
    <span class="hero-badge">Conoce más</span>
    <h1 class="hero-title">Sobre {{ personalize.companyName ?? 'nosotros' }}</h1>
  </section>

  <div class="about-content-sections">
    {% for item in contents %}
        <section class="card-premium mb-5">
          <h2 class="mb-4" style="color: var(--c-brand); font-weight: 800; letter-spacing: -0.02em;">{{ item.title }}</h2>
          <div class="content-body" style="color: var(--c-muted); line-height: 1.8; font-size: 1.1rem;">
            {{ item.content|raw }}
          </div>
        </section>
    {% else %}
        <div class="text-center py-5">
            <p class="text-muted">Próximamente más información sobre nosotros.</p>
        </div>
    {% endfor %}
  </div>
</div>
{% endblock %}