<div class="container py-5">
    <div class="row g-4 mb-5">
        <!-- Brand Section -->
        <div class="col-lg-4 col-md-6">
            <h4 class="text-white fw-bold mb-2">{{ personalize.companyName ?? 'Empresa' }}</h4>
            {% if personalize.instagram or personalize.twitter or personalize.linkedin or personalize.tiktok or personalize.youtube or personalize.whatsapp %}
                <p class="text-white-50 medium mb-2">
                    Nuestras Redes Sociales!
                </p>
                <div class="d-flex gap-2 mb-4">
                    {% if personalize.instagram %}
                        <a href="{{ personalize.instagram }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-instagram"></i></a>
                    {% endif %}
                    {% if personalize.twitter %}
                        <a href="{{ personalize.twitter }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-twitter"></i></a>
                    {% endif %}
                    {% if personalize.linkedin %}
                        <a href="{{ personalize.linkedin }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-linkedin"></i></a>
                    {% endif %}
                    {% if personalize.tiktok %}
                        <a href="{{ personalize.tiktok }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-tiktok"></i></a>
                    {% endif %}
                    {% if personalize.youtube %}
                        <a href="{{ personalize.youtube }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-youtube"></i></a>
                    {% endif %}
                    {% if personalize.whatsapp %}
                        <a href="https://wa.me/{{ personalize.whatsapp|replace({'+': '', ' ': '', '-': ''}) }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;"><i class="bi bi-whatsapp"></i></a>
                    {% endif %}
                </div>
            {% endif %}
        </div>

        <!-- Links Section -->
        <div class="col-lg-2 col-md-6">
            <h6 class="text-white fw-bold mb-4">Compañía</h6>
            <ul class="list-unstyled">
                <li class="mb-2"><a href="{{ path('about') }}" class="text-white-50 text-decoration-none hover-white">Nosotros</a></li>
                <li class="mb-2"><a href="{{ path('contact') }}" class="text-white-50 text-decoration-none hover-white">Contacto</a></li>
            </ul>
        </div>

        <div class="col-lg-3 col-md-6">
            <h6 class="text-white fw-bold mb-4">Ayuda</h6>
            <ul class="list-unstyled">
                <li class="mb-2"><a href="{{ path('shipping_returns') }}" class="text-white-50 text-decoration-none hover-white">Envíos y devoluciones</a></li>
                <li class="mb-2"><a href="{{ path('faq') }}" class="text-white-50 text-decoration-none hover-white">Preguntas frecuentes</a></li>
                <li class="mt-4">
                    <a href="{{ path('app_cancellation') }}" class="btn btn-sm px-4 py-2 rounded-pill fw-bold text-uppercase shadow btn-arrepentimiento" style="font-size: 0.75rem; background-color: var(--primary-color, #fff); color: #fff !important; border: none; letter-spacing: 0.05em; transition: all 0.2s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.3) !important;">
                        Botón de arrepentimiento
                    </a>
                </li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="col-lg-3 col-md-6">
            <h6 class="text-white fw-bold mb-4">Contacto</h6>
            <ul class="list-unstyled text-white-50 small">
                {% if personalize.address %}
                    <li class="mb-3 d-flex align-items-center gap-2">
                        <i class="mr-2 bi bi-geo-alt text-white"></i>
                        <span>{{ personalize.address }}, {{ personalize.city }}, {{ personalize.province }}</span>
                    </li>
                {% endif %}
                {% if personalize.whatsapp %}
                    <li class="mb-3 d-flex align-items-center gap-2">
                        <i class="mr-2 bi bi-whatsapp text-white"></i>
                        <span>{{ personalize.whatsapp }}</span>
                    </li>
                {% endif %}
                {% if personalize.email %}
                    <li class="mb-3 d-flex align-items-center gap-2">
                        <i class="mr-2 bi bi-envelope text-white"></i>
                        <span>{{ personalize.email }}</span>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>

    <!-- Bottom Section -->
    <div class="pt-4 border-top border-secondary border-opacity-25 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <p class="text-white-50 small mb-0">&copy; {{ "now"|date("Y") }} {{ personalize.companyName ?? 'Empresa' }}. Todos los derechos reservados.</p>
       <!-- <div class="d-flex gap-4">
            <a href="#" class="text-white-50 text-decoration-none small hover-white">Legal</a>
            <a href="#" class="text-white-50 text-decoration-none small hover-white mx-2">Privacidad</a>
            <a href="#" class="text-white-50 text-decoration-none small hover-white">Cookies</a>
        </div>-->
    </div>
</div>

<style>
.hover-white:hover {
    color: white !important;
}
.btn-arrepentimiento:hover {
    background-color: var(--primary-color) !important;
    filter: brightness(1.2);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.4) !important;
}
.ls-wide {
    letter-spacing: 0.1em;
}
</style>
