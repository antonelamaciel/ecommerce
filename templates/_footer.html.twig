<div class="container py-4 py-md-5">
    <div class="row g-3 g-md-4 mb-4 mb-md-5">
        <!-- Brand Section -->
        <div class="col-12 col-lg-4 col-md-6 mb-2 mb-md-0">
            <div class="d-flex flex-column flex-md-column gap-2">
                <h4 class="text-white fw-bold mb-0 ls-wide" style="font-size: 1.1rem;">{{ personalize.companyName ?? 'Empresa' }}</h4>
                {% if personalize.instagram or personalize.twitter or personalize.linkedin or personalize.tiktok or personalize.youtube or personalize.whatsapp %}
                    <div class="d-flex flex-wrap gap-2 mt-1">
                        {% if personalize.instagram %}
                            <a href="{{ personalize.instagram }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center mr-1" style="width: 28px; height: 28px;"><i class="bi bi-instagram" style="font-size: 0.8rem;"></i></a>
                        {% endif %}
                        {% if personalize.twitter %}
                            <a href="{{ personalize.twitter }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center mr-1" style="width: 28px; height: 28px;"><i class="bi bi-twitter" style="font-size: 0.8rem;"></i></a>
                        {% endif %}
                        {% if personalize.linkedin %}
                            <a href="{{ personalize.linkedin }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center mr-1" style="width: 28px; height: 28px;"><i class="bi bi-linkedin" style="font-size: 0.8rem;"></i></a>
                        {% endif %}
                        {% if personalize.tiktok %}
                            <a href="{{ personalize.tiktok }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center mr-1" style="width: 28px; height: 28px;"><i class="bi bi-tiktok" style="font-size: 0.8rem;"></i></a>
                        {% endif %}
                        {% if personalize.youtube %}
                            <a href="{{ personalize.youtube }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center mr-1" style="width: 28px; height: 28px;"><i class="bi bi-youtube" style="font-size: 0.8rem;"></i></a>
                        {% endif %}
                        {% if personalize.whatsapp %}
                            <a href="https://wa.me/{{ personalize.whatsapp|replace({'+': '', ' ': '', '-': ''}) }}" target="_blank" class="btn btn-outline-light btn-sm rounded-circle p-0 d-flex align-items-center justify-content-center mr-1" style="width: 28px; height: 28px;"><i class="bi bi-whatsapp" style="font-size: 0.8rem;"></i></a>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Links Section -->
        <div class="col-6 col-md-6 col-lg-2">
            <h6 class="text-white fw-bold mb-3" style="font-size: 0.9rem;">Compañía</h6>
            <ul class="list-unstyled">
                <li class="mb-1 mb-md-2"><a href="{{ path('about') }}" class="text-white-50 text-decoration-none hover-white">Nosotros</a></li>
                <li class="mb-1 mb-md-2"><a href="{{ path('contact') }}" class="text-white-50 text-decoration-none hover-white">Contacto</a></li>
            </ul>
        </div>

        <div class="col-6 col-md-6 col-lg-3">
            <h6 class="text-white fw-bold mb-3" style="font-size: 0.9rem;">Ayuda</h6>
            <ul class="list-unstyled">
                <li class="mb-1 mb-md-2"><a href="{{ path('shipping_returns') }}" class="text-white-50 text-decoration-none hover-white">Envíos y devoluciones</a></li>
                <li class="mb-1 mb-md-2"><a href="{{ path('faq') }}" class="text-white-50 text-decoration-none hover-white">Preguntas frecuentes</a></li>
                <li class="mt-3">
                    <a href="{{ path('app_cancellation') }}" class="btn btn-sm px-3 py-2 rounded-pill fw-bold text-uppercase shadow btn-arrepentimiento" style="font-size: 0.65rem; background-color: var(--tertiary-color, #fff); color: #fff !important; border: none; letter-spacing: 0.05em; transition: all 0.2s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.3) !important;">
                        Arrepentimiento
                    </a>
                </li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="col-12 col-md-6 col-lg-3">
            <h6 class="text-white fw-bold mb-3" style="font-size: 0.9rem;">Contacto</h6>
            <ul class="list-unstyled text-white-50 small">
                {% if personalize.address %}
                    <li class="mb-2 d-flex align-items-center gap-2">
                        <i class="mr-1 bi bi-geo-alt text-white"></i>
                        <span>{{ personalize.address }}, {{ personalize.city }}</span>
                    </li>
                {% endif %}
                {% if personalize.whatsapp %}
                    <li class="mb-2 d-flex align-items-center gap-2">
                        <i class="mr-1 bi bi-whatsapp text-white"></i>
                        <span>{{ personalize.whatsapp }}</span>
                    </li>
                {% endif %}
                {% if personalize.email %}
                    <li class="mb-2 d-flex align-items-center gap-2">
                        <i class="mr-1 bi bi-envelope text-white"></i>
                        <span>{{ personalize.email }}</span>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>

    <!-- Bottom Section -->
    <div class="pt-3 border-top border-secondary border-opacity-25 d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
        <p class="text-white-50 small mb-0 text-center text-md-start">&copy; {{ "now"|date("Y") }} {{ personalize.companyName ?? 'Empresa' }}. <br class="d-md-none"> <a href="https://monkai-web.netlify.app/" target="_blank" class="text-white-50 text-decoration-none hover-white">Desarrollado por "MONKAI"</a></p>
       <!-- <div class="d-flex gap-4">
            <a href="#" class="text-white-50 text-decoration-none small hover-white">Legal</a>
            <a href="#" class="text-white-50 text-decoration-none small hover-white mx-2">Privacidad</a>
            <a href="#" class="text-white-50 text-decoration-none small hover-white">Cookies</a>
        </div>-->
    </div>
</div>

<style>
.hover-white {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0.25rem 0.5rem;
    margin-left: -0.5rem;
    border-radius: 8px;
    display: inline-block;
}
.hover-white:hover {
    background-color: var(--primary-color) !important;
    color: var(--secondary-color) !important; /* Gris claro */
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}
.btn-arrepentimiento:hover {
    background-color: var(--tertiary-color) !important;
    filter: brightness(1.2);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.4) !important;
}
.ls-wide {
    letter-spacing: 0.1em;
}
</style>
