{% extends 'base.html.twig' %}

{% block title %}Mis pedidos{% endblock %}

{% block body %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --c-soft: #fcfaf7;
    
    /* Dynamic Brand Colors */
    --c-brand: var(--tertiary-color, #1a1a1a);
    --c-brand-light: color-mix(in srgb, var(--c-brand) 8%, white);
    
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  .orders-wrap {
    font-family: var(--font-main);
    color: var(--c-ink);
    padding: 3rem 0 5rem;
    animation: fadeUp .6s var(--transition) both;
  }

  /* Header */
  .orders-header {
    margin-bottom: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
  }
  .orders-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .orders-subtitle {
    color: var(--c-muted);
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }


  /* Table Card */
  .orders-card {
    background: var(--c-surface);
    border-radius: var(--radius-md);
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
  }

  .orders-table {
    width: 100%;
    border-collapse: collapse;
  }

  .orders-table th {
    background: var(--c-soft);
    padding: 1.25rem 1.5rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--c-muted);
    border-bottom: 1px solid var(--c-border);
  }

  .orders-table td {
    padding: 1.5rem;
    vertical-align: middle;
    border-bottom: 1px solid var(--c-border);
  }
  .orders-table tr:last-child td { border-bottom: none; }
  .orders-table tbody tr { transition: var(--transition); }
  .orders-table tbody tr:hover { background: #fdfcfb; }

  /* Elements */
  .qty-pill {
    background: var(--c-soft);
    padding: 0.4rem 0.8rem;
    border-radius: 30px;
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--c-brand);
  }

  .state-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1rem;
    border-radius: 30px;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .state-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: currentColor;
  }

  /* Status Colors */
  .state-0 { background: #fef2f2; color: #991b1b; }
  .state-1 { background: #eafcf1; color: #10b981; } /* Approved */
  .state-2 { background: #fffbe6; color: #d97706; } /* Prep */
  .state-3 { background: #eff6ff; color: #2563eb; } /* Sent */
  .state-4 { background: #fffbeb; color: #b45309; }
  .state-5 { background: #f1f5f9; color: #475569; text-decoration: line-through; }

  .order-price {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--c-ink);
  }
  .order-date { color: var(--c-muted); font-size: 0.9rem; }
  .ref-badge {
    background: #f8f9fa;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
  }

  .order-action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--c-brand);
    font-weight: 700;
    font-size: 0.9rem;
    text-decoration: none !important;
    transition: var(--transition);
  }
  .order-action:hover {
    transform: translateX(5px);
    opacity: 0.8;
  }

  /* Empty State */
  .orders-empty {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-soft);
  }
  .orders-empty i { font-size: 4rem; color: var(--c-border); margin-bottom: 1.5rem; }
  .btn-explore {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    background: var(--c-brand);
    color: #fff;
    padding: 1rem 2rem;
    border-radius: var(--radius-sm);
    font-weight: 700;
    text-decoration: none !important;
    transition: var(--transition);
  }
  .btn-explore:hover { filter: brightness(1.1); transform: translateY(-3px); color: #fff; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 991px) {
    .orders-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
  }
  @media (max-width: 767px) {
    .orders-card { overflow-x: visible; }
    .orders-table { min-width: 0; }
    .orders-table td, .orders-table th { padding: 1rem 0.75rem; }
  }

  /* ── Dark Mode Overrides ── */
  body.dark-mode {
    --c-bg: #121212;
    --c-surface: #1e1e1e;
    --c-border: #333;
    --c-ink: #f5f5f5;
    --c-muted: #b0b0b0;
    --c-soft: #2a2a2a;
  }
  body.dark-mode .orders-title { color: #ffffff !important; }
  body.dark-mode .orders-card, body.dark-mode .orders-empty { 
    background-color: #1e1e1e !important; 
    border-color: #333 !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
  }
  body.dark-mode .orders-table th { background-color: #2a2a2a !important; color: #ffffff !important; border-bottom-color: #333 !important; }
  body.dark-mode .orders-table td { border-bottom-color: #333 !important; }
  body.dark-mode .orders-table tbody tr:hover { background-color: #252525 !important; }
  body.dark-mode .order-price { color: #ffffff !important; }
  body.dark-mode .ref-badge { background-color: #2a2a2a !important; border-color: #444 !important; color: #b0b0b0 !important; }
  body.dark-mode .qty-pill { background-color: #2a2a2a !important; color: #ffffff !important; }
  
  /* Status Overrides for Dark Mode */
  body.dark-mode .state-0 { background: #331111 !important; color: #ff8080 !important; }
  body.dark-mode .state-1 { background: #06331a !important; color: #50e3a6 !important; }
  body.dark-mode .state-2 { background: #332100 !important; color: #ffda6a !important; }
  body.dark-mode .state-3 { background: #001a33 !important; color: #80c0ff !important; }
  body.dark-mode .state-4 { background: #332100 !important; color: #ffb84d !important; }
  body.dark-mode .state-5 { background: #2a2a2a !important; color: #666 !important; }
  body.dark-mode .btn-back:hover { color: #ffffff !important; }
</style>

<div class="orders-wrap">

  <!-- ── Header ── -->
  <div class="orders-header">
    <div>
      <h1 class="orders-title">Mis pedidos</h1>
      <p class="orders-subtitle">Gestiona y revisa el historial de tus compras</p>
    </div>
    <button type="button" onclick="window.history.back()" class="btn-back">
      <i class="bi bi-arrow-left"></i> Volver
    </button>
  </div>

  {% if orders %}

    <div class="orders-card">
      <table class="orders-table">
        <thead>
          <tr>
            <th class="d-none d-md-table-cell">Artículos</th>
            <th class="d-none d-md-table-cell">Estado</th>
            <th class="d-none d-md-table-cell">Total</th>
            <th>Fecha</th>
            <th class="d-none d-md-table-cell">ID del pedido</th>
            <th class="text-end">Acción</th>
          </tr>
        </thead>
        <tbody>
          {% for order in orders %}
            <tr>
              <td class="d-none d-md-table-cell">
                <span class="qty-pill">{{ order.totalQuantity }} unidades</span>
              </td>
              <td class="d-none d-md-table-cell">
                <div class="d-flex flex-column gap-1">
                  <span class="state-badge state-{{ order.state }}">
                    {{ order.state == 0 ? 'No pagado' :
                       order.state == 1 ? 'Pago aceptado' :
                       order.state == 2 ? 'En preparación' :
                       order.state == 3 ? 'Enviado/Retirado' :
                       order.state == 4 ? 'Pendiente' :
                       order.state == 5 ? 'Cancelado' : 'Estado ' ~ order.state }}
                  </span>
                  {% if order.paymentMethod %}
                    <span class="small text-muted" style="font-size: 0.65rem; margin-left: 0.5rem;">
                      {{ order.paymentMethod == 'cash' ? 'Efectivo' : (order.paymentMethod == 'transfer' ? 'Transferencia' : 'Mercado Pago') }}
                    </span>
                  {% endif %}
                </div>
              </td>
              <td class="d-none d-md-table-cell">
                <span class="order-price">
                  ARS {{ ((order.carrierPrice + order.total) / 100)|number_format(2, ',', '.') }}
                </span>
              </td>
              <td>
                <span class="order-date">{{ order.createdAt|date('d/m/Y') }}</span>
              </td>
              <td class="d-none d-md-table-cell">
                <span class="ref-badge">{{ order.reference }}</span>
              </td>
              <td class="text-end">
                <a href="{{ path('account_order', {'reference': order.reference}) }}" class="order-action">
                  Detalles <i class="bi bi-arrow-right d-md-inline"></i>
                </a>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

  {% else %}

    <div class="orders-empty">
      <i class="bi bi-bag-x"></i>
      <h2 class="orders-title mb-2">Aún no tienes pedidos</h2>
      <p class="text-muted">Cuando realices tu primera compra, aparecerá aquí.</p>
      <a href="{{ path('product') }}" class="btn-explore">
        <i class="bi bi-bag-plus"></i> Ir a la tienda
      </a>
    </div>

  {% endif %}

</div>

{% endblock %}