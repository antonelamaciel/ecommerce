{% extends 'base.html.twig' %}

{% block title %}Modificar contraseña - empresa{% endblock %}
{% block body %}
<style>
  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --c-brand: var(--tertiary-color, #1a1a1a);
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
  }

  .password-wrap {
    color: var(--c-ink);
    padding: 3rem 0 5rem;
    animation: fadeUp .6s var(--transition) both;
    max-width: 500px;
    margin: 0 auto;
  }

  .password-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .password-title {
    font-size: clamp(1.8rem, 4vw, 2.3rem);
    font-weight: 700;
    margin: 0;
  }
  .password-subtitle {
    color: var(--c-muted);
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .card-premium {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    box-shadow: var(--shadow-soft);
  }

  /* Form Styling */
  .password-wrap form > div { margin-bottom: 1.25rem; }
  
  .password-wrap form input[type="password"], 
  .password-wrap form input[type="text"], 
  .password-wrap form input[type="email"] {
    width: 100%;
    padding: 0.9rem 1.2rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--c-border);
    background: #fdfcfb;
    transition: var(--transition);
    font-size: 1rem;
    color: var(--c-ink);
  }
  .password-wrap form input:focus {
    outline: none;
    border-color: var(--c-brand);
    background: #fff;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-brand) 10%, transparent);
  }
  
  .password-wrap form input:disabled {
    background: var(--c-soft);
    color: var(--c-muted);
    cursor: not-allowed;
  }

  /* RepeatedType fields */
  .password-wrap form .password-field {
    margin-bottom: 1rem;
  }

  .password-wrap form button[type="submit"], .password-wrap .btn-outline-success {
    width: 100%;
    background: var(--c-brand) !important;
    color: #fff !important;
    border: none !important;
    padding: 1.1rem !important;
    border-radius: var(--radius-sm) !important;
    font-weight: 700 !important;
    font-size: 1.05rem !important;
    cursor: pointer;
    transition: var(--transition);
    margin-top: 1.5rem;
    display: block;
    text-align: center;
  }
  .password-wrap form button:hover, .password-wrap .btn-outline-success:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .password-wrap label {
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
    display: block;
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }


  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Dark Mode Overrides ── */
  body.dark-mode {
    --c-bg: #121212;
    --c-surface: #1e1e1e;
    --c-border: #333;
    --c-ink: #f5f5f5;
    --c-muted: #b0b0b0;
  }
  body.dark-mode .password-title { color: #ffffff !important; }
  body.dark-mode .card-premium { 
    background-color: #1e1e1e !important; 
    border-color: #333 !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
  }
  body.dark-mode .password-wrap form input[type="password"], 
  body.dark-mode .password-wrap form input[type="text"], 
  body.dark-mode .password-wrap form input[type="email"] {
    background-color: #2a2a2a !important;
    border-color: #444 !important;
    color: #ffffff !important;
  }
  body.dark-mode .password-wrap form input:focus {
    border-color: #ffffff !important;
    background-color: #333 !important;
    box-shadow: 0 0 0 4px rgba(255,255,255,0.1) !important;
  }
  body.dark-mode .password-wrap form button[type="submit"], body.dark-mode .password-wrap .btn-outline-success {
    background-color: #ffffff !important;
    color: #121212 !important;
  }
  body.dark-mode .btn-back:hover { color: #ffffff !important; }
</style>

<div class="password-wrap">
     <button type="button" onclick="window.history.back()" class="btn-back mt-1">
        <i class="bi bi-arrow-left"></i> Volver
    </button>
  <header class="password-header">
    <h1 class="password-title">Cambiar contraseña</h1>
    <p class="password-subtitle">Actualiza tu contraseña para mantener protegida tu cuenta.</p>
  </header>

  {% for message in app.flashes('notice') %}
      <div class="alert alert-danger alert-dismissible fade show mb-1" role="alert">
          <i class="bi bi-exclamation-triangle-fill mr-2"></i>
          {{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  {% endfor %}

  <div class="card-premium">
    {{ form(form) }}



  </div>

 
</div>
{% endblock %}
