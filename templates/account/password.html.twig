{% extends 'base.html.twig' %}

{% block title %}Modificar contraseña - empresa{% endblock %}
{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --c-brand: var(--primary-color, #1a1a1a);
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  .password-wrap {
    font-family: var(--font-main);
    color: var(--c-ink);
    padding: 3rem 0 5rem;
    animation: fadeUp .6s var(--transition) both;
    max-width: 500px;
    margin: 0 auto;
  }

  .password-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }
  .password-title {
    font-size: clamp(1.8rem, 4vw, 2.3rem);
    font-weight: 700;
    margin: 0;
  }
  .password-subtitle {
    color: var(--c-muted);
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .card-premium {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-md);
    padding: 2.5rem;
    box-shadow: var(--shadow-soft);
  }

  /* Form Styling */
  form > div { margin-bottom: 1.25rem; }
  
  form input[type="password"], 
  form input[type="text"], 
  form input[type="email"] {
    width: 100%;
    padding: 0.9rem 1.2rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--c-border);
    background: #fdfcfb;
    transition: var(--transition);
    font-size: 1rem;
    color: var(--c-ink);
  }
  form input:focus {
    outline: none;
    border-color: var(--c-brand);
    background: #fff;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--c-brand) 10%, transparent);
  }
  
  form input:disabled {
    background: var(--c-soft);
    color: var(--c-muted);
    cursor: not-allowed;
  }

  /* RepeatedType fields */
  form .password-field {
    margin-bottom: 1rem;
  }

  form button[type="submit"], .btn-outline-success {
    width: 100%;
    background: var(--c-brand) !important;
    color: #fff !important;
    border: none !important;
    padding: 1.1rem !important;
    border-radius: var(--radius-sm) !important;
    font-weight: 700 !important;
    font-size: 1.05rem !important;
    cursor: pointer;
    transition: var(--transition);
    margin-top: 1.5rem;
    display: block;
    text-align: center;
  }
  form button:hover, .btn-outline-success:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  label {
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
    display: block;
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
    color: var(--c-muted);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none !important;
    transition: var(--transition);
    width: 100%;
  }
  .btn-back:hover {
    color: var(--c-brand);
    transform: translateX(-5px);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="password-wrap">
  <header class="password-header">
    <h1 class="password-title">Cambiar contraseña</h1>
    <p class="password-subtitle">Actualiza tu contraseña para mantener protegida tu cuenta.</p>
  </header>

  {% for message in app.flashes('notice') %}
      <div class="alert alert-danger alert-dismissible fade show mb-2" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2"></i>
          {{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
  {% endfor %}

  <div class="card-premium">
    {{ form(form) }}

     <a href="{{ path('account') }}" class="btn-back text-dark">
        <i class="bi bi-arrow-left"></i> Volver a mi cuenta
    </a>

  </div>

 
</div>
{% endblock %}
