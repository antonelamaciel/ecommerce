{% extends 'base.html.twig' %}

{% block title %}Mis direcciones - {{ personalize.companyName ?? 'Empresa' }}{% endblock %}

{% block body %}

<style>
  /* ── Tokens (Consistent with whole ecosystem) ── */
  :root {
    --c-bg: #fcfbf9;
    --c-surface: #ffffff;
    --c-border: #f0ede8;
    --c-ink: #1a1a1a;
    --c-muted: #696561;
    --radius-lg: 24px;
    --radius-md: 16px;
    --radius-sm: 10px;
    --shadow-soft: 0 10px 40px rgba(0,0,0,.04);
    --transition: .3s cubic-bezier(.4, 0, .2, 1);
    --font-main: 'Outfit', sans-serif;
  }

  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');

  body { 
    background: var(--c-bg); 
    font-family: var(--font-main);
    color: var(--c-ink);
  }

  .mt-page { margin-top: 3rem; margin-bottom: 5rem; }

  /* ── Header ── */
  .page-header {
    margin-bottom: 3rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .page-title {
    font-size: clamp(1rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .btn-add-address {
    background: var(--primary-color) !important;
    color: var(--tertiary-color) !important;
    border: 1px solid var(--tertiary-color) !important;
    padding: 0.75rem 1.5rem;
    border-radius: 99px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: var(--transition);
  }
  .btn-add-address:hover {
    filter: brightness(1.1); transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.1);
    color: #fff;
  }

  /* ── Mobile Tweaks ── */
  @media (max-width: 767px) {
    .mt-page { margin-top: 1.5rem; }
    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
      margin-bottom: 2rem;
    }
    .btn-add-address {
      padding: 0.45rem 1rem;
      font-size: 0.75rem;
    }
    .page-title {
      font-size: 1.4rem !important;
    }
    .address-card {
      padding: 1.25rem;
    }
  }

  /* ── Address Card ── */
  .address-card {
    background: var(--c-surface);
    border-radius: var(--radius-md);
    padding: 2rem;
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-soft);
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: var(--transition);
  }
  .address-card:hover {
    border-color: var(--tertiary-color, var(--c-ink));
    transform: translateY(-5px);
  }

  .address-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .address-card__title i { color: var(--tertiary-color, var(--c-ink)); }

  .address-card__text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--c-muted);
    flex: 1;
    margin-bottom: 1.5rem;
  }

  /* ── Actions ── */
  .address-card__actions {
    display: flex;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--c-border);
  }
  .action-link {
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--c-ink);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    transition: var(--transition);
  }
  .action-link:hover { color: var(--tertiary-color, var(--c-ink)); }
  .action-link.delete { color: #ef4444; }
  .action-link.delete:hover { opacity: 0.8; }

  /* ── Empty State ── */
  .empty-state {
    text-align: center;
    padding: 5rem 2rem;
    background: var(--c-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--c-border);
  }
  .empty-state i { font-size: 3.5rem; color: var(--c-border); margin-bottom: 1.5rem; display: block; }
  .empty-state p { color: var(--c-muted); font-size: 1.1rem; }

  /* ── Dark Mode Overrides ── */
  body.dark-mode {
    --c-bg: #121212;
    --c-surface: #1e1e1e;
    --c-border: #333;
    --c-ink: #f5f5f5;
    --c-muted: #b0b0b0;
  }
  body.dark-mode .page-title { color: #ffffff !important; }
  body.dark-mode .address-card, body.dark-mode .empty-state {
    background-color: #1e1e1e !important;
    border-color: #333 !important;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3) !important;
  }
  body.dark-mode .address-card:hover { border-color: #ffffff !important; background-color: #252525 !important; }
  body.dark-mode .address-card__title { color: #ffffff !important; }
  body.dark-mode .action-link { color: #ffffff !important; }
  body.dark-mode .action-link:hover { color: #ffffff !important; opacity: 0.8; }
  body.dark-mode .action-link.delete { color: #ef4444 !important; }
  body.dark-mode .address-card__actions { border-top-color: #333 !important; }
  body.dark-mode .btn-add-address { 
      background-color: var(--primary-color) !important; 
      color: var(--tertiary-color) !important; 
      border: 1px solid var(--tertiary-color) !important;
  }
  body.dark-mode .btn-add-address:hover { 
      background-color: #000000 !important; 
      border-color: #ffffff !important; 
      color: #ffffff !important; 
  }
  body.dark-mode .btn-back:hover { color: #ffffff !important; }
</style>

<div class="container mt-page">
    <button type="button" onclick="window.history.back()" class="btn-back mt-1">
        <i class="bi bi-arrow-left"></i> Volver
    </button>
    <header class="page-header">
        <div>
            <h5 class="page-title mt-2">Gestionar mis direcciones</h5>
            <p class="text-muted mt-2">Administra tus lugares de entrega guardados.</p>
        </div>
        <a href="{{ path('account_address_new') }}" class="btn-add-address">
            <i class="bi bi-plus-lg"></i> Añadir una dirección
        </a>
    </header>

    <div class="row g-4">
        {% for address in app.user.addresses %}
            <div class="col-md-6">
                <div class="address-card">
                    <div class="address-card__title">
                        <i class="bi bi-house-door-fill"></i>
                        {{ address.name }}
                    </div>
                    <div class="address-card__text">
                        <b>{{ address.firstname }} {{ address.lastname }}</b><br>
                        {{ address.address }}<br>
                        {{ address.postal }} {{ address.city }}<br>
                        {{ address.country }}<br>
                        {% if address.phone %}
                            <span class="small mt-2 d-block"><i class="bi bi-telephone pe-1"></i> {{ address.phone }}</span>
                        {% endif %}
                    </div>
                    <div class="address-card__actions">
                        <a href="{{ path('account_address_update', {id: address.id}) }}" class="action-link">
                            <i class="bi bi-pencil-square"></i> Editar
                        </a>
                        <a href="{{ path('account_address_delete', {id: address.id}) }}" class="action-link delete" 
                           onclick="return confirm('¿Estás seguro de que quieres eliminar esta dirección?')">
                            <i class="bi bi-trash3"></i> Eliminar
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="empty-state">
                    <i class="bi bi-geo"></i>
                    <p>No hay direcciones añadidas por el momento.</p>
                    <a href="{{ path('account_address_new') }}" class="btn-add-address d-inline-flex mt-3">
                        Configurar mi primera dirección
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>


</div>
{% endblock %}
